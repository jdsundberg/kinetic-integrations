{
  "swagger": "2.0",
  "info": { "title": "LegacyApp", "version": "1.0" },
  "host": "legacy.test",
  "basePath": "/api/v1",
  "schemes": ["https"],
  "securityDefinitions": {
    "basic": { "type": "basic" }
  },
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "parameters": [
          { "name": "limit", "in": "query", "type": "integer" }
        ],
        "responses": { "200": { "schema": { "type": "array", "items": { "type": "object" } } } }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create user",
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": {
            "type": "object",
            "required": ["email"],
            "properties": {
              "email": { "type": "string" },
              "name": { "type": "string" }
            }
          } }
        ],
        "responses": { "201": { "schema": { "type": "object", "properties": { "id": { "type": "integer" } } } } }
      }
    }
  }
}
