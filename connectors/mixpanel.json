{
  "id": "mixpanel",
  "service": "Mixpanel",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Mixpanel integration with 3 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "project_id",
        "required": true,
        "description": "project id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7856FF\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">M</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "event_track",
      "name": "Mixpanel Event Track",
      "description": "POST /import",
      "method": "POST",
      "path": "/import",
      "inputs": [
        {
          "name": "Events JSON",
          "required": true,
          "mapTo": "Events JSON"
        }
      ],
      "outputs": [
        {
          "name": "Code",
          "path": "code"
        },
        {
          "name": "Num Records Imported",
          "path": "num_records_imported"
        }
      ]
    },
    {
      "id": "test",
      "name": "Mixpanel Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "user_profile_set",
      "name": "Mixpanel User Profile Set",
      "description": "POST /engage#profile-set",
      "method": "POST",
      "path": "/engage#profile-set",
      "inputs": [
        {
          "name": "Distinct ID",
          "required": true,
          "mapTo": "Distinct ID"
        },
        {
          "name": "Properties JSON",
          "required": true,
          "mapTo": "Properties JSON"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        }
      ]
    }
  ]
}