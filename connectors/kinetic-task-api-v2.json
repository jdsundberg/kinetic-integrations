{
  "id": "kinetic-task-api-v2",
  "service": "Kinetic Task API v2",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Kinetic Task Engine API v2 \u2014 manage trees, runs, triggers, errors, handlers, and engine status.",
  "docsUrl": "https://docs.kineticdata.com/reference",
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F36C24\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">K</text></svg>",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "api_username",
        "required": true,
        "description": "Kinetic Platform username."
      },
      {
        "name": "api_password",
        "required": true,
        "encrypted": true,
        "description": "Kinetic Platform password."
      },
      {
        "name": "api_location",
        "required": true,
        "description": "Kinetic server URL (e.g. https://myspace.kinops.io)."
      },
      {
        "name": "enable_debug_logging",
        "required": false,
        "description": "True or False."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "tree_list",
      "name": "Tree List",
      "description": "Lists workflow trees.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/trees?limit=100&include=details",
      "inputs": [],
      "outputs": [
        {
          "name": "Trees JSON",
          "path": "trees"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "tree_retrieve",
      "name": "Tree Retrieve",
      "description": "Retrieves a tree by title.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/trees/{title}?include=treeJson,details",
      "inputs": [
        {
          "name": "Title",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Name",
          "path": "tree.name"
        },
        {
          "name": "Status",
          "path": "tree.status"
        },
        {
          "name": "Version ID",
          "path": "tree.versionId"
        }
      ]
    },
    {
      "id": "run_list",
      "name": "Run List",
      "description": "Lists workflow runs.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/runs?limit=25&include=details",
      "inputs": [
        {
          "name": "Tree Name",
          "required": false
        },
        {
          "name": "Status",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Runs JSON",
          "path": "runs"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "run_triggers",
      "name": "Run Triggers",
      "description": "Lists triggers (node activations) for a run.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/triggers?runId={run_id}&include=details",
      "inputs": [
        {
          "name": "Run ID",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Triggers JSON",
          "path": "triggers"
        }
      ]
    },
    {
      "id": "error_list",
      "name": "Error List",
      "description": "Lists active task errors.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/errors?include=details&status=Active&limit=25",
      "inputs": [],
      "outputs": [
        {
          "name": "Errors JSON",
          "path": "errors"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "error_resolve",
      "name": "Error Resolve",
      "description": "Resolves one or more task errors.",
      "method": "POST",
      "path": "/app/components/task/app/api/v2/errors/resolve",
      "inputs": [
        {
          "name": "Error IDs JSON",
          "required": true,
          "description": "Array of error IDs.",
          "mapTo": "ids"
        },
        {
          "name": "Action",
          "required": true,
          "description": "Do Nothing, Retry, or Skip.",
          "mapTo": "action"
        },
        {
          "name": "Resolution",
          "required": false,
          "mapTo": "resolution"
        }
      ],
      "outputs": []
    },
    {
      "id": "handler_list",
      "name": "Handler List",
      "description": "Lists installed handlers.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/handlers?limit=200&include=details",
      "inputs": [],
      "outputs": [
        {
          "name": "Handlers JSON",
          "path": "handlers"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "source_list",
      "name": "Source List",
      "description": "Lists configured sources.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/sources",
      "inputs": [],
      "outputs": [
        {
          "name": "Sources JSON",
          "path": "sources"
        }
      ]
    },
    {
      "id": "engine_status",
      "name": "Engine Status",
      "description": "Gets task engine status and version.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/engine",
      "inputs": [],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Version",
          "path": "version"
        }
      ]
    },
    {
      "id": "test",
      "name": "Kinetic Task API v2 Connection Test",
      "description": "Validates authentication by checking engine status.",
      "method": "GET",
      "path": "/app/components/task/app/api/v2/engine",
      "inputs": [],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        }
      ]
    }
  ]
}