{
  "id": "contentful",
  "service": "Contentful",
  "version": 1,
  "category": "Commerce & Content",
  "description": "Contentful integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "space_id",
        "required": true,
        "description": "space id."
      },
      {
        "name": "environment",
        "required": true,
        "description": "environment."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2478CC\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">C</text></svg>",
  "docsUrl": "https://www.contentful.com/developers/docs/references/content-management-api/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "entry_create",
      "name": "Contentful Entry Create",
      "description": "POST /spaces/{space_id}/environments/{environment_id}/entries",
      "method": "POST",
      "path": "/spaces/{{inputs.Space ID}}/environments/{{inputs.Environment ID}}/entries",
      "inputs": [
        {
          "name": "Space ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Environment ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Fields JSON",
          "required": true,
          "mapTo": "Fields JSON"
        }
      ],
      "outputs": [
        {
          "name": "Entry ID",
          "path": "sys.id"
        }
      ]
    },
    {
      "id": "entry_list",
      "name": "Contentful Entry List",
      "description": "GET /spaces/{space_id}/environments/{environment_id}/entries",
      "method": "GET",
      "path": "/spaces/{{inputs.Space ID}}/environments/{{inputs.Environment ID}}/entries",
      "inputs": [
        {
          "name": "Space ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Environment ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Entries JSON",
          "path": "items"
        }
      ]
    },
    {
      "id": "test",
      "name": "Contentful Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}