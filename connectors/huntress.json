{
  "id": "huntress",
  "service": "Huntress",
  "version": 1,
  "category": "Security & IAM",
  "description": "Huntress MDR integration with 16 pre-built routines covering accounts, organizations, agents, incident reports, and reports — the security operations layer for MSPs running managed detection and response.",
  "auth": {
    "type": "basic",
    "properties": [
      { "name": "api_url", "required": true, "description": "Huntress API base URL. Default: https://api.huntress.io/v1." },
      { "name": "api_key", "required": true, "description": "Huntress API key (username). Generated in the Huntress dashboard under Account Settings > API Credentials." },
      { "name": "api_secret", "required": true, "description": "Huntress API secret (password).", "encrypted": true }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#12132C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">H</text></svg>",
  "docsUrl": "https://api.huntress.io/docs",
  "defaultHeaders": { "Accept": "application/json", "Content-Type": "application/json" },
  "baseUrl": "https://api.huntress.io",
  "routines": [
    { "id": "test", "name": "Huntress Connection Test", "description": "GET /v1/account", "method": "GET", "path": "/v1/account", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "account_retrieve", "name": "Huntress Account Retrieve", "description": "GET /v1/account", "method": "GET", "path": "/v1/account", "inputs": [], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "actor_retrieve", "name": "Huntress Current Actor (API User)", "description": "GET /v1/actor", "method": "GET", "path": "/v1/actor", "inputs": [], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organizations_list", "name": "Huntress Organizations List", "description": "GET /v1/organizations", "method": "GET", "path": "/v1/organizations", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"Name","required":false,"mapTo":"name"}], "outputs": [{"name":"Organizations","path":"organizations"},{"name":"Pagination","path":"pagination"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_retrieve", "name": "Huntress Organization Retrieve", "description": "GET /v1/organization/{{inputs.Organization ID}}", "method": "GET", "path": "/v1/organization/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_create", "name": "Huntress Organization Create", "description": "POST /v1/organization", "method": "POST", "path": "/v1/organization", "inputs": [{"name":"Name","required":true,"mapTo":"name"},{"name":"Key","required":false,"mapTo":"key"}], "outputs": [{"name":"Organization ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_update", "name": "Huntress Organization Update", "description": "PUT /v1/organization/{{inputs.Organization ID}}", "method": "PUT", "path": "/v1/organization/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":false,"mapTo":"name"},{"name":"Key","required":false,"mapTo":"key"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "agents_list", "name": "Huntress Agents List", "description": "GET /v1/agents", "method": "GET", "path": "/v1/agents", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"Organization ID","required":false,"mapTo":"organization_id"},{"name":"Hostname","required":false,"mapTo":"hostname"},{"name":"Platform","required":false,"mapTo":"platform"}], "outputs": [{"name":"Agents","path":"agents"},{"name":"Pagination","path":"pagination"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "agent_retrieve", "name": "Huntress Agent Retrieve", "description": "GET /v1/agent/{{inputs.Agent ID}}", "method": "GET", "path": "/v1/agent/{{inputs.Agent ID}}", "inputs": [{"name":"Agent ID","required":true,"mapTo":"Agent ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "incident_reports_list", "name": "Huntress Incident Reports List", "description": "GET /v1/incident_reports", "method": "GET", "path": "/v1/incident_reports", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"Status","required":false,"mapTo":"status"},{"name":"Organization ID","required":false,"mapTo":"organization_id"},{"name":"Agent ID","required":false,"mapTo":"agent_id"},{"name":"Severity","required":false,"mapTo":"severity"},{"name":"Updated At Min","required":false,"mapTo":"updated_at_min"},{"name":"Updated At Max","required":false,"mapTo":"updated_at_max"}], "outputs": [{"name":"Incident Reports","path":"incident_reports"},{"name":"Pagination","path":"pagination"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "incident_report_retrieve", "name": "Huntress Incident Report Retrieve", "description": "GET /v1/incident_report/{{inputs.Incident Report ID}}", "method": "GET", "path": "/v1/incident_report/{{inputs.Incident Report ID}}", "inputs": [{"name":"Incident Report ID","required":true,"mapTo":"Incident Report ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "incident_report_update", "name": "Huntress Incident Report Update", "description": "PUT /v1/incident_report/{{inputs.Incident Report ID}}", "method": "PUT", "path": "/v1/incident_report/{{inputs.Incident Report ID}}", "inputs": [{"name":"Incident Report ID","required":true,"mapTo":"Incident Report ID"},{"name":"Status","required":false,"mapTo":"status"},{"name":"Closed Reason","required":false,"mapTo":"closed_reason"},{"name":"Summary","required":false,"mapTo":"summary"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "reports_list", "name": "Huntress Reports List", "description": "GET /v1/reports", "method": "GET", "path": "/v1/reports", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"Type","required":false,"mapTo":"type"},{"name":"Organization ID","required":false,"mapTo":"organization_id"}], "outputs": [{"name":"Reports","path":"reports"},{"name":"Pagination","path":"pagination"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "report_retrieve", "name": "Huntress Report Retrieve", "description": "GET /v1/report/{{inputs.Report ID}}", "method": "GET", "path": "/v1/report/{{inputs.Report ID}}", "inputs": [{"name":"Report ID","required":true,"mapTo":"Report ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "billing_reports_list", "name": "Huntress Billing Reports List", "description": "GET /v1/billing_reports", "method": "GET", "path": "/v1/billing_reports", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"}], "outputs": [{"name":"Billing Reports","path":"billing_reports"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "signals_list", "name": "Huntress Signals List", "description": "GET /v1/signals", "method": "GET", "path": "/v1/signals", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"Organization ID","required":false,"mapTo":"organization_id"},{"name":"Agent ID","required":false,"mapTo":"agent_id"}], "outputs": [{"name":"Signals","path":"signals"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
