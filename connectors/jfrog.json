{
  "id": "jfrog",
  "service": "Jfrog",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Jfrog integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">J</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "artifact_deploy",
      "name": "JFrog Artifact Deploy",
      "description": "PUT /{repo_key}/{artifact_path}",
      "method": "PUT",
      "path": "/{{inputs.Repo Key}}/{{inputs.Artifact Path}}",
      "inputs": [
        {
          "name": "Repo Key",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Artifact Path",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "URI",
          "path": "uri"
        }
      ]
    },
    {
      "id": "artifact_search",
      "name": "JFrog Artifact Search",
      "description": "GET /api/search/artifact?name={name}",
      "method": "GET",
      "path": "/api/search/artifact?name={{inputs.Name}}",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Results JSON",
          "path": "results"
        }
      ]
    },
    {
      "id": "test",
      "name": "Jfrog Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}