{
  "id": "workable",
  "service": "Workable",
  "version": 1,
  "category": "HR & People",
  "description": "Workable integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "subdomain",
        "required": true,
        "description": "subdomain."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#19B4E6\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">W</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "candidate_create",
      "name": "Workable Candidate Create",
      "description": "POST /spi/v3/accounts/{subdomain}/jobs/{shortcode}/candidates",
      "method": "POST",
      "path": "/spi/v3/accounts/{{inputs.Subdomain}}/jobs/{{inputs.Shortcode}}/candidates",
      "inputs": [
        {
          "name": "Subdomain",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Job Shortcode",
          "required": true,
          "mapTo": "Job Shortcode"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Candidate ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Workable Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://SUBDOMAIN.workable.com"
}
