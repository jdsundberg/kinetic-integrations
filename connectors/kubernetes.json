{
  "id": "kubernetes",
  "service": "Kubernetes",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Kubernetes integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "api_server",
        "required": true,
        "description": "Kubernetes API server URL."
      },
      {
        "name": "service_token",
        "required": true,
        "description": "Kubernetes service account token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#326CE5\"><path d=\"M10.2 3.6l-1 .3.5 1.8h.1l.2-.2.7-1.5-.5-.4zm3.5 0l-.4.4.7 1.5.2.2h.1l.5-1.8-1-.3zM12 4.6l-.9 1.5.9.5.9-.5-.9-1.5zM7.6 6l-.9.6 1.3 1.3v.2l-.1.2-1.6.5.1.7h.1l1.6-.6.1-.1V8.6L9 7.4l-.6-.5-.8-.8zm8.8 0l-.8.8-.6.5.8 1.2v.2l.1.1 1.6.6h.1l.1-.7-1.6-.5-.1-.2v-.2L17.2 6.6l-.8-.6zM12 7.4l-1.1.7-.1 1.3-1.3.5-.7-1.1h-.2l-.7.6 1.4 1.2V11l-.8 1.1 1.6.7.2-.1.7-1.2h2l.7 1.2.2.1 1.6-.7-.8-1.1V10.6l1.4-1.2-.7-.6h-.2l-.7 1.1-1.3-.5-.1-1.3-1.1-.7zm-1 2.2h2l.6 1.4-.9 1.2h-1.4l-.9-1.2.6-1.4zM4.8 10.7l-.2 1 1.8.4.2.1.1-.2.2-1.6-.6-.2-1.5.5zm14.4 0l-1.5-.5-.6.2.2 1.6.1.2.2-.1 1.8-.4-.2-1zm-11.4 3l-1.5.8.5 1 .2-.1 1.2-1.3.1-.2-.1-.2h-.4zm12.4 0h-.4l-.1.2.1.2 1.2 1.3.2.1.5-1-1.5-.8zm-11.5 2l-.1.1-.1.6 1.7.2h.3v-.3l-.2-1.5-.7.2-.9.7zm10.7 0l-.9-.7-.7-.2-.2 1.5v.3h.3l1.7-.2-.1-.6-.1-.1zM9.1 17l-.1.2.8 1.6.6-.2.2-1.7v-.3l-.3.1-1.2.3zm5.8 0l-1.2-.3-.3-.1v.3l.2 1.7.6.2.8-1.6-.1-.2zm-4.4.5l-.6 1.6.4.3L12 18l1.7 1.4.4-.3-.6-1.6H12h-1.5z\"/></svg>",
  "docsUrl": "https://kubernetes.io/docs/reference/kubernetes-api/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "deployment_create",
      "name": "Kubernetes Deployment Create",
      "description": "POST /apis/apps/v1/namespaces/{{inputs.Namespace}}/deployments",
      "method": "POST",
      "path": "/apis/apps/v1/namespaces/{{inputs.Namespace}}/deployments",
      "inputs": [
        {
          "name": "Namespace",
          "required": true,
          "mapTo": "Namespace"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Image",
          "required": true,
          "mapTo": "Image"
        },
        {
          "name": "Replicas",
          "required": false,
          "mapTo": "Replicas"
        },
        {
          "name": "Port",
          "required": false,
          "mapTo": "Port"
        }
      ],
      "outputs": [
        {
          "name": "Deployment Name",
          "path": "deployment_name"
        },
        {
          "name": "UID",
          "path": "uid"
        },
        {
          "name": "Namespace",
          "path": "namespace"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "namespace_create",
      "name": "Kubernetes Namespace Create",
      "description": "POST /api/v1/namespaces",
      "method": "POST",
      "path": "/api/v1/namespaces",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Labels Json",
          "required": false,
          "mapTo": "Labels Json"
        }
      ],
      "outputs": [
        {
          "name": "Namespace Name",
          "path": "namespace_name"
        },
        {
          "name": "UID",
          "path": "uid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "pod_list",
      "name": "Kubernetes Pod List",
      "description": "GET /api/v1/namespaces/{{inputs.Namespace}}/pods?labelSelector={{inputs.Label Selector}}",
      "method": "GET",
      "path": "/api/v1/namespaces/{{inputs.Namespace}}/pods?labelSelector={{inputs.Label Selector}}",
      "inputs": [
        {
          "name": "Namespace",
          "required": true
        },
        {
          "name": "Label Selector",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Pods JSON",
          "path": "pods_json"
        },
        {
          "name": "Pod Count",
          "path": "pod_count"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "service_create",
      "name": "Kubernetes Service Create",
      "description": "POST /api/v1/namespaces/{{inputs.Namespace}}/services",
      "method": "POST",
      "path": "/api/v1/namespaces/{{inputs.Namespace}}/services",
      "inputs": [
        {
          "name": "Namespace",
          "required": true,
          "mapTo": "Namespace"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Selector Json",
          "required": true,
          "mapTo": "Selector Json"
        },
        {
          "name": "Port",
          "required": true,
          "mapTo": "Port"
        },
        {
          "name": "Target Port",
          "required": true,
          "mapTo": "Target Port"
        },
        {
          "name": "Type",
          "required": false,
          "mapTo": "Type"
        }
      ],
      "outputs": [
        {
          "name": "Service Name",
          "path": "service_name"
        },
        {
          "name": "Cluster IP",
          "path": "cluster_ip"
        },
        {
          "name": "UID",
          "path": "uid"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Kubernetes Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://CLUSTER.k8s.local"
}
