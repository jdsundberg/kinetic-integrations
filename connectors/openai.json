{
  "id": "openai",
  "service": "Openai",
  "version": 1,
  "category": "AI & Machine Learning",
  "description": "Openai integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">O</text></svg>",
  "docsUrl": "https://platform.openai.com/docs/api-reference",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "chat_completion",
      "name": "OpenAI Chat Completion",
      "description": "POST /v1/chat/completions",
      "method": "POST",
      "path": "/v1/chat/completions",
      "inputs": [
        {
          "name": "Model",
          "required": true,
          "mapTo": "Model"
        },
        {
          "name": "Messages JSON",
          "required": true,
          "mapTo": "Messages JSON"
        },
        {
          "name": "Max Tokens",
          "required": false,
          "mapTo": "Max Tokens"
        },
        {
          "name": "Temperature",
          "required": false,
          "mapTo": "Temperature"
        }
      ],
      "outputs": [
        {
          "name": "Response Text",
          "path": "choices[0].message.content"
        },
        {
          "name": "Model",
          "path": "model"
        },
        {
          "name": "Finish Reason",
          "path": "choices[0].finish_reason"
        },
        {
          "name": "Total Tokens",
          "path": "usage.total_tokens"
        }
      ]
    },
    {
      "id": "embedding_create",
      "name": "OpenAI Embedding Create",
      "description": "POST /v1/embeddings",
      "method": "POST",
      "path": "/v1/embeddings",
      "inputs": [
        {
          "name": "Model",
          "required": true,
          "mapTo": "Model"
        },
        {
          "name": "Input",
          "required": true,
          "mapTo": "Input"
        }
      ],
      "outputs": [
        {
          "name": "Embedding JSON",
          "path": "data[0].embedding"
        },
        {
          "name": "Total Tokens",
          "path": "usage.total_tokens"
        }
      ]
    },
    {
      "id": "test",
      "name": "Openai Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.openai.com"
}
