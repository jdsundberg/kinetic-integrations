{
  "id": "veeam-vbr",
  "service": "Veeam VBR",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Veeam Backup & Replication integration with 33 pre-built routines covering jobs (list/start/stop/enable/disable/retry), backups, restore points, sessions, repositories, proxies, managed servers, inventory (VMware/Hyper-V/Agents), credentials, restore operations, and malware detection.",
  "auth": {
    "type": "oauth2_password",
    "properties": [
      {
        "name": "api_url",
        "required": true,
        "description": "Veeam VBR server API base URL (used both for OAuth2 token request and API calls)."
      },
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint path (relative to api_url) or full URL. Default: /api/oauth2/token.",
        "defaultValue": "/api/oauth2/token"
      },
      {
        "name": "username",
        "required": true,
        "description": "Veeam VBR user with REST API access."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password.",
        "encrypted": true
      },
      {
        "name": "client_id",
        "required": false,
        "description": "OAuth2 client ID if the server requires one. Leave blank otherwise."
      },
      {
        "name": "client_secret",
        "required": false,
        "description": "OAuth2 client secret if the server requires one.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00B336\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">VBR</text></svg>",
  "docsUrl": "https://helpcenter.veeam.com/docs/backup/vbr_rest/overview.html",
