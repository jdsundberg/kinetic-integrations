{
  "id": "talkdesk",
  "service": "Talkdesk",
  "version": 1,
  "category": "Other",
  "description": "Talkdesk integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#4462F0\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "call_list",
      "name": "Talkdesk Call List",
      "description": "GET /calls",
      "method": "GET",
      "path": "/calls",
      "inputs": [
        {
          "name": "Date",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Calls JSON",
          "path": "data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Talkdesk Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}