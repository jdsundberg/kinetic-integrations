{
  "id": "discord",
  "service": "Discord",
  "version": 1,
  "category": "Communication",
  "description": "Discord integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "bot_token",
        "required": true,
        "description": "Discord bot token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#5865F2\"><path d=\"M20.3 4.4a19.8 19.8 0 00-4.9-1.5.1.1 0 00-.1 0c-.2.4-.4.9-.6 1.3a18.3 18.3 0 00-5.5 0 12.6 12.6 0 00-.6-1.3.1.1 0 00-.1 0A19.7 19.7 0 003.7 4.4a.1.1 0 000 0C.5 9 -.3 13.6.1 18.1a.1.1 0 000 .1 19.9 19.9 0 006 3 .1.1 0 00.1 0c.5-.6.9-1.3 1.2-2a.1.1 0 000-.1 13.1 13.1 0 01-1.9-.9.1.1 0 010-.1 10.2 10.2 0 00.4-.3.1.1 0 01.1 0c3.9 1.8 8.2 1.8 12.1 0a.1.1 0 01.1 0l.4.3a.1.1 0 010 .1 12.3 12.3 0 01-1.9.9.1.1 0 000 .1c.4.7.8 1.4 1.2 2a.1.1 0 00.1 0 19.8 19.8 0 006-3 .1.1 0 000-.1c.5-5.2-.8-9.7-3.5-13.7z\"/></svg>",
  "docsUrl": "https://discord.com/developers/docs/reference",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "channel_create",
      "name": "Discord Channel Create",
      "description": "POST https://discord.com/api/v10/guilds/<%= @inputs['Guild Id'] %>/channels",
      "method": "POST",
      "path": "/api/v10/guilds/<%= @inputs['Guild Id'] %>/channels",
      "inputs": [
        {
          "name": "Guild Id",
          "required": true,
          "mapTo": "Guild Id"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Type",
          "required": false,
          "mapTo": "Type"
        },
        {
          "name": "Topic",
          "required": false,
          "mapTo": "Topic"
        },
        {
          "name": "Parent Id",
          "required": false,
          "mapTo": "Parent Id"
        }
      ],
      "outputs": [
        {
          "name": "Channel ID",
          "path": "channel_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Type",
          "path": "type"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "member_add_role",
      "name": "Discord Member Add Role",
      "description": "PUT https://discord.com/api/v10/guilds/<%= @inputs['Guild Id'] %>/members/<%= @inputs['User Id'] %>/roles/<%= @inputs['Role Id'] %>",
      "method": "PUT",
      "path": "/api/v10/guilds/<%= @inputs['Guild Id'] %>/members/<%= @inputs['User Id'] %>/roles/<%= @inputs['Role Id'] %>",
      "inputs": [
        {
          "name": "Guild Id",
          "required": true,
          "mapTo": "Guild Id"
        },
        {
          "name": "User Id",
          "required": true,
          "mapTo": "User Id"
        },
        {
          "name": "Role Id",
          "required": true,
          "mapTo": "Role Id"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "message_send",
      "name": "Discord Message Send",
      "description": "POST https://discord.com/api/v10/channels/<%= @inputs['Channel Id'] %>/messages",
      "method": "POST",
      "path": "/api/v10/channels/<%= @inputs['Channel Id'] %>/messages",
      "inputs": [
        {
          "name": "Channel Id",
          "required": true,
          "mapTo": "Channel Id"
        },
        {
          "name": "Content",
          "required": true,
          "mapTo": "Content"
        },
        {
          "name": "Tts",
          "required": false,
          "mapTo": "Tts"
        },
        {
          "name": "Embeds Json",
          "required": false,
          "mapTo": "Embeds Json"
        }
      ],
      "outputs": [
        {
          "name": "Message ID",
          "path": "message_id"
        },
        {
          "name": "Channel ID",
          "path": "channel_id"
        },
        {
          "name": "Timestamp",
          "path": "timestamp"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "role_create",
      "name": "Discord Role Create",
      "description": "POST https://discord.com/api/v10/guilds/<%= @inputs['Guild Id'] %>/roles",
      "method": "POST",
      "path": "/api/v10/guilds/<%= @inputs['Guild Id'] %>/roles",
      "inputs": [
        {
          "name": "Guild Id",
          "required": true,
          "mapTo": "Guild Id"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Color",
          "required": false,
          "mapTo": "Color"
        },
        {
          "name": "Hoist",
          "required": false,
          "mapTo": "Hoist"
        },
        {
          "name": "Mentionable",
          "required": false,
          "mapTo": "Mentionable"
        },
        {
          "name": "Permissions",
          "required": false,
          "mapTo": "Permissions"
        }
      ],
      "outputs": [
        {
          "name": "Role ID",
          "path": "role_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Color",
          "path": "color"
        },
        {
          "name": "Position",
          "path": "position"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Discord Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}