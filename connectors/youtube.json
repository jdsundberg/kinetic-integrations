{
  "id": "youtube",
  "service": "Youtube",
  "version": 1,
  "category": "Social & Marketplace",
  "description": "Youtube integration with 3 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">Y</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "channel_retrieve",
      "name": "YouTube Channel Retrieve",
      "description": "GET /youtube/v3/channels?part=snippet,statistics&id={channel_id}",
      "method": "GET",
      "path": "/youtube/v3/channels?part=snippet,statistics&id={channel_id}",
      "inputs": [
        {
          "name": "Channel ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Channel JSON",
          "path": "items[0]"
        }
      ]
    },
    {
      "id": "test",
      "name": "Youtube Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "video_list",
      "name": "YouTube Video List",
      "description": "GET /youtube/v3/videos?part=snippet&chart=mostPopular",
      "method": "GET",
      "path": "/youtube/v3/videos?part=snippet&chart=mostPopular",
      "inputs": [
        {
          "name": "Region Code",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Videos JSON",
          "path": "items"
        }
      ]
    }
  ]
}