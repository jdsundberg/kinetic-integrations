{
  "id": "ninjaone",
  "service": "NinjaOne",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "NinjaOne RMM integration with 30 pre-built routines covering organizations, locations, devices (list/retrieve/reboot/reset/run-script), device activities/software/disks/volumes, policies, jobs, alerts, tickets, and custom fields — the modern MSP RMM platform.",
  "auth": {
    "type": "oauth2",
    "properties": [
      { "name": "api_url", "required": true, "description": "NinjaOne API base URL (region-specific). Examples: https://app.ninjarmm.com (US), https://eu.ninjarmm.com (EU), https://ca.ninjarmm.com (CA), https://oc.ninjarmm.com (OC)." },
      { "name": "client_id", "required": true, "description": "OAuth2 client ID (created in Administration > Apps > API)." },
      { "name": "client_secret", "required": true, "description": "OAuth2 client secret.", "encrypted": true },
      { "name": "scope", "required": true, "description": "OAuth2 scope. Typically: monitoring management control offline_access." }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F5333F\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">N1</text></svg>",
  "docsUrl": "https://app.ninjarmm.com/apidocs/",
  "defaultHeaders": { "Accept": "application/json", "Content-Type": "application/json" },
  "baseUrl": "https://app.ninjarmm.com",
  "routines": [
    { "id": "test", "name": "NinjaOne Connection Test", "description": "GET /v2/organizations (pageSize=1)", "method": "GET", "path": "/v2/organizations", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "organizations_list", "name": "NinjaOne Organizations List", "description": "GET /v2/organizations", "method": "GET", "path": "/v2/organizations", "inputs": [{"name":"Page Size","required":false,"mapTo":"pageSize"},{"name":"After","required":false,"mapTo":"after"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_retrieve", "name": "NinjaOne Organization Retrieve", "description": "GET /v2/organization/{{inputs.Organization ID}}", "method": "GET", "path": "/v2/organization/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_create", "name": "NinjaOne Organization Create", "description": "POST /v2/organizations", "method": "POST", "path": "/v2/organizations", "inputs": [{"name":"Name","required":true,"mapTo":"name"},{"name":"Description","required":false,"mapTo":"description"},{"name":"Node Approval Mode","required":false,"mapTo":"nodeApprovalMode"}], "outputs": [{"name":"Organization ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_update", "name": "NinjaOne Organization Update", "description": "PATCH /v2/organization/{{inputs.Organization ID}}", "method": "PATCH", "path": "/v2/organization/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":false,"mapTo":"name"},{"name":"Description","required":false,"mapTo":"description"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_locations", "name": "NinjaOne Organization Locations", "description": "GET /v2/organization/{{inputs.Organization ID}}/locations", "method": "GET", "path": "/v2/organization/{{inputs.Organization ID}}/locations", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "location_create", "name": "NinjaOne Location Create", "description": "POST /v2/organization/{{inputs.Organization ID}}/locations", "method": "POST", "path": "/v2/organization/{{inputs.Organization ID}}/locations", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":true,"mapTo":"name"},{"name":"Address","required":false,"mapTo":"address"},{"name":"Description","required":false,"mapTo":"description"}], "outputs": [{"name":"Location ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "devices_list", "name": "NinjaOne Devices List", "description": "GET /v2/devices", "method": "GET", "path": "/v2/devices", "inputs": [{"name":"Device Filter","required":false,"mapTo":"df"},{"name":"Page Size","required":false,"mapTo":"pageSize"},{"name":"After","required":false,"mapTo":"after"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_retrieve", "name": "NinjaOne Device Retrieve", "description": "GET /v2/device/{{inputs.Device ID}}", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_update", "name": "NinjaOne Device Update", "description": "PATCH /v2/device/{{inputs.Device ID}}", "method": "PATCH", "path": "/v2/device/{{inputs.Device ID}}", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"},{"name":"Policy ID","required":false,"mapTo":"policyId"},{"name":"Approval Status","required":false,"mapTo":"approvalStatus"},{"name":"Display Name","required":false,"mapTo":"displayName"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_reboot", "name": "NinjaOne Device Reboot", "description": "POST /v2/device/{{inputs.Device ID}}/reboot/{{inputs.Mode}}", "method": "POST", "path": "/v2/device/{{inputs.Device ID}}/reboot/{{inputs.Mode}}", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"},{"name":"Mode","required":true,"mapTo":"Mode"},{"name":"Reason","required":false,"mapTo":"reason"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_script_run", "name": "NinjaOne Device Run Script", "description": "POST /v2/device/{{inputs.Device ID}}/script/run", "method": "POST", "path": "/v2/device/{{inputs.Device ID}}/script/run", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"},{"name":"Type","required":true,"mapTo":"type"},{"name":"ID","required":true,"mapTo":"id"},{"name":"Parameters","required":false,"mapTo":"parameters"},{"name":"Run As","required":false,"mapTo":"runAs"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_activities", "name": "NinjaOne Device Activities", "description": "GET /v2/device/{{inputs.Device ID}}/activities", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/activities", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"},{"name":"Older Than","required":false,"mapTo":"olderThan"},{"name":"Newer Than","required":false,"mapTo":"newerThan"},{"name":"Page Size","required":false,"mapTo":"pageSize"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_software", "name": "NinjaOne Device Software", "description": "GET /v2/device/{{inputs.Device ID}}/software", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/software", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_processors", "name": "NinjaOne Device Processors", "description": "GET /v2/device/{{inputs.Device ID}}/processors", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/processors", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_disks", "name": "NinjaOne Device Disks", "description": "GET /v2/device/{{inputs.Device ID}}/disks", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/disks", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_volumes", "name": "NinjaOne Device Volumes", "description": "GET /v2/device/{{inputs.Device ID}}/volumes", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/volumes", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_custom_fields", "name": "NinjaOne Device Custom Fields", "description": "GET /v2/device/{{inputs.Device ID}}/custom-fields", "method": "GET", "path": "/v2/device/{{inputs.Device ID}}/custom-fields", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "device_custom_fields_update", "name": "NinjaOne Device Custom Fields Update", "description": "PATCH /v2/device/{{inputs.Device ID}}/custom-fields", "method": "PATCH", "path": "/v2/device/{{inputs.Device ID}}/custom-fields", "inputs": [{"name":"Device ID","required":true,"mapTo":"Device ID"},{"name":"Fields JSON","required":true,"mapTo":"fields"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "alerts_list", "name": "NinjaOne Alerts List", "description": "GET /v2/alerts", "method": "GET", "path": "/v2/alerts", "inputs": [{"name":"Device Filter","required":false,"mapTo":"df"},{"name":"Source Type","required":false,"mapTo":"sourceType"},{"name":"Page Size","required":false,"mapTo":"pageSize"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "alert_reset", "name": "NinjaOne Alert Reset", "description": "DELETE /v2/alert/{{inputs.Alert UID}}", "method": "DELETE", "path": "/v2/alert/{{inputs.Alert UID}}", "inputs": [{"name":"Alert UID","required":true,"mapTo":"Alert UID"}], "outputs": [{"name":"Response Code","path":"response_code"}] },
    { "id": "alert_reset_activity", "name": "NinjaOne Alert Reset with Activity", "description": "POST /v2/alert/{{inputs.Alert UID}}/reset", "method": "POST", "path": "/v2/alert/{{inputs.Alert UID}}/reset", "inputs": [{"name":"Alert UID","required":true,"mapTo":"Alert UID"},{"name":"Activity Data","required":false,"mapTo":"activityData"}], "outputs": [{"name":"Response Code","path":"response_code"}] },
    { "id": "policies_list", "name": "NinjaOne Policies List", "description": "GET /v2/policies", "method": "GET", "path": "/v2/policies", "inputs": [], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "jobs_list", "name": "NinjaOne Jobs List", "description": "GET /v2/jobs", "method": "GET", "path": "/v2/jobs", "inputs": [{"name":"Device Filter","required":false,"mapTo":"df"},{"name":"Job Type","required":false,"mapTo":"jobType"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "queued_scripts", "name": "NinjaOne Queued Scripts", "description": "GET /v2/queued-scripts", "method": "GET", "path": "/v2/queued-scripts", "inputs": [{"name":"Device Filter","required":false,"mapTo":"df"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "scripts_list", "name": "NinjaOne Scripts List", "description": "GET /v2/scripts", "method": "GET", "path": "/v2/scripts", "inputs": [], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tickets_list", "name": "NinjaOne Tickets List", "description": "GET /v2/ticketing/ticket", "method": "GET", "path": "/v2/ticketing/ticket", "inputs": [{"name":"Page Size","required":false,"mapTo":"pageSize"},{"name":"Client ID","required":false,"mapTo":"clientId"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_create", "name": "NinjaOne Ticket Create", "description": "POST /v2/ticketing/ticket", "method": "POST", "path": "/v2/ticketing/ticket", "inputs": [{"name":"Client ID","required":true,"mapTo":"clientId"},{"name":"Subject","required":true,"mapTo":"subject"},{"name":"Description","required":false,"mapTo":"description"},{"name":"Ticket Form ID","required":false,"mapTo":"ticketFormId"},{"name":"Status","required":false,"mapTo":"status"},{"name":"Type","required":false,"mapTo":"type"},{"name":"Priority","required":false,"mapTo":"priority"},{"name":"Severity","required":false,"mapTo":"severity"},{"name":"Location ID","required":false,"mapTo":"locationId"},{"name":"Node ID","required":false,"mapTo":"nodeId"},{"name":"Contact IDs","required":false,"mapTo":"contactIds"}], "outputs": [{"name":"Ticket ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_retrieve", "name": "NinjaOne Ticket Retrieve", "description": "GET /v2/ticketing/ticket/{{inputs.Ticket ID}}", "method": "GET", "path": "/v2/ticketing/ticket/{{inputs.Ticket ID}}", "inputs": [{"name":"Ticket ID","required":true,"mapTo":"Ticket ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_update", "name": "NinjaOne Ticket Update", "description": "PUT /v2/ticketing/ticket/{{inputs.Ticket ID}}", "method": "PUT", "path": "/v2/ticketing/ticket/{{inputs.Ticket ID}}", "inputs": [{"name":"Ticket ID","required":true,"mapTo":"Ticket ID"},{"name":"Status","required":false,"mapTo":"status"},{"name":"Priority","required":false,"mapTo":"priority"},{"name":"Severity","required":false,"mapTo":"severity"},{"name":"Assigned App User ID","required":false,"mapTo":"assignedAppUserId"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_comment_create", "name": "NinjaOne Ticket Comment Create", "description": "POST /v2/ticketing/ticket/{{inputs.Ticket ID}}/comment", "method": "POST", "path": "/v2/ticketing/ticket/{{inputs.Ticket ID}}/comment", "inputs": [{"name":"Ticket ID","required":true,"mapTo":"Ticket ID"},{"name":"Body","required":true,"mapTo":"body"},{"name":"Public","required":false,"mapTo":"public"},{"name":"Comment Type","required":false,"mapTo":"type"}], "outputs": [{"name":"Comment ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
