{
  "id": "acumatica",
  "service": "Acumatica",
  "version": 1,
  "category": "Accounting",
  "description": "Acumatica integration with 8 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "Acumatica OAuth2 token endpoint."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "instance_url",
        "required": true,
        "description": "Acumatica instance URL."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "account_list",
      "name": "Acumatica Cloud ERP Chart of Accounts",
      "description": "GET /entity/Default/24.200.001/accounts",
      "method": "GET",
      "path": "/entity/Default/24.200.001/accounts",
      "inputs": [],
      "outputs": [
        {
          "name": "Accounts JSON",
          "path": "accounts"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "bill_create",
      "name": "Acumatica Cloud ERP Bill Create",
      "description": "POST /entity/Default/24.200.001/bills",
      "method": "POST",
      "path": "/entity/Default/24.200.001/bills",
      "inputs": [
        {
          "name": "Vendor Id",
          "required": true,
          "mapTo": "Vendor Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        }
      ],
      "outputs": [
        {
          "name": "Bill Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "customer_create",
      "name": "Acumatica Cloud ERP Customer Create",
      "description": "POST /entity/Default/24.200.001/customers",
      "method": "POST",
      "path": "/entity/Default/24.200.001/customers",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        },
        {
          "name": "Address",
          "required": false,
          "mapTo": "Address"
        }
      ],
      "outputs": [
        {
          "name": "Customer Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    },
    {
      "id": "invoice_create",
      "name": "Acumatica Cloud ERP Invoice Create",
      "description": "POST /entity/Default/24.200.001/invoices",
      "method": "POST",
      "path": "/entity/Default/24.200.001/invoices",
      "inputs": [
        {
          "name": "Customer Id",
          "required": true,
          "mapTo": "Customer Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        },
        {
          "name": "Currency",
          "required": false,
          "mapTo": "Currency"
        }
      ],
      "outputs": [
        {
          "name": "Invoice Id",
          "path": "id"
        },
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "invoice_retrieve",
      "name": "Acumatica Cloud ERP Invoice Retrieve",
      "description": "GET /entity/Default/24.200.001/invoices/{invoice_id}",
      "method": "GET",
      "path": "/entity/Default/24.200.001/invoices/{invoice_id}",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Total",
          "path": "total"
        },
        {
          "name": "Balance Due",
          "path": "balance"
        }
      ]
    },
    {
      "id": "journal_entry_create",
      "name": "Acumatica Cloud ERP Journal Entry Create",
      "description": "POST /entity/Default/24.200.001/journal-entries",
      "method": "POST",
      "path": "/entity/Default/24.200.001/journal-entries",
      "inputs": [
        {
          "name": "Date",
          "required": true,
          "mapTo": "Date"
        },
        {
          "name": "Lines JSON",
          "required": true,
          "mapTo": "Lines JSON"
        },
        {
          "name": "Memo",
          "required": false,
          "mapTo": "Memo"
        }
      ],
      "outputs": [
        {
          "name": "Entry Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "Acumatica Cloud ERP Payment Create",
      "description": "POST /entity/Default/24.200.001/payments",
      "method": "POST",
      "path": "/entity/Default/24.200.001/payments",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "mapTo": "Invoice Id"
        },
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Payment Date",
          "required": false,
          "mapTo": "Payment Date"
        },
        {
          "name": "Payment Method",
          "required": false,
          "mapTo": "Payment Method"
        }
      ],
      "outputs": [
        {
          "name": "Payment Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "vendor_create",
      "name": "Acumatica Cloud ERP Vendor Create",
      "description": "POST /entity/Default/24.200.001/vendors",
      "method": "POST",
      "path": "/entity/Default/24.200.001/vendors",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Vendor Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    }
  ]
}