{
  "id": "onepassword",
  "service": "Onepassword",
  "version": 1,
  "category": "Other",
  "description": "Onepassword integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0097A7\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">O</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "item_list",
      "name": "1Password Item List",
      "description": "GET /v1/vaults/{vault_id}/items",
      "method": "GET",
      "path": "/v1/vaults/{vault_id}/items",
      "inputs": [
        {
          "name": "Vault ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Items JSON",
          "path": "items"
        }
      ]
    },
    {
      "id": "item_retrieve",
      "name": "1Password Item Retrieve",
      "description": "GET /v1/vaults/{vault_id}/items/{item_id}",
      "method": "GET",
      "path": "/v1/vaults/{vault_id}/items/{item_id}",
      "inputs": [
        {
          "name": "Vault ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Item ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Item JSON",
          "path": "item"
        }
      ]
    },
    {
      "id": "test",
      "name": "Onepassword Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}