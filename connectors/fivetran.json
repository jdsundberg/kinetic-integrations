{
  "id": "fivetran",
  "service": "Fivetran",
  "version": 1,
  "category": "Data & Analytics",
  "description": "Fivetran integration with 3 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0073FF\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">F</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "connector_list",
      "name": "Fivetran Connector List",
      "description": "GET /v1/groups/{group_id}/connectors",
      "method": "GET",
      "path": "/v1/groups/{{inputs.Group ID}}/connectors",
      "inputs": [
        {
          "name": "Group ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Connectors JSON",
          "path": "data.items"
        }
      ]
    },
    {
      "id": "connector_sync",
      "name": "Fivetran Connector Sync",
      "description": "POST /v1/connectors/{connector_id}/force",
      "method": "POST",
      "path": "/v1/connectors/{{inputs.Connector ID}}/force",
      "inputs": [
        {
          "name": "Connector ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Code",
          "path": "code"
        }
      ]
    },
    {
      "id": "test",
      "name": "Fivetran Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.fivetran.com"
}
