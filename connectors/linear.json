      "description": "POST https://api.linear.app/graphql",
      "method": "POST",
      "path": "/graphql",
      "inputs": [
        {
          "name": "Issue Id",
          "required": true,
          "mapTo": "Issue Id"
        },
        {
          "name": "Body",
          "required": true,
          "mapTo": "Body"
        }
      ],
      "outputs": [
