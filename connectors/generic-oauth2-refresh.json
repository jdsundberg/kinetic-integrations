{
  "id": "generic-oauth2-refresh",
  "service": "Generic REST (OAuth2 Refresh Token)",
  "version": 1,
  "category": "Generic",
  "generic": true,
  "description": "Connect to any REST API using an OAuth2 refresh token (user-context).",
  "auth": {
    "type": "oauth2_refresh",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "encrypted": true,
        "description": "OAuth2 client secret."
      },
      {
        "name": "refresh_token",
        "required": true,
        "encrypted": true,
        "description": "Long-lived refresh token."
      },
      {
        "name": "base_url",
        "required": true,
        "description": "API base URL."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": []
}