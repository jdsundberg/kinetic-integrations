{
  "id": "acronis",
  "service": "Acronis Cyber Protect",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Acronis Cyber Protect Cloud integration with 24 pre-built routines covering tenants, users, contacts, resources (workloads), applications, offering items, alerts, activities, reports, events, backup plans, and usage — the MSP-focused cyber protection platform.",
  "auth": {
    "type": "oauth2",
    "properties": [
      { "name": "api_url", "required": true, "description": "Acronis data center URL (e.g. https://us-cloud.acronis.com, https://eu-cloud.acronis.com). This is the management endpoint for your region." },
      { "name": "client_id", "required": true, "description": "Acronis API client ID (created in Partner portal > Settings > API Clients)." },
      { "name": "client_secret", "required": true, "description": "Acronis API client secret.", "encrypted": true }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#EE1C25\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "docsUrl": "https://developer.acronis.com/doc/account-management/v2/guide/",
  "defaultHeaders": { "Accept": "application/json", "Content-Type": "application/json" },
  "baseUrl": "https://us-cloud.acronis.com",
  "routines": [
    { "id": "test", "name": "Acronis Connection Test", "description": "GET /api/2/tenants/self", "method": "GET", "path": "/api/2/tenants/self", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "tenant_self", "name": "Acronis Self Tenant", "description": "GET /api/2/tenants/self", "method": "GET", "path": "/api/2/tenants/self", "inputs": [], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenants_list", "name": "Acronis Tenants List", "description": "GET /api/2/tenants", "method": "GET", "path": "/api/2/tenants", "inputs": [{"name":"Parent","required":false,"mapTo":"parent"},{"name":"Kind","required":false,"mapTo":"kind"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"After","required":false,"mapTo":"after"}], "outputs": [{"name":"Items","path":"items"},{"name":"Paging","path":"paging"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_retrieve", "name": "Acronis Tenant Retrieve", "description": "GET /api/2/tenants/{{inputs.Tenant ID}}", "method": "GET", "path": "/api/2/tenants/{{inputs.Tenant ID}}", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"Tenant ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_create", "name": "Acronis Tenant Create", "description": "POST /api/2/tenants", "method": "POST", "path": "/api/2/tenants", "inputs": [{"name":"Name","required":true,"mapTo":"name"},{"name":"Parent ID","required":true,"mapTo":"parent_id"},{"name":"Kind","required":true,"mapTo":"kind"},{"name":"Language","required":false,"mapTo":"language"},{"name":"Contact","required":false,"mapTo":"contact"}], "outputs": [{"name":"Tenant ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_update", "name": "Acronis Tenant Update", "description": "PUT /api/2/tenants/{{inputs.Tenant ID}}", "method": "PUT", "path": "/api/2/tenants/{{inputs.Tenant ID}}", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"Tenant ID"},{"name":"Name","required":false,"mapTo":"name"},{"name":"Enabled","required":false,"mapTo":"enabled"},{"name":"Version","required":true,"mapTo":"version"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_offering_items", "name": "Acronis Tenant Offering Items", "description": "GET /api/2/tenants/{{inputs.Tenant ID}}/offering_items", "method": "GET", "path": "/api/2/tenants/{{inputs.Tenant ID}}/offering_items", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"Tenant ID"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_offering_items_update", "name": "Acronis Tenant Offering Items Update", "description": "PUT /api/2/tenants/{{inputs.Tenant ID}}/offering_items", "method": "PUT", "path": "/api/2/tenants/{{inputs.Tenant ID}}/offering_items", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"Tenant ID"},{"name":"Offering Items","required":true,"mapTo":"offering_items"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tenant_usages", "name": "Acronis Tenant Usages", "description": "GET /api/2/tenants/{{inputs.Tenant ID}}/usages", "method": "GET", "path": "/api/2/tenants/{{inputs.Tenant ID}}/usages", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"Tenant ID"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "users_list", "name": "Acronis Users List", "description": "GET /api/2/users", "method": "GET", "path": "/api/2/users", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"After","required":false,"mapTo":"after"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "user_create", "name": "Acronis User Create", "description": "POST /api/2/users", "method": "POST", "path": "/api/2/users", "inputs": [{"name":"Tenant ID","required":true,"mapTo":"tenant_id"},{"name":"Login","required":true,"mapTo":"login"},{"name":"Contact","required":true,"mapTo":"contact"},{"name":"Activated","required":false,"mapTo":"activated"},{"name":"Business Type","required":false,"mapTo":"business_type"}], "outputs": [{"name":"User ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "user_retrieve", "name": "Acronis User Retrieve", "description": "GET /api/2/users/{{inputs.User ID}}", "method": "GET", "path": "/api/2/users/{{inputs.User ID}}", "inputs": [{"name":"User ID","required":true,"mapTo":"User ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "user_send_activation", "name": "Acronis User Send Activation", "description": "POST /api/2/users/{{inputs.User ID}}/send-activation-email", "method": "POST", "path": "/api/2/users/{{inputs.User ID}}/send-activation-email", "inputs": [{"name":"User ID","required":true,"mapTo":"User ID"}], "outputs": [{"name":"Response Code","path":"response_code"}] },
    { "id": "resources_list", "name": "Acronis Resources List", "description": "GET /api/resource_management/v4/resources", "method": "GET", "path": "/api/resource_management/v4/resources", "inputs": [{"name":"Tenant ID","required":false,"mapTo":"tenant"},{"name":"Kind","required":false,"mapTo":"kind"},{"name":"Limit","required":false,"mapTo":"limit"},{"name":"After","required":false,"mapTo":"after"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "resource_retrieve", "name": "Acronis Resource Retrieve", "description": "GET /api/resource_management/v4/resources/{{inputs.Resource ID}}", "method": "GET", "path": "/api/resource_management/v4/resources/{{inputs.Resource ID}}", "inputs": [{"name":"Resource ID","required":true,"mapTo":"Resource ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "alerts_list", "name": "Acronis Alerts List", "description": "GET /api/alert_manager/v1/alerts", "method": "GET", "path": "/api/alert_manager/v1/alerts", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"},{"name":"Severity","required":false,"mapTo":"severity"},{"name":"Category","required":false,"mapTo":"category"},{"name":"Limit","required":false,"mapTo":"limit"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "alert_dismiss", "name": "Acronis Alert Dismiss", "description": "DELETE /api/alert_manager/v1/alerts/{{inputs.Alert ID}}", "method": "DELETE", "path": "/api/alert_manager/v1/alerts/{{inputs.Alert ID}}", "inputs": [{"name":"Alert ID","required":true,"mapTo":"Alert ID"}], "outputs": [{"name":"Response Code","path":"response_code"}] },
    { "id": "activities_list", "name": "Acronis Activities List", "description": "GET /api/task_manager/v2/activities", "method": "GET", "path": "/api/task_manager/v2/activities", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"},{"name":"State","required":false,"mapTo":"state"},{"name":"Limit","required":false,"mapTo":"limit"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "activity_retrieve", "name": "Acronis Activity Retrieve", "description": "GET /api/task_manager/v2/activities/{{inputs.Activity ID}}", "method": "GET", "path": "/api/task_manager/v2/activities/{{inputs.Activity ID}}", "inputs": [{"name":"Activity ID","required":true,"mapTo":"Activity ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "backup_plans_list", "name": "Acronis Backup Plans List", "description": "GET /api/policy_management/v4/policies", "method": "GET", "path": "/api/policy_management/v4/policies", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"},{"name":"Limit","required":false,"mapTo":"limit"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "backup_plan_run", "name": "Acronis Backup Plan Run", "description": "POST /api/policy_management/v4/policies/{{inputs.Policy ID}}/run", "method": "POST", "path": "/api/policy_management/v4/policies/{{inputs.Policy ID}}/run", "inputs": [{"name":"Policy ID","required":true,"mapTo":"Policy ID"},{"name":"Resource ID","required":false,"mapTo":"resource_id"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "reports_list", "name": "Acronis Reports List", "description": "GET /api/reporting/v4/reports", "method": "GET", "path": "/api/reporting/v4/reports", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "events_list", "name": "Acronis Events List", "description": "GET /api/event_service/v2/events", "method": "GET", "path": "/api/event_service/v2/events", "inputs": [{"name":"Tenant","required":false,"mapTo":"tenant"},{"name":"Start","required":false,"mapTo":"start"},{"name":"End","required":false,"mapTo":"end"},{"name":"Limit","required":false,"mapTo":"limit"}], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "applications_list", "name": "Acronis Applications List", "description": "GET /api/2/applications", "method": "GET", "path": "/api/2/applications", "inputs": [], "outputs": [{"name":"Items","path":"items"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
