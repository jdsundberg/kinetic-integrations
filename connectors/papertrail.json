{
  "id": "papertrail",
  "service": "Papertrail",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Papertrail integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#35568C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">P</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "search",
      "name": "Papertrail Search",
      "description": "GET /api/v1/events/search.json?q={query}",
      "method": "GET",
      "path": "/api/v1/events/search.json?q={{inputs.Query}}",
      "inputs": [
        {
          "name": "Query",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Events JSON",
          "path": "events"
        }
      ]
    },
    {
      "id": "test",
      "name": "Papertrail Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://papertrailapp.com"
}
