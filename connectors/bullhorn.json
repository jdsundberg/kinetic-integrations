{
  "id": "bullhorn",
  "service": "Bullhorn",
  "version": 1,
  "category": "HR & People",
  "description": "Bullhorn integration with 3 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      },
      {
        "name": "auth_url",
        "required": true,
        "description": "auth url."
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#FF6600\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">B</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "candidate_create",
      "name": "Bullhorn Candidate Create",
      "description": "PUT /rest-services/{corpToken}/entity/Candidate",
      "method": "PUT",
      "path": "/rest-services/{corpToken}/entity/Candidate",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Candidate ID",
          "path": "changedEntityId"
        }
      ]
    },
    {
      "id": "search",
      "name": "Bullhorn Search",
      "description": "GET /rest-services/{corpToken}/search/Candidate?query={query}",
      "method": "GET",
      "path": "/rest-services/{corpToken}/search/Candidate?query={query}",
      "inputs": [
        {
          "name": "Query",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Results JSON",
          "path": "data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Bullhorn Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}