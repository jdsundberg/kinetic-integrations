{
  "id": "auth0",
  "service": "Auth0",
  "version": 1,
  "category": "Security & Identity",
  "description": "Auth0 integration with 6 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "domain",
        "required": true,
        "description": "Auth0 tenant domain (e.g. myco.auth0.com)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#EB5424\"><path d=\"M16.5 24l-4.5-7.8 4.5-7.8h-9L3 16.2 7.5 24h9zm-9-24l-4.5 7.8 4.5 7.8h9L21 7.8 16.5 0h-9z\"/></svg>",
  "docsUrl": "https://auth0.com/docs/api",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
