      "id": "role_assign",
      "name": "Auth0 Role Assign",
      "description": "Auth0 Role Assign.",
      "method": "POST",
      "path": "/v2/users/{{inputs.User Id}}/roles",
      "inputs": [
        {
          "name": "User Id",
          "required": true,
          "mapTo": "User Id"
        },
        {
          "name": "Role Ids",
          "required": true,
          "mapTo": "Role Ids"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
