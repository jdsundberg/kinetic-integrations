{
  "id": "mulesoft",
  "service": "Mulesoft",
  "version": 1,
  "category": "Data & Analytics",
  "description": "Mulesoft integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      },
      {
        "name": "org_id",
        "required": true,
        "description": "org id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">M</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "application_list",
      "name": "MuleSoft Application List",
      "description": "GET /cloudhub/api/v2/applications",
      "method": "GET",
      "path": "/cloudhub/api/v2/applications",
      "inputs": [],
      "outputs": [
        {
          "name": "Applications JSON",
          "path": "applications"
        }
      ]
    },
    {
      "id": "test",
      "name": "Mulesoft Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}