{
  "id": "webflow",
  "service": "Webflow",
  "version": 1,
  "category": "Commerce & Content",
  "description": "Webflow integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#4353FF\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">W</text></svg>",
  "docsUrl": "https://docs.developers.webflow.com/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "item_create",
      "name": "Webflow Collection Item Create",
      "description": "POST /v2/collections/{collection_id}/items",
      "method": "POST",
      "path": "/v2/collections/{{inputs.Collection ID}}/items",
      "inputs": [
        {
          "name": "Collection ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Fields JSON",
          "required": true,
          "mapTo": "Fields JSON"
        }
      ],
      "outputs": [
        {
          "name": "Item ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "item_list",
      "name": "Webflow Collection Item List",
      "description": "GET /v2/collections/{collection_id}/items",
      "method": "GET",
      "path": "/v2/collections/{{inputs.Collection ID}}/items",
      "inputs": [
        {
          "name": "Collection ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Items JSON",
          "path": "items"
        }
      ]
    },
    {
      "id": "test",
      "name": "Webflow Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}