      "name": "Veeam VSPC Connection Test",
      "description": "GET /api/v3/about",
      "method": "GET",
      "path": "/api/v3/about",
      "inputs": [],
      "outputs": [
        { "name": "Response Code", "path": "response_code" },
        { "name": "Connected", "path": "connected" }
      ]
    },
    {
      "id": "organizations_list",
      "name": "Veeam VSPC Organizations List",
      "description": "GET /api/v3/organizations",
      "method": "GET",
      "path": "/api/v3/organizations",
      "inputs": [
        { "name": "Limit", "required": false, "mapTo": "limit" },
        { "name": "Offset", "required": false, "mapTo": "offset" },
        { "name": "Filter", "required": false, "mapTo": "filter" }
      ],
      "outputs": [
        { "name": "Data", "path": "data" },
        { "name": "Meta", "path": "meta" },
        { "name": "Response Body", "path": "response_body" },
        { "name": "Response Code", "path": "response_code" }
      ]
    },
    {
      "id": "organization_retrieve",
