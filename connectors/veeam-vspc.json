{
  "id": "veeam-vspc",
  "service": "Veeam VSPC",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Veeam Service Provider Console integration with 28 pre-built routines covering organizations (tenants), companies, locations, sites, backup servers, jobs (start/stop/enable/disable), backups, sessions, alarms, managed/discovered computers, licensing, and invoices — the MSP multi-tenant control plane for Veeam.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "api_url",
        "required": true,
        "description": "VSPC server API base URL, e.g. https://vspc.example.com:1280. The connector appends /api/v3/... to this base."
      },
      {
        "name": "username",
        "required": true,
        "description": "VSPC portal administrator or reseller/company user with API access."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password for the VSPC user.",
        "encrypted": true
      },
      {
        "name": "verify_tls",
        "required": false,
        "description": "Whether to verify the TLS certificate. Default true. Set false only for lab/self-signed deployments."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00B336\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"9\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">VSPC</text></svg>",
  "docsUrl": "https://helpcenter.veeam.com/docs/vac/rest/overview.html",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "baseUrl": "https://VSPC-HOST:1280",
  "routines": [
