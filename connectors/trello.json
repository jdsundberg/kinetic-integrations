{
  "id": "trello",
  "service": "Trello",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Trello integration with 7 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "token",
        "required": true,
        "description": "Trello API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#0052CC\"><path d=\"M21 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.3 3 3 3h18c1.7 0 3-1.3 3-3V3c0-1.7-1.3-3-3-3zM10.4 18.2c0 .8-.6 1.4-1.4 1.4H5c-.8 0-1.4-.6-1.4-1.4V5c0-.8.6-1.4 1.4-1.4H9c.8 0 1.4.6 1.4 1.4v13.1zm10.1-6c0 .8-.6 1.4-1.4 1.4h-4c-.8 0-1.4-.6-1.4-1.4V5c0-.8.6-1.4 1.4-1.4h4c.8 0 1.4.6 1.4 1.4v7.1z\"/></svg>",
  "docsUrl": "https://developer.atlassian.com/cloud/trello/rest/api-group-actions/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "board_create",
      "name": "Trello Board Create",
      "description": "POST https://api.trello.com/1/boards",
      "method": "POST",
      "path": "/1/boards",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Desc",
          "required": false,
          "mapTo": "Desc"
        },
        {
          "name": "Default Lists",
          "required": false,
          "mapTo": "Default Lists"
        },
        {
          "name": "Organization Id",
          "required": false,
          "mapTo": "Organization Id"
        }
      ],
      "outputs": [
        {
          "name": "Board ID",
          "path": "board_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Short URL",
          "path": "short_url"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
