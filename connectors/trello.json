      "path": "/1/lists",
      "inputs": [
        {
          "name": "Board Id",
          "required": true,
          "mapTo": "Board Id"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Pos",
          "required": false,
          "mapTo": "Pos"
