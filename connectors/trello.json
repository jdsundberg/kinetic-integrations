        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Desc",
          "required": false,
          "mapTo": "Desc"
        },
        {
          "name": "Pos",
          "required": false,
          "mapTo": "Pos"
        },
        {
          "name": "Due",
          "required": false,
          "mapTo": "Due"
        }
