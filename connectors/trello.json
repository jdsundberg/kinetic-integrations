      "description": "PUT https://api.trello.com/1/boards/{{inputs.Board Id}}/members/{{inputs.Member Id}}",
      "method": "PUT",
      "path": "/1/boards/{{inputs.Board Id}}/members/{{inputs.Member Id}}",
      "inputs": [
