{
  "id": "dynamics365-bc",
  "service": "Dynamics365 Bc",
  "version": 1,
  "category": "Accounting",
  "description": "Dynamics365 Bc integration with 9 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "Azure AD token endpoint."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "Azure AD app client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "Azure AD app client secret.",
        "encrypted": true
      },
      {
        "name": "tenant_id",
        "required": true,
        "description": "Azure AD tenant ID."
      },
      {
        "name": "environment",
        "required": true,
        "description": "Business Central environment name (e.g. Production)."
      },
      {
        "name": "company_id",
        "required": true,
        "description": "Business Central company ID."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#E65100\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">D</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "account_list",
      "name": "Dynamics 365 Business Central Chart of Accounts",
      "description": "GET /api/v2.0/companies/{company_id}/accounts",
      "method": "GET",
      "path": "/api/v2.0/companies/{company_id}/accounts",
      "inputs": [],
      "outputs": [
        {
          "name": "Accounts JSON",
          "path": "accounts"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "bill_create",
      "name": "Dynamics 365 Business Central Bill Create",
      "description": "POST /api/v2.0/companies/{company_id}/bills",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/bills",
      "inputs": [
        {
          "name": "Vendor Id",
          "required": true,
          "mapTo": "Vendor Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        }
      ],
      "outputs": [
        {
          "name": "Bill Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "customer_create",
      "name": "Dynamics 365 Business Central Customer Create",
      "description": "POST /api/v2.0/companies/{company_id}/customers",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/customers",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        },
        {
          "name": "Address",
          "required": false,
          "mapTo": "Address"
        }
      ],
      "outputs": [
        {
          "name": "Customer Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    },
    {
      "id": "invoice_create",
      "name": "Dynamics 365 Business Central Invoice Create",
      "description": "POST /api/v2.0/companies/{company_id}/invoices",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/invoices",
      "inputs": [
        {
          "name": "Customer Id",
          "required": true,
          "mapTo": "Customer Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        },
        {
          "name": "Currency",
          "required": false,
          "mapTo": "Currency"
        }
      ],
      "outputs": [
        {
          "name": "Invoice Id",
          "path": "id"
        },
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "invoice_retrieve",
      "name": "Dynamics 365 Business Central Invoice Retrieve",
      "description": "GET /api/v2.0/companies/{company_id}/invoices/{invoice_id}",
      "method": "GET",
      "path": "/api/v2.0/companies/{company_id}/invoices/{invoice_id}",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Total",
          "path": "total"
        },
        {
          "name": "Balance Due",
          "path": "balance"
        }
      ]
    },
    {
      "id": "journal_entry_create",
      "name": "Dynamics 365 Business Central Journal Entry Create",
      "description": "POST /api/v2.0/companies/{company_id}/journal-entries",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/journal-entries",
      "inputs": [
        {
          "name": "Date",
          "required": true,
          "mapTo": "Date"
        },
        {
          "name": "Lines JSON",
          "required": true,
          "mapTo": "Lines JSON"
        },
        {
          "name": "Memo",
          "required": false,
          "mapTo": "Memo"
        }
      ],
      "outputs": [
        {
          "name": "Entry Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "Dynamics 365 Business Central Payment Create",
      "description": "POST /api/v2.0/companies/{company_id}/payments",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/payments",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "mapTo": "Invoice Id"
        },
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Payment Date",
          "required": false,
          "mapTo": "Payment Date"
        },
        {
          "name": "Payment Method",
          "required": false,
          "mapTo": "Payment Method"
        }
      ],
      "outputs": [
        {
          "name": "Payment Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "test",
      "name": "Dynamics365 Bc Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "vendor_create",
      "name": "Dynamics 365 Business Central Vendor Create",
      "description": "POST /api/v2.0/companies/{company_id}/vendors",
      "method": "POST",
      "path": "/api/v2.0/companies/{company_id}/vendors",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Vendor Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    }
  ]
}