{
  "id": "helpscout",
  "service": "Helpscout",
  "version": 1,
  "category": "Other",
  "description": "Helpscout integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">H</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "conversation_create",
      "name": "Help Scout Conversation Create",
      "description": "POST /v2/conversations",
      "method": "POST",
      "path": "/v2/conversations",
      "inputs": [
        {
          "name": "Subject",
          "required": true,
          "mapTo": "Subject"
        },
        {
          "name": "Customer Email",
          "required": true,
          "mapTo": "Customer Email"
        },
        {
          "name": "Mailbox ID",
          "required": true,
          "mapTo": "Mailbox ID"
        },
        {
          "name": "Text",
          "required": true,
          "mapTo": "Text"
        }
      ],
      "outputs": [
        {
          "name": "Conversation ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "conversation_list",
      "name": "Help Scout Conversation List",
      "description": "GET /v2/conversations?mailbox={mailbox_id}",
      "method": "GET",
      "path": "/v2/conversations?mailbox={{inputs.Mailbox ID}}",
      "inputs": [
        {
          "name": "Mailbox ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Conversations JSON",
          "path": "_embedded.conversations"
        }
      ]
    },
    {
      "id": "test",
      "name": "Helpscout Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.helpscout.net"
}
