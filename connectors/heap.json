{
  "id": "heap",
  "service": "Heap",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Heap integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "app_id",
        "required": true,
        "description": "app id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#5B30A6\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">H</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "test",
      "name": "Heap Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "track",
      "name": "Heap Track Event",
      "description": "POST /api/track",
      "method": "POST",
      "path": "/api/track",
      "inputs": [
        {
          "name": "Identity",
          "required": true,
          "mapTo": "Identity"
        },
        {
          "name": "Event",
          "required": true,
          "mapTo": "Event"
        },
        {
          "name": "Properties JSON",
          "required": false,
          "mapTo": "Properties JSON"
        }
      ],
      "outputs": []
    },
    {
      "id": "user_add_properties",
      "name": "Heap Add User Properties",
      "description": "POST /api/add_user_properties",
      "method": "POST",
      "path": "/api/add_user_properties",
      "inputs": [
        {
          "name": "Identity",
          "required": true,
          "mapTo": "Identity"
        },
        {
          "name": "Properties JSON",
          "required": true,
          "mapTo": "Properties JSON"
        }
      ],
      "outputs": []
    }
  ]
}