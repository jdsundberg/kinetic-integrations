{
  "id": "launchdarkly",
  "service": "Launchdarkly",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Launchdarkly integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">L</text></svg>",
  "docsUrl": "https://apidocs.launchdarkly.com/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "flag_list",
      "name": "LaunchDarkly Flag List",
      "description": "GET /api/v2/flags/{projectKey}",
      "method": "GET",
      "path": "/api/v2/flags/{projectKey}",
      "inputs": [
        {
          "name": "Project Key",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Flags JSON",
          "path": "items"
        }
      ]
    },
    {
      "id": "flag_toggle",
      "name": "LaunchDarkly Flag Toggle",
      "description": "PATCH /api/v2/flags/{projectKey}/{flagKey}",
      "method": "PATCH",
      "path": "/api/v2/flags/{projectKey}/{flagKey}",
      "inputs": [
        {
          "name": "Project Key",
          "required": true,
          "mapTo": "Project Key"
        },
        {
          "name": "Flag Key",
          "required": true,
          "mapTo": "Flag Key"
        },
        {
          "name": "On",
          "required": true,
          "mapTo": "On"
        }
      ],
      "outputs": [
        {
          "name": "Key",
          "path": "key"
        },
        {
          "name": "On",
          "path": "on"
        }
      ]
    },
    {
      "id": "test",
      "name": "Launchdarkly Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}