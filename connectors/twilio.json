{
  "id": "twilio",
  "service": "Twilio",
  "version": 1,
  "category": "Communication",
  "description": "Twilio integration with 8 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "account_sid",
        "required": true,
        "description": "Twilio Account SID."
      },
      {
        "name": "auth_token",
        "required": true,
        "description": "Twilio Auth Token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#F22F46\"><path d=\"M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm0 20.4a8.4 8.4 0 110-16.8 8.4 8.4 0 010 16.8zm3.6-11.4a1.8 1.8 0 11-3.6 0 1.8 1.8 0 013.6 0zm0 4.8a1.8 1.8 0 11-3.6 0 1.8 1.8 0 013.6 0zm-4.8-4.8a1.8 1.8 0 11-3.6 0 1.8 1.8 0 013.6 0zm0 4.8a1.8 1.8 0 11-3.6 0 1.8 1.8 0 013.6 0z\"/></svg>",
  "docsUrl": "https://www.twilio.com/docs/usage/api",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "call_create",
      "name": "Twilio Call Create",
      "description": "POST https://api.twilio.com/2010-04-01/Accounts/<%= @info['account_sid'] %>/Calls.json",
      "method": "POST",
      "path": "/2010-04-01/Accounts/Calls.json",
      "inputs": [
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "From",
          "required": true,
          "mapTo": "From"
        },
        {
          "name": "Url",
          "required": true,
          "mapTo": "Url"
        },
        {
          "name": "Status Callback",
          "required": false,
          "mapTo": "Status Callback"
        }
      ],
      "outputs": [
        {
          "name": "Call SID",
          "path": "call_sid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "conversation_create",
      "name": "Twilio Conversation Create",
      "description": "POST https://conversations.twilio.com/v1/Conversations",
      "method": "POST",
      "path": "/v1/Conversations",
      "inputs": [
        {
          "name": "Friendly Name",
          "required": true,
          "mapTo": "Friendly Name"
        },
        {
          "name": "Unique Name",
          "required": false,
          "mapTo": "Unique Name"
        }
      ],
      "outputs": [
        {
          "name": "Conversation SID",
          "path": "conversation_sid"
        },
        {
          "name": "Friendly Name",
          "path": "friendly_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "message_retrieve",
      "name": "Twilio Message Retrieve",
      "description": "GET https://api.twilio.com/2010-04-01/Accounts/<%= @info['account_sid'] %>/Messages/<%= @inputs['Message Sid'] %>.json",
      "method": "GET",
      "path": "/2010-04-01/Accounts/Messages/<%= @inputs['Message Sid'] %>.json",
      "inputs": [
        {
          "name": "Message Sid",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "SID",
          "path": "sid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Body",
          "path": "body"
        },
        {
          "name": "From",
          "path": "from"
        },
        {
          "name": "To",
          "path": "to"
        },
        {
          "name": "Message JSON",
          "path": "message_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "number_lookup",
      "name": "Twilio Number Lookup",
      "description": "GET https://lookups.twilio.com/v2/PhoneNumbers/<%= @inputs['Phone Number'] %>",
      "method": "GET",
      "path": "/v2/PhoneNumbers/<%= @inputs['Phone Number'] %>",
      "inputs": [
        {
          "name": "Phone Number",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Phone Number",
          "path": "phone_number"
        },
        {
          "name": "Country Code",
          "path": "country_code"
        },
        {
          "name": "Valid",
          "path": "valid"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "sms_send",
      "name": "Twilio SMS Send",
      "description": "POST https://api.twilio.com/2010-04-01/Accounts/<%= @info['account_sid'] %>/Messages.json",
      "method": "POST",
      "path": "/2010-04-01/Accounts/Messages.json",
      "inputs": [
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "From",
          "required": true,
          "mapTo": "From"
        },
        {
          "name": "Body",
          "required": true,
          "mapTo": "Body"
        },
        {
          "name": "Status Callback",
          "required": false,
          "mapTo": "Status Callback"
        }
      ],
      "outputs": [
        {
          "name": "Message SID",
          "path": "message_sid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Date Sent",
          "path": "date_sent"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Twilio Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "verify_check",
      "name": "Twilio Verify Check",
      "description": "POST https://verify.twilio.com/v2/Services/<%= @inputs['Service Sid'] %>/VerificationCheck",
      "method": "POST",
      "path": "/v2/Services/<%= @inputs['Service Sid'] %>/VerificationCheck",
      "inputs": [
        {
          "name": "Service Sid",
          "required": true,
          "mapTo": "Service Sid"
        },
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "Code",
          "required": true,
          "mapTo": "Code"
        }
      ],
      "outputs": [
        {
          "name": "SID",
          "path": "sid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Valid",
          "path": "valid"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "verify_send",
      "name": "Twilio Verify Send",
      "description": "POST https://verify.twilio.com/v2/Services/<%= @inputs['Service Sid'] %>/Verifications",
      "method": "POST",
      "path": "/v2/Services/<%= @inputs['Service Sid'] %>/Verifications",
      "inputs": [
        {
          "name": "Service Sid",
          "required": true,
          "mapTo": "Service Sid"
        },
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "Channel",
          "required": true,
          "mapTo": "Channel"
        }
      ],
      "outputs": [
        {
          "name": "SID",
          "path": "sid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Channel",
          "path": "channel"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}