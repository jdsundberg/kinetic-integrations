{
  "id": "datto-rmm",
  "service": "Datto RMM",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Datto RMM integration with 30 pre-built routines covering sites, devices, alerts, jobs, components, audits, quick jobs, UDFs, and warranty \u2014 the operational surface an MSP needs to monitor and control endpoints across customer sites.",
  "auth": {
    "type": "oauth2_password",
    "properties": [
      {
        "name": "api_url",
        "required": true,
        "description": "Datto RMM platform API URL. Format: https://{platform}-api.centrastage.net/api (pinotage, merlot, vidal, syrah, zinfandel, concord). Found in the Datto RMM UI under Setup > Global Settings > API."
      },
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint. For Datto RMM use /auth/oauth/token.",
        "defaultValue": "/auth/oauth/token"
      },
      {
        "name": "username",
        "required": true,
        "description": "Datto RMM API Key (treated as the OAuth2 password-grant username).",
        "encrypted": true
      },
      {
        "name": "password",
        "required": true,
        "description": "Datto RMM API Secret Key (treated as the OAuth2 password-grant password).",
        "encrypted": true
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client_id. Datto RMM uses the literal value 'public-client'.",
        "defaultValue": "public-client"
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client_secret. Datto RMM uses the literal value 'public'.",
        "defaultValue": "public"
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0072CE\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">DR</text></svg>",
  "docsUrl": "https://help.datto.com/s/article/KB363124686",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "baseUrl": "https://PLATFORM-api.centrastage.net/api",
