{
  "id": "aws-sns",
  "service": "Aws Sns",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Aws Sns integration with 5 pre-built routines.",
  "auth": {
    "type": "aws",
    "properties": [
      {
        "name": "aws_access_key_id",
        "required": true,
        "description": "AWS access key ID."
      },
      {
        "name": "aws_secret_access_key",
        "required": true,
        "description": "AWS secret access key.",
        "encrypted": true
      },
      {
        "name": "aws_region",
        "required": true,
        "description": "AWS region (e.g. us-east-1)."
      },
      {
        "name": "aws_service",
        "required": false,
        "description": "AWS service name for signing."
      },
      {
        "name": "region",
        "required": true,
        "description": "AWS region."
      },
      {
        "name": "access_key_id",
        "required": true,
        "description": "AWS access key ID."
      },
      {
        "name": "secret_access_key",
        "required": true,
        "description": "AWS secret access key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#E65100\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "publish",
      "name": "AWS SNS Publish",
      "description": "AWS SNS Publish.",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Topic Arn",
          "required": true,
          "mapTo": "Topic Arn"
        },
        {
          "name": "Message",
          "required": true,
          "mapTo": "Message"
        },
        {
          "name": "Subject",
          "required": false,
          "mapTo": "Subject"
        },
        {
          "name": "Message Structure",
          "required": false,
          "mapTo": "Message Structure"
        }
      ],
      "outputs": [
        {
          "name": "Message ID",
          "path": "message_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "subscribe",
      "name": "AWS SNS Subscribe",
      "description": "AWS SNS Subscribe.",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Topic Arn",
          "required": true,
          "mapTo": "Topic Arn"
        },
        {
          "name": "Protocol",
          "required": true,
          "mapTo": "Protocol"
        },
        {
          "name": "Endpoint",
          "required": true,
          "mapTo": "Endpoint"
        }
      ],
      "outputs": [
        {
          "name": "Subscription ARN",
          "path": "subscription_arn"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Aws Sns Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "topic_create",
      "name": "AWS SNS Topic Create",
      "description": "AWS SNS Topic Create.",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Display Name",
          "required": false,
          "mapTo": "Display Name"
        },
        {
          "name": "Fifo Topic",
          "required": false,
          "mapTo": "Fifo Topic"
        }
      ],
      "outputs": [
        {
          "name": "Topic ARN",
          "path": "topic_arn"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "unsubscribe",
      "name": "AWS SNS Unsubscribe",
      "description": "AWS SNS Unsubscribe.",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Subscription Arn",
          "required": true,
          "mapTo": "Subscription Arn"
        }
      ],
      "outputs": [
        {
          "name": "Request ID",
          "path": "request_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}