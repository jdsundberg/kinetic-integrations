{
  "id": "sentinelone",
  "service": "Sentinelone",
  "version": 1,
  "category": "Other",
  "description": "Sentinelone integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">S</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "agent_list",
      "name": "SentinelOne Agent List",
      "description": "GET /web/api/v2.1/agents",
      "method": "GET",
      "path": "/web/api/v2.1/agents",
      "inputs": [
        {
          "name": "Computer Name Contains",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Agents JSON",
          "path": "data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Sentinelone Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "threat_list",
      "name": "SentinelOne Threat List",
      "description": "GET /web/api/v2.1/threats",
      "method": "GET",
      "path": "/web/api/v2.1/threats",
      "inputs": [
        {
          "name": "Created After",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Threats JSON",
          "path": "data"
        }
      ]
    }
  ]
}