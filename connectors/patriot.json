{
  "id": "patriot",
  "service": "Patriot",
  "version": 1,
  "category": "Accounting",
  "description": "Patriot integration with 8 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "Patriot API key.",
        "encrypted": true
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "account_list",
      "name": "Patriot Accounting Chart of Accounts",
      "description": "GET /api/v1/accounts",
      "method": "GET",
      "path": "/api/v1/accounts",
      "inputs": [],
      "outputs": [
        {
          "name": "Accounts JSON",
          "path": "accounts"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "bill_create",
      "name": "Patriot Accounting Bill Create",
      "description": "POST /api/v1/bills",
      "method": "POST",
      "path": "/api/v1/bills",
      "inputs": [
        {
          "name": "Vendor Id",
          "required": true,
          "mapTo": "Vendor Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        }
      ],
      "outputs": [
        {
          "name": "Bill Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "customer_create",
      "name": "Patriot Accounting Customer Create",
      "description": "POST /api/v1/customers",
      "method": "POST",
      "path": "/api/v1/customers",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        },
        {
          "name": "Address",
          "required": false,
          "mapTo": "Address"
        }
      ],
      "outputs": [
        {
          "name": "Customer Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    },
    {
      "id": "invoice_create",
      "name": "Patriot Accounting Invoice Create",
      "description": "POST /api/v1/invoices",
      "method": "POST",
      "path": "/api/v1/invoices",
      "inputs": [
        {
          "name": "Customer Id",
          "required": true,
          "mapTo": "Customer Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        },
        {
          "name": "Currency",
          "required": false,
          "mapTo": "Currency"
        }
      ],
      "outputs": [
        {
          "name": "Invoice Id",
          "path": "id"
        },
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "invoice_retrieve",
      "name": "Patriot Accounting Invoice Retrieve",
      "description": "GET /api/v1/invoices/{invoice_id}",
      "method": "GET",
      "path": "/api/v1/invoices/{invoice_id}",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Total",
          "path": "total"
        },
        {
          "name": "Balance Due",
          "path": "balance"
        }
      ]
    },
    {
      "id": "journal_entry_create",
      "name": "Patriot Accounting Journal Entry Create",
      "description": "POST /api/v1/journal-entries",
      "method": "POST",
      "path": "/api/v1/journal-entries",
      "inputs": [
        {
          "name": "Date",
          "required": true,
          "mapTo": "Date"
        },
        {
          "name": "Lines JSON",
          "required": true,
          "mapTo": "Lines JSON"
        },
        {
          "name": "Memo",
          "required": false,
          "mapTo": "Memo"
        }
      ],
      "outputs": [
        {
          "name": "Entry Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "Patriot Accounting Payment Create",
      "description": "POST /api/v1/payments",
      "method": "POST",
      "path": "/api/v1/payments",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "mapTo": "Invoice Id"
        },
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Payment Date",
          "required": false,
          "mapTo": "Payment Date"
        },
        {
          "name": "Payment Method",
          "required": false,
          "mapTo": "Payment Method"
        }
      ],
      "outputs": [
        {
          "name": "Payment Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "vendor_create",
      "name": "Patriot Accounting Vendor Create",
      "description": "POST /api/v1/vendors",
      "method": "POST",
      "path": "/api/v1/vendors",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Vendor Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    }
  ]
}