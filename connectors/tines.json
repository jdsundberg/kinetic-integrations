{
  "id": "tines",
  "service": "Tines",
  "version": 1,
  "category": "Other",
  "description": "Tines integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#8B5CF6\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "story_run",
      "name": "Tines Story Run",
      "description": "POST /api/v1/stories/{story_id}/trigger",
      "method": "POST",
      "path": "/api/v1/stories/{story_id}/trigger",
      "inputs": [
        {
          "name": "Story ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Payload JSON",
          "required": false,
          "mapTo": "Payload JSON"
        }
      ],
      "outputs": [
        {
          "name": "Run ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Tines Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}