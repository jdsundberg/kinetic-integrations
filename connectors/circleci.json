{
  "id": "circleci",
  "service": "Circleci",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Circleci integration with 5 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "api_key_header",
        "required": false,
        "description": "Header name for the API key. Default: Circle-Token"
      },
      {
        "name": "api_token",
        "required": true,
        "description": "CircleCI personal API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#283593\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">C</text></svg>",
  "docsUrl": "https://circleci.com/docs/api/v2/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "artifact_retrieve",
      "name": "CircleCI Artifact Retrieve",
      "description": "GET https://circleci.com/api/v2/project/{{inputs.Project Slug}}/{{inputs.Job Number}}/artifacts",
      "method": "GET",
      "path": "/api/v2/project/{{inputs.Project Slug}}/{{inputs.Job Number}}/artifacts",
      "inputs": [
        {
          "name": "Project Slug",
          "required": true
        },
        {
          "name": "Job Number",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Artifacts JSON",
          "path": "artifacts_json"
        },
        {
          "name": "Next Page Token",
          "path": "next_page_token"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "job_cancel",
      "name": "CircleCI Job Cancel",
      "description": "POST https://circleci.com/api/v2/project/{{inputs.Project Slug}}/job/{{inputs.Job Number}}/cancel",
      "method": "POST",
      "path": "/api/v2/project/{{inputs.Project Slug}}/job/{{inputs.Job Number}}/cancel",
      "inputs": [
        {
          "name": "Project Slug",
          "required": true,
          "mapTo": "Project Slug"
        },
        {
          "name": "Job Number",
          "required": true,
          "mapTo": "Job Number"
        }
      ],
      "outputs": [
        {
          "name": "Message",
          "path": "message"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "pipeline_trigger",
      "name": "CircleCI Pipeline Trigger",
      "description": "POST https://circleci.com/api/v2/project/{{inputs.Project Slug}}/pipeline",
      "method": "POST",
      "path": "/api/v2/project/{{inputs.Project Slug}}/pipeline",
      "inputs": [
        {
          "name": "Project Slug",
          "required": true,
          "mapTo": "Project Slug"
        },
        {
          "name": "Branch",
          "required": false,
          "mapTo": "Branch"
        },
        {
          "name": "Tag",
          "required": false,
          "mapTo": "Tag"
        },
        {
          "name": "Parameters Json",
          "required": false,
          "mapTo": "Parameters Json"
        }
      ],
      "outputs": [
        {
          "name": "Pipeline ID",
          "path": "pipeline_id"
        },
        {
          "name": "Number",
          "path": "number"
        },
        {
          "name": "State",
          "path": "state"
        },
        {
          "name": "Created At",
          "path": "created_at"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Circleci Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "workflow_approve",
      "name": "CircleCI Workflow Approve",
      "description": "POST https://circleci.com/api/v2/workflow/{{inputs.Workflow Id}}/approve/{{inputs.Approval Request Id}}",
      "method": "POST",
      "path": "/api/v2/workflow/{{inputs.Workflow Id}}/approve/{{inputs.Approval Request Id}}",
      "inputs": [
        {
          "name": "Workflow Id",
          "required": true,
          "mapTo": "Workflow Id"
        },
        {
          "name": "Approval Request Id",
          "required": true,
          "mapTo": "Approval Request Id"
        }
      ],
      "outputs": [
        {
          "name": "Message",
          "path": "message"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}