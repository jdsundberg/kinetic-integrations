{
  "id": "amplitude",
  "service": "Amplitude",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Amplitude integration with 3 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#1B1F3B\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "event_upload",
      "name": "Amplitude Event Upload",
      "description": "POST /2/httpapi",
      "method": "POST",
      "path": "/2/httpapi",
      "inputs": [
        {
          "name": "Events JSON",
          "required": true,
          "mapTo": "Events JSON"
        }
      ],
      "outputs": [
        {
          "name": "Code",
          "path": "code"
        },
        {
          "name": "Events Ingested",
          "path": "events_ingested"
        }
      ]
    },
    {
      "id": "test",
      "name": "Amplitude Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "user_search",
      "name": "Amplitude User Search",
      "description": "GET /1/usersearch?user={user_id}",
      "method": "GET",
      "path": "/1/usersearch?user={{inputs.User ID}}",
      "inputs": [
        {
          "name": "User ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Matches JSON",
          "path": "matches"
        }
      ]
    }
  ],
  "baseUrl": "https://amplitude.com"
}
