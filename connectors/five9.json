{
  "id": "five9",
  "service": "Five9",
  "version": 1,
  "category": "Other",
  "description": "Five9 integration with 2 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#FF6600\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">F</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "agent_list",
      "name": "Five9 Agent List",
      "description": "GET /appsvcs/rs/svc/agents",
      "method": "GET",
      "path": "/appsvcs/rs/svc/agents",
      "inputs": [],
      "outputs": [
        {
          "name": "Agents JSON",
          "path": "agents"
        }
      ]
    },
    {
      "id": "test",
      "name": "Five9 Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}