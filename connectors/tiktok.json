{
  "id": "tiktok",
  "service": "Tiktok",
  "version": 1,
  "category": "Social & Marketplace",
  "description": "Tiktok integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "test",
      "name": "Tiktok Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "user_info",
      "name": "TikTok User Info",
      "description": "GET /v2/user/info/",
      "method": "GET",
      "path": "/v2/user/info/",
      "inputs": [],
      "outputs": [
        {
          "name": "User JSON",
          "path": "data.user"
        }
      ]
    }
  ],
  "baseUrl": "https://open-api.tiktok.com"
}
