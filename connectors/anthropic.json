{
  "id": "anthropic",
  "service": "Anthropic",
  "version": 1,
  "category": "AI & Machine Learning",
  "description": "Anthropic integration with 2 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "anthropic_version",
        "required": true,
        "description": "anthropic version."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "message_create",
      "name": "Anthropic Claude Message Create",
      "description": "POST /v1/messages",
      "method": "POST",
      "path": "/v1/messages",
      "inputs": [
        {
          "name": "Model",
          "required": true,
          "mapTo": "Model"
        },
        {
          "name": "Prompt",
          "required": true,
          "mapTo": "Prompt"
        },
        {
          "name": "Max Tokens",
          "required": false,
          "mapTo": "Max Tokens"
        },
        {
          "name": "System Prompt",
          "required": false,
          "mapTo": "System Prompt"
        }
      ],
      "outputs": [
        {
          "name": "Response Text",
          "path": "content[0].text"
        },
        {
          "name": "Model",
          "path": "model"
        },
        {
          "name": "Stop Reason",
          "path": "stop_reason"
        },
        {
          "name": "Input Tokens",
          "path": "usage.input_tokens"
        },
        {
          "name": "Output Tokens",
          "path": "usage.output_tokens"
        }
      ]
    },
    {
      "id": "test",
      "name": "Anthropic Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}