{
  "id": "adobe-sign",
  "service": "Adobe Sign",
  "version": 1,
  "category": "Documents & Storage",
  "description": "Adobe Sign integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#EC1C24\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "agreement_cancel",
      "name": "Adobe Sign Agreement Cancel",
      "description": "PUT /api/rest/v6/agreements/{agreement_id}/state",
      "method": "PUT",
      "path": "/api/rest/v6/agreements/{{inputs.Agreement ID}}/state",
      "inputs": [
        {
          "name": "Agreement ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "agreement_create",
      "name": "Adobe Sign Agreement Create",
      "description": "POST /api/rest/v6/agreements",
      "method": "POST",
      "path": "/api/rest/v6/agreements",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Recipient Email",
          "required": true,
          "mapTo": "Recipient Email"
        },
        {
          "name": "Message",
          "required": false,
          "mapTo": "Message"
        }
      ],
      "outputs": [
        {
          "name": "Agreement ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "agreement_retrieve",
      "name": "Adobe Sign Agreement Retrieve",
      "description": "GET /api/rest/v6/agreements/{agreement_id}",
      "method": "GET",
      "path": "/api/rest/v6/agreements/{{inputs.Agreement ID}}",
      "inputs": [
        {
          "name": "Agreement ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    },
    {
      "id": "agreement_status",
      "name": "Adobe Sign Agreement Status",
      "description": "GET /api/rest/v6/agreements/{agreement_id}/signingUrls",
      "method": "GET",
      "path": "/api/rest/v6/agreements/{{inputs.Agreement ID}}/signingUrls",
      "inputs": [
        {
          "name": "Agreement ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Signing URL",
          "path": "signingUrlSetInfos[0].signingUrls[0].esignUrl"
        }
      ]
    },
    {
      "id": "test",
      "name": "Adobe Sign Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}