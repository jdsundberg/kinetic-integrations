{
  "id": "totango",
  "service": "Totango",
  "version": 1,
  "category": "Other",
  "description": "Totango integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00B47D\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "account_search",
      "name": "Totango Account Search",
      "description": "POST /api/v1/search/accounts",
      "method": "POST",
      "path": "/api/v1/search/accounts",
      "inputs": [
        {
          "name": "Query JSON",
          "required": true,
          "mapTo": "Query JSON"
        }
      ],
      "outputs": [
        {
          "name": "Accounts JSON",
          "path": "response.accounts.hits"
        }
      ]
    },
    {
      "id": "test",
      "name": "Totango Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}