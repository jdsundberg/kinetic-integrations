{
  "id": "gcp-pubsub",
  "service": "Gcp Pubsub",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Gcp Pubsub integration with 5 pre-built routines.",
  "auth": {
    "type": "jwt",
    "properties": [
      {
        "name": "service_account_email",
        "required": true,
        "description": "Google service account email."
      },
      {
        "name": "private_key",
        "required": true,
        "description": "PEM private key from service account JSON.",
        "encrypted": true
      },
      {
        "name": "jwt_subject",
        "required": false,
        "description": "Email to impersonate (domain-wide delegation)."
      },
      {
        "name": "jwt_scope",
        "required": true,
        "description": "OAuth2 scope for the JWT assertion."
      },
      {
        "name": "project_id",
        "required": true,
        "description": "GCP project ID."
      },
      {
        "name": "access_token",
        "required": true,
        "description": "GCP OAuth2 access token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00695C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">G</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "publish",
      "name": "GCP Pub/Sub Publish",
      "description": "GCP Pub/Sub Publish.",
      "method": "POST",
      "path": "/v1/projects/topics/<%= @inputs['Topic Id'] %>:publish",
      "inputs": [
        {
          "name": "Topic Id",
          "required": true,
          "mapTo": "Topic Id"
        },
        {
          "name": "Message Data",
          "required": true,
          "mapTo": "Message Data"
        },
        {
          "name": "Attributes Json",
          "required": false,
          "mapTo": "Attributes Json"
        }
      ],
      "outputs": [
        {
          "name": "Message IDs",
          "path": "message_ids"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "pull",
      "name": "GCP Pub/Sub Pull",
      "description": "GCP Pub/Sub Pull.",
      "method": "POST",
      "path": "/v1/projects/subscriptions/<%= @inputs['Subscription Id'] %>:pull",
      "inputs": [
        {
          "name": "Subscription Id",
          "required": true,
          "mapTo": "Subscription Id"
        },
        {
          "name": "Max Messages",
          "required": false,
          "mapTo": "Max Messages"
        }
      ],
      "outputs": [
        {
          "name": "Messages JSON",
          "path": "messages_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "subscription_create",
      "name": "GCP Pub/Sub Subscription Create",
      "description": "GCP Pub/Sub Subscription Create.",
      "method": "PUT",
      "path": "/v1/projects/subscriptions/<%= @inputs['Subscription Id'] %>",
      "inputs": [
        {
          "name": "Subscription Id",
          "required": true,
          "mapTo": "Subscription Id"
        },
        {
          "name": "Topic Id",
          "required": true,
          "mapTo": "Topic Id"
        },
        {
          "name": "Ack Deadline Seconds",
          "required": false,
          "mapTo": "Ack Deadline Seconds"
        },
        {
          "name": "Push Endpoint",
          "required": false,
          "mapTo": "Push Endpoint"
        }
      ],
      "outputs": [
        {
          "name": "Subscription Name",
          "path": "subscription_name"
        },
        {
          "name": "Topic",
          "path": "topic"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Gcp Pubsub Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "topic_create",
      "name": "GCP Pub/Sub Topic Create",
      "description": "GCP Pub/Sub Topic Create.",
      "method": "PUT",
      "path": "/v1/projects/topics/<%= @inputs['Topic Id'] %>",
      "inputs": [
        {
          "name": "Topic Id",
          "required": true,
          "mapTo": "Topic Id"
        },
        {
          "name": "Labels Json",
          "required": false,
          "mapTo": "Labels Json"
        }
      ],
      "outputs": [
        {
          "name": "Topic Name",
          "path": "topic_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}