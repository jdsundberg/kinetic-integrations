{
  "id": "taxslayer-pro",
  "service": "Taxslayer Pro",
  "version": 1,
  "category": "Tax Software",
  "description": "Taxslayer Pro integration with 6 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "TaxSlayer Pro API key.",
        "encrypted": true
      },
      {
        "name": "efin",
        "required": true,
        "description": "Electronic Filing ID Number."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "client_create",
      "name": "TaxSlayer Pro Client Create",
      "description": "POST /api/v1/clients",
      "method": "POST",
      "path": "/api/v1/clients",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "SSN",
          "required": true,
          "mapTo": "SSN"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Client Id",
          "path": "id"
        }
      ]
    },
    {
      "id": "return_create",
      "name": "TaxSlayer Pro Return Create",
      "description": "POST /api/v1/returns",
      "method": "POST",
      "path": "/api/v1/returns",
      "inputs": [
        {
          "name": "Taxpayer SSN",
          "required": true,
          "mapTo": "Taxpayer SSN"
        },
        {
          "name": "Tax Year",
          "required": true,
          "mapTo": "Tax Year"
        },
        {
          "name": "Filing Status",
          "required": true,
          "mapTo": "Filing Status"
        },
        {
          "name": "Taxpayer Name",
          "required": true,
          "mapTo": "Taxpayer Name"
        }
      ],
      "outputs": [
        {
          "name": "Return Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "return_retrieve",
      "name": "TaxSlayer Pro Return Retrieve",
      "description": "GET /api/v1/returns/{return_id}",
      "method": "GET",
      "path": "/api/v1/returns/{{inputs.Return Id}}",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Federal Refund",
          "path": "federal_refund"
        },
        {
          "name": "State Refund",
          "path": "state_refund"
        },
        {
          "name": "Tax Year",
          "path": "tax_year"
        }
      ]
    },
    {
      "id": "return_status",
      "name": "TaxSlayer Pro Return Status",
      "description": "GET /api/v1/returns/{return_id}/status",
      "method": "GET",
      "path": "/api/v1/returns/{{inputs.Return Id}}/status",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Accepted Date",
          "path": "accepted_date"
        },
        {
          "name": "Rejection Reason",
          "path": "rejection_reason"
        }
      ]
    },
    {
      "id": "return_submit",
      "name": "TaxSlayer Pro Return E-File",
      "description": "POST /api/v1/returns/{return_id}/efile",
      "method": "POST",
      "path": "/api/v1/returns/{{inputs.Return Id}}/efile",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        },
        {
          "name": "PIN",
          "required": false,
          "mapTo": "PIN"
        }
      ],
      "outputs": [
        {
          "name": "Submission Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Confirmation",
          "path": "confirmation_number"
        }
      ]
    },
    {
      "id": "test",
      "name": "Taxslayer Pro Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}