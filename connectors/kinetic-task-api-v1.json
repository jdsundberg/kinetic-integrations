{
  "id": "kinetic-task-api-v1",
  "service": "Kinetic Task API v1",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Kinetic Task Engine API v1 \u2014 manage trees, runs, triggers, handlers, and sources. Supports both Basic auth and API access keys.",
  "docsUrl": "https://docs.kineticdata.com/reference",
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F36C24\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">K</text></svg>",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "api_username",
        "required": true,
        "description": "Kinetic Platform username."
      },
      {
        "name": "api_password",
        "required": true,
        "encrypted": true,
        "description": "Kinetic Platform password."
      },
      {
        "name": "api_location",
        "required": true,
        "description": "Kinetic server URL (e.g. https://myspace.kinops.io)."
      },
      {
        "name": "api_access_key_identifier",
        "required": false,
        "description": "Task API access key identifier (alternative to Basic auth)."
      },
      {
        "name": "api_access_key_secret",
        "required": false,
        "encrypted": true,
        "description": "Task API access key secret."
      },
      {
        "name": "enable_debug_logging",
        "required": false,
        "description": "True or False."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "run_create",
      "name": "Workflow Run Create",
      "description": "Creates a new workflow run (triggers a tree).",
      "method": "POST",
      "path": "/app/components/task/app/api/v1/run-trees/{{inputs.Tree Title}}",
      "inputs": [
        {
          "name": "Tree Title",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Source Data JSON",
          "required": false,
          "description": "Input values for the run."
        }
      ],
      "outputs": [
        {
          "name": "Run ID",
          "path": "run.id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Kinetic Task API v1 Connection Test",
      "description": "Validates authentication.",
      "method": "GET",
      "path": "/app/components/task/app/api/v1/trees?limit=1",
      "inputs": [],
      "outputs": []
    }
  ]
}