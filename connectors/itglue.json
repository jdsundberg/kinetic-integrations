{
  "id": "itglue",
  "service": "IT Glue",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "IT Glue integration with 23 pre-built routines covering organizations, configurations, contacts, passwords, documents, flexible assets, flexible asset types, locations, domains, and attachments — the dominant MSP documentation platform.",
  "auth": {
    "type": "apikey",
    "properties": [
      { "name": "api_url", "required": true, "description": "IT Glue API base URL, typically https://api.itglue.com (US) or https://api.eu.itglue.com (EU)." },
      { "name": "api_key", "required": true, "description": "IT Glue API key. Created in Account > API Keys. Sent as x-api-key header.", "encrypted": true }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#42B549\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">IT</text></svg>",
  "docsUrl": "https://api.itglue.com/developer/",
  "defaultHeaders": { "Accept": "application/vnd.api+json", "Content-Type": "application/vnd.api+json" },
  "baseUrl": "https://api.itglue.com",
  "routines": [
    { "id": "test", "name": "IT Glue Connection Test", "description": "GET /organizations (page size 1)", "method": "GET", "path": "/organizations", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "organizations_list", "name": "IT Glue Organizations List", "description": "GET /organizations", "method": "GET", "path": "/organizations", "inputs": [{"name":"Filter Name","required":false,"mapTo":"filter[name]"},{"name":"Filter Organization Type ID","required":false,"mapTo":"filter[organization_type_id]"},{"name":"Page Number","required":false,"mapTo":"page[number]"},{"name":"Page Size","required":false,"mapTo":"page[size]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Meta","path":"meta"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_retrieve", "name": "IT Glue Organization Retrieve", "description": "GET /organizations/{{inputs.Organization ID}}", "method": "GET", "path": "/organizations/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_create", "name": "IT Glue Organization Create", "description": "POST /organizations", "method": "POST", "path": "/organizations", "inputs": [{"name":"Name","required":true,"mapTo":"data.attributes.name"},{"name":"Organization Type ID","required":true,"mapTo":"data.attributes.organization-type-id"},{"name":"Organization Status ID","required":false,"mapTo":"data.attributes.organization-status-id"},{"name":"Description","required":false,"mapTo":"data.attributes.description"}], "outputs": [{"name":"Organization ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "organization_update", "name": "IT Glue Organization Update", "description": "PATCH /organizations/{{inputs.Organization ID}}", "method": "PATCH", "path": "/organizations/{{inputs.Organization ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":false,"mapTo":"data.attributes.name"},{"name":"Description","required":false,"mapTo":"data.attributes.description"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "configurations_list", "name": "IT Glue Configurations List", "description": "GET /configurations", "method": "GET", "path": "/configurations", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter Name","required":false,"mapTo":"filter[name]"},{"name":"Filter Configuration Type ID","required":false,"mapTo":"filter[configuration_type_id]"},{"name":"Filter Serial Number","required":false,"mapTo":"filter[serial_number]"},{"name":"Page Number","required":false,"mapTo":"page[number]"},{"name":"Page Size","required":false,"mapTo":"page[size]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "configuration_retrieve", "name": "IT Glue Configuration Retrieve", "description": "GET /organizations/{{inputs.Organization ID}}/relationships/configurations/{{inputs.Configuration ID}}", "method": "GET", "path": "/organizations/{{inputs.Organization ID}}/relationships/configurations/{{inputs.Configuration ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Configuration ID","required":true,"mapTo":"Configuration ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "configuration_create", "name": "IT Glue Configuration Create", "description": "POST /organizations/{{inputs.Organization ID}}/relationships/configurations", "method": "POST", "path": "/organizations/{{inputs.Organization ID}}/relationships/configurations", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":true,"mapTo":"data.attributes.name"},{"name":"Configuration Type ID","required":true,"mapTo":"data.attributes.configuration-type-id"},{"name":"Configuration Status ID","required":true,"mapTo":"data.attributes.configuration-status-id"},{"name":"Serial Number","required":false,"mapTo":"data.attributes.serial-number"},{"name":"Hostname","required":false,"mapTo":"data.attributes.hostname"},{"name":"Primary IP","required":false,"mapTo":"data.attributes.primary-ip"},{"name":"MAC Address","required":false,"mapTo":"data.attributes.mac-address"},{"name":"Manufacturer ID","required":false,"mapTo":"data.attributes.manufacturer-id"},{"name":"Model ID","required":false,"mapTo":"data.attributes.model-id"},{"name":"Operating System ID","required":false,"mapTo":"data.attributes.operating-system-id"}], "outputs": [{"name":"Configuration ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "configuration_update", "name": "IT Glue Configuration Update", "description": "PATCH /organizations/{{inputs.Organization ID}}/relationships/configurations/{{inputs.Configuration ID}}", "method": "PATCH", "path": "/organizations/{{inputs.Organization ID}}/relationships/configurations/{{inputs.Configuration ID}}", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Configuration ID","required":true,"mapTo":"Configuration ID"},{"name":"Name","required":false,"mapTo":"data.attributes.name"},{"name":"Serial Number","required":false,"mapTo":"data.attributes.serial-number"},{"name":"Hostname","required":false,"mapTo":"data.attributes.hostname"},{"name":"Configuration Status ID","required":false,"mapTo":"data.attributes.configuration-status-id"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "contacts_list", "name": "IT Glue Contacts List", "description": "GET /contacts", "method": "GET", "path": "/contacts", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter First Name","required":false,"mapTo":"filter[first_name]"},{"name":"Filter Last Name","required":false,"mapTo":"filter[last_name]"},{"name":"Filter Primary Email","required":false,"mapTo":"filter[primary_email]"},{"name":"Page Number","required":false,"mapTo":"page[number]"},{"name":"Page Size","required":false,"mapTo":"page[size]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "contact_create", "name": "IT Glue Contact Create", "description": "POST /organizations/{{inputs.Organization ID}}/relationships/contacts", "method": "POST", "path": "/organizations/{{inputs.Organization ID}}/relationships/contacts", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"First Name","required":true,"mapTo":"data.attributes.first-name"},{"name":"Last Name","required":false,"mapTo":"data.attributes.last-name"},{"name":"Title","required":false,"mapTo":"data.attributes.title"},{"name":"Contact Type ID","required":false,"mapTo":"data.attributes.contact-type-id"},{"name":"Important","required":false,"mapTo":"data.attributes.important"}], "outputs": [{"name":"Contact ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "passwords_list", "name": "IT Glue Passwords List", "description": "GET /passwords", "method": "GET", "path": "/passwords", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter Name","required":false,"mapTo":"filter[name]"},{"name":"Page Number","required":false,"mapTo":"page[number]"},{"name":"Page Size","required":false,"mapTo":"page[size]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "password_retrieve", "name": "IT Glue Password Retrieve", "description": "GET /passwords/{{inputs.Password ID}} (with show_password=true)", "method": "GET", "path": "/passwords/{{inputs.Password ID}}", "inputs": [{"name":"Password ID","required":true,"mapTo":"Password ID"},{"name":"Show Password","required":false,"mapTo":"show_password"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "password_create", "name": "IT Glue Password Create", "description": "POST /organizations/{{inputs.Organization ID}}/relationships/passwords", "method": "POST", "path": "/organizations/{{inputs.Organization ID}}/relationships/passwords", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":true,"mapTo":"data.attributes.name"},{"name":"Username","required":false,"mapTo":"data.attributes.username"},{"name":"Password","required":true,"mapTo":"data.attributes.password"},{"name":"URL","required":false,"mapTo":"data.attributes.url"},{"name":"Notes","required":false,"mapTo":"data.attributes.notes"},{"name":"Password Category ID","required":false,"mapTo":"data.attributes.password-category-id"}], "outputs": [{"name":"Password ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "documents_list", "name": "IT Glue Documents List", "description": "GET /documents", "method": "GET", "path": "/documents", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter Name","required":false,"mapTo":"filter[name]"},{"name":"Page Number","required":false,"mapTo":"page[number]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "document_create", "name": "IT Glue Document Create", "description": "POST /organizations/{{inputs.Organization ID}}/relationships/documents", "method": "POST", "path": "/organizations/{{inputs.Organization ID}}/relationships/documents", "inputs": [{"name":"Organization ID","required":true,"mapTo":"Organization ID"},{"name":"Name","required":true,"mapTo":"data.attributes.name"},{"name":"Content","required":true,"mapTo":"data.attributes.content"},{"name":"Public","required":false,"mapTo":"data.attributes.public"}], "outputs": [{"name":"Document ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "flexible_assets_list", "name": "IT Glue Flexible Assets List", "description": "GET /flexible_assets", "method": "GET", "path": "/flexible_assets", "inputs": [{"name":"Filter Flexible Asset Type ID","required":true,"mapTo":"filter[flexible_asset_type_id]"},{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter Name","required":false,"mapTo":"filter[name]"},{"name":"Page Number","required":false,"mapTo":"page[number]"},{"name":"Page Size","required":false,"mapTo":"page[size]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "flexible_asset_retrieve", "name": "IT Glue Flexible Asset Retrieve", "description": "GET /flexible_assets/{{inputs.Flexible Asset ID}}", "method": "GET", "path": "/flexible_assets/{{inputs.Flexible Asset ID}}", "inputs": [{"name":"Flexible Asset ID","required":true,"mapTo":"Flexible Asset ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "flexible_asset_create", "name": "IT Glue Flexible Asset Create", "description": "POST /flexible_assets", "method": "POST", "path": "/flexible_assets", "inputs": [{"name":"Organization ID","required":true,"mapTo":"data.attributes.organization-id"},{"name":"Flexible Asset Type ID","required":true,"mapTo":"data.attributes.flexible-asset-type-id"},{"name":"Traits","required":true,"mapTo":"data.attributes.traits"}], "outputs": [{"name":"Flexible Asset ID","path":"data.id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "flexible_asset_types_list", "name": "IT Glue Flexible Asset Types List", "description": "GET /flexible_asset_types", "method": "GET", "path": "/flexible_asset_types", "inputs": [{"name":"Filter Name","required":false,"mapTo":"filter[name]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "locations_list", "name": "IT Glue Locations List", "description": "GET /locations", "method": "GET", "path": "/locations", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Page Number","required":false,"mapTo":"page[number]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "domains_list", "name": "IT Glue Domains List", "description": "GET /domains", "method": "GET", "path": "/domains", "inputs": [{"name":"Filter Organization ID","required":false,"mapTo":"filter[organization_id]"},{"name":"Filter Name","required":false,"mapTo":"filter[name]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "user_metrics", "name": "IT Glue User Metrics (daily)", "description": "GET /user_metrics_daily", "method": "GET", "path": "/user_metrics_daily", "inputs": [{"name":"Page Number","required":false,"mapTo":"page[number]"}], "outputs": [{"name":"Data","path":"data"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
