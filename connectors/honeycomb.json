{
  "id": "honeycomb",
  "service": "Honeycomb",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Honeycomb integration with 3 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F8CE47\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">H</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "event_send",
      "name": "Honeycomb Event Send",
      "description": "POST /1/events/{dataset}",
      "method": "POST",
      "path": "/1/events/{dataset}",
      "inputs": [
        {
          "name": "Dataset",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Data JSON",
          "required": true,
          "mapTo": "Data JSON"
        }
      ],
      "outputs": []
    },
    {
      "id": "query_create",
      "name": "Honeycomb Query Create",
      "description": "POST /1/queries/{dataset}",
      "method": "POST",
      "path": "/1/queries/{dataset}",
      "inputs": [
        {
          "name": "Dataset",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Query JSON",
          "required": true,
          "mapTo": "Query JSON"
        }
      ],
      "outputs": [
        {
          "name": "Query ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Honeycomb Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}