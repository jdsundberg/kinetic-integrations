{
  "id": "cloudflare",
  "service": "Cloudflare",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Cloudflare integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "api_token",
        "required": true,
        "description": "Cloudflare API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#F38020\"><path d=\"M16.6 15.6l.5-1.8c.1-.4.1-.7-.1-1-.2-.2-.5-.4-.8-.4l-8.3-.1c-.1 0-.2 0-.2-.1s0-.2.1-.2l.1-.1h8.4c1-.1 2.1-.8 2.5-1.8l.5-1.3c0-.1 0-.1 0-.2a5.3 5.3 0 00-10.2-.5 3.3 3.3 0 00-5.2 2.2A4.2 4.2 0 00.5 14.4c0 .1 0 .2.1.2h15.6c.1 0 .2-.1.3-.2l.1-.1v-.7zm3.3-5.3a.1.1 0 00-.1 0 3.6 3.6 0 00-3.4 2.5l-.2.7c-.1.4 0 .7.1 1 .2.2.5.4.8.4l2.6.1c.1 0 .2 0 .2.1s0 .2-.1.2l-.1.1H16c-.1 0-.2.1-.3.2l-.2.7c0 .2 0 .3.2.4h7.7c.1 0 .2-.1.2-.2a5 5 0 00-3.7-5.4z\"/></svg>",
  "docsUrl": "https://developers.cloudflare.com/api/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "dns_create",
      "name": "Cloudflare DNS Create",
      "description": "POST https://api.cloudflare.com/client/v4/zones/{{inputs.Zone Id}}/dns_records",
      "method": "POST",
      "path": "/client/v4/zones/{{inputs.Zone Id}}/dns_records",
      "inputs": [
        {
          "name": "Zone Id",
          "required": true,
          "mapTo": "Zone Id"
        },
        {
          "name": "Type",
          "required": true,
          "mapTo": "Type"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Content",
          "required": true,
          "mapTo": "Content"
        },
        {
          "name": "Ttl",
          "required": false,
          "mapTo": "Ttl"
        },
        {
          "name": "Proxied",
          "required": false,
          "mapTo": "Proxied"
        }
      ],
      "outputs": [
        {
          "name": "Record ID",
          "path": "record_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Type",
          "path": "type"
        },
        {
          "name": "Content",
          "path": "content"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "dns_delete",
      "name": "Cloudflare DNS Delete",
      "description": "DELETE https://api.cloudflare.com/client/v4/zones/{{inputs.Zone Id}}/dns_records/{{inputs.Record Id}}",
      "method": "DELETE",
      "path": "/client/v4/zones/{{inputs.Zone Id}}/dns_records/{{inputs.Record Id}}",
      "inputs": [
        {
          "name": "Zone Id",
          "required": true
        },
        {
          "name": "Record Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Record ID",
          "path": "record_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "dns_update",
      "name": "Cloudflare DNS Update",
      "description": "PUT https://api.cloudflare.com/client/v4/zones/{{inputs.Zone Id}}/dns_records/{{inputs.Record Id}}",
      "method": "PUT",
      "path": "/client/v4/zones/{{inputs.Zone Id}}/dns_records/{{inputs.Record Id}}",
      "inputs": [
        {
          "name": "Zone Id",
          "required": true,
          "mapTo": "Zone Id"
        },
        {
          "name": "Record Id",
          "required": true,
          "mapTo": "Record Id"
        },
        {
          "name": "Type",
          "required": true,
          "mapTo": "Type"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Content",
          "required": true,
          "mapTo": "Content"
        },
        {
          "name": "Ttl",
          "required": false,
          "mapTo": "Ttl"
        },
        {
          "name": "Proxied",
          "required": false,
          "mapTo": "Proxied"
        }
      ],
      "outputs": [
        {
          "name": "Record ID",
          "path": "record_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Content",
          "path": "content"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Cloudflare Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "zone_list",
      "name": "Cloudflare Zone List",
      "description": "GET https://api.cloudflare.com/client/v4/zones?name={{inputs.Name}}&page={{inputs.Page}}&per_page={{inputs.Per Page}}",
      "method": "GET",
      "path": "/client/v4/zones?name={{inputs.Name}}&page={{inputs.Page}}&per_page={{inputs.Per Page}}",
      "inputs": [
        {
          "name": "Name",
          "required": false
        },
        {
          "name": "Page",
          "required": false
        },
        {
          "name": "Per Page",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Zones JSON",
          "path": "zones_json"
        },
        {
          "name": "Total Count",
          "path": "total_count"
        },
        {
          "name": "Total Pages",
          "path": "total_pages"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}