{
  "id": "logzio",
  "service": "Logzio",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Logzio integration with 2 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "region",
        "required": true,
        "description": "region."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">L</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "search",
      "name": "Logz.io Search",
      "description": "POST /v1/search",
      "method": "POST",
      "path": "/v1/search",
      "inputs": [
        {
          "name": "Query JSON",
          "required": true,
          "mapTo": "Query JSON"
        }
      ],
      "outputs": [
        {
          "name": "Hits JSON",
          "path": "hits"
        }
      ]
    },
    {
      "id": "test",
      "name": "Logzio Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.logz.io"
}
