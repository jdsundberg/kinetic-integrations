          "name": "File ID",
          "path": "file_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Path",
          "path": "path"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "file_upload",
      "name": "Dropbox File Upload",
      "description": "POST https://content.dropboxapi.com/2/files/upload",
      "method": "POST",
      "path": "https://content.dropboxapi.com/2/files/upload",
      "inputs": [
        {
          "name": "Path",
          "required": true,
          "mapTo": "Path"
