    },
    {
      "id": "share_create",
      "name": "Dropbox Shared Link Create",
      "description": "POST https://api.dropboxapi.com/2/sharing/create_shared_link_with_settings",
      "method": "POST",
      "path": "https://api.dropboxapi.com/2/sharing/create_shared_link_with_settings",
      "inputs": [
        {
          "name": "Path",
          "required": true,
          "mapTo": "Path"
        },
        {
          "name": "Requested Visibility",
          "required": false,
          "mapTo": "Requested Visibility"
        },
        {
          "name": "Link Password",
          "required": false,
          "mapTo": "Link Password"
        }
      ],
      "outputs": [
        {
          "name": "URL",
          "path": "url"
        },
        {
          "name": "Path",
          "path": "path"
        },
        {
          "name": "Visibility",
          "path": "visibility"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Dropbox Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
