{
  "id": "dropbox",
  "service": "Dropbox",
  "version": 1,
  "category": "Documents & Storage",
  "description": "Dropbox integration with 7 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#0061FF\"><path d=\"M6 1.8L0 5.6l6 3.8 6-3.8-6-3.8zM18 1.8l-6 3.8 6 3.8 6-3.8-6-3.8zM0 13.3l6 3.8 6-3.8-6-3.8-6 3.8zM18 9.5l-6 3.8 6 3.8 6-3.8-6-3.8zM6 18.4l6 3.8 6-3.8-6-3.8-6 3.8z\"/></svg>",
  "docsUrl": "https://www.dropbox.com/developers/documentation/http/overview",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "file_delete",
      "name": "Dropbox File Delete",
      "description": "POST https://api.dropboxapi.com/2/files/delete_v2",
      "method": "POST",
      "path": "https://api.dropboxapi.com/2/files/delete_v2",
      "inputs": [
        {
          "name": "Path",
          "required": true,
          "mapTo": "Path"
        }
      ],
      "outputs": [
        {
          "name": "File ID",
          "path": "file_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Path",
          "path": "path"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "file_download",
      "name": "Dropbox File Download",
      "description": "POST https://content.dropboxapi.com/2/files/download",
      "method": "POST",
      "path": "https://content.dropboxapi.com/2/files/download",
      "inputs": [
        {
          "name": "Path",
          "required": true,
          "mapTo": "Path"
        }
      ],
      "outputs": [
        {
          "name": "File Content",
          "path": "file_content"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Size",
          "path": "size"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "file_move",
      "name": "Dropbox File Move",
      "description": "POST https://api.dropboxapi.com/2/files/move_v2",
      "method": "POST",
      "path": "https://api.dropboxapi.com/2/files/move_v2",
      "inputs": [
        {
          "name": "From Path",
          "required": true,
          "mapTo": "From Path"
        },
        {
          "name": "To Path",
          "required": true,
          "mapTo": "To Path"
        },
        {
          "name": "Autorename",
          "required": false,
          "mapTo": "Autorename"
        },
        {
          "name": "Allow Ownership Transfer",
          "required": false,
          "mapTo": "Allow Ownership Transfer"
        }
