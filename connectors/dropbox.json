      "description": "POST https://api.dropboxapi.com/2/files/create_folder_v2",
      "method": "POST",
      "path": "https://api.dropboxapi.com/2/files/create_folder_v2",
      "inputs": [
        {
          "name": "Path",
          "required": true,
          "mapTo": "Path"
        },
        {
          "name": "Autorename",
          "required": false,
          "mapTo": "Autorename"
        }
      ],
      "outputs": [
        {
          "name": "Folder ID",
          "path": "folder_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Path",
          "path": "path"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
