          "path": "file_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Path",
          "path": "path"
        },
        {
          "name": "Size",
          "path": "size"
        },
        {
          "name": "Content Hash",
          "path": "content_hash"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
