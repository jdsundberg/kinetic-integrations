{
  "id": "xmatters",
  "service": "Xmatters",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Xmatters integration with 5 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "xMatters instance URL (e.g. https://myco.xmatters.com)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">X</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "event_trigger",
      "name": "xMatters Event Trigger",
      "description": "POST /api/xm/1/events",
      "method": "POST",
      "path": "/api/xm/1/events",
      "inputs": [
        {
          "name": "Form Id",
          "required": true,
          "mapTo": "Form Id"
        },
        {
          "name": "Subject",
          "required": true,
          "mapTo": "Subject"
        },
        {
          "name": "Recipients Json",
          "required": true,
          "mapTo": "Recipients Json"
        },
        {
          "name": "Priority",
          "required": false,
          "mapTo": "Priority"
        },
        {
          "name": "Properties Json",
          "required": false,
          "mapTo": "Properties Json"
        }
      ],
      "outputs": [
        {
          "name": "Event ID",
          "path": "event_id"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "group_create",
      "name": "xMatters Group Create",
      "description": "POST /api/xm/1/groups",
      "method": "POST",
      "path": "/api/xm/1/groups",
      "inputs": [
        {
          "name": "Target Name",
          "required": true,
          "mapTo": "Target Name"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Status",
          "required": false,
          "mapTo": "Status"
        },
        {
          "name": "Observed By All",
          "required": false,
          "mapTo": "Observed By All"
        }
      ],
      "outputs": [
        {
          "name": "Group ID",
          "path": "group_id"
        },
        {
          "name": "Target Name",
          "path": "target_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "person_create",
      "name": "xMatters Person Create",
      "description": "POST /api/xm/1/people",
      "method": "POST",
      "path": "/api/xm/1/people",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Target Name",
          "required": true,
          "mapTo": "Target Name"
        },
        {
          "name": "Roles Json",
          "required": false,
          "mapTo": "Roles Json"
        },
        {
          "name": "Site Id",
          "required": false,
          "mapTo": "Site Id"
        }
      ],
      "outputs": [
        {
          "name": "Person ID",
          "path": "person_id"
        },
        {
          "name": "Target Name",
          "path": "target_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "shift_create",
      "name": "xMatters Shift Create",
      "description": "POST /api/xm/1/groups/{{inputs.Group Id}}/shifts",
      "method": "POST",
      "path": "/api/xm/1/groups/{{inputs.Group Id}}/shifts",
      "inputs": [
        {
          "name": "Group Id",
          "required": true,
          "mapTo": "Group Id"
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Start Time",
          "required": false,
          "mapTo": "Start Time"
        },
        {
          "name": "End Time",
          "required": false,
          "mapTo": "End Time"
        },
        {
          "name": "Timezone",
          "required": false,
          "mapTo": "Timezone"
        }
      ],
      "outputs": [
        {
          "name": "Shift ID",
          "path": "shift_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Xmatters Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}