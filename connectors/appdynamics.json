{
  "id": "appdynamics",
  "service": "Appdynamics",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Appdynamics integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      },
      {
        "name": "account_id",
        "required": true,
        "description": "account id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "application_list",
      "name": "AppDynamics Application List",
      "description": "GET /controller/rest/applications?output=JSON",
      "method": "GET",
      "path": "/controller/rest/applications?output=JSON",
      "inputs": [],
      "outputs": [
        {
          "name": "Applications JSON",
          "path": "applications"
        }
      ]
    },
    {
      "id": "health_violations",
      "name": "AppDynamics Health Violations",
      "description": "GET /controller/rest/applications/{applicationId}/problems/healthrule-violations?output=JSON",
      "method": "GET",
      "path": "/controller/rest/applications/{applicationId}/problems/healthrule-violations?output=JSON",
      "inputs": [
        {
          "name": "Application ID",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Violations JSON",
          "path": "violations"
        }
      ]
    },
    {
      "id": "test",
      "name": "Appdynamics Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}