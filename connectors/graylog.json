{
  "id": "graylog",
  "service": "Graylog",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Graylog integration with 2 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#FF3633\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">G</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "search",
      "name": "Graylog Search",
      "description": "GET /api/search/universal/relative?query={query}&range={range}",
      "method": "GET",
      "path": "/api/search/universal/relative?query={query}&range={range}",
      "inputs": [
        {
          "name": "Query",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Range Seconds",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Messages JSON",
          "path": "messages"
        },
        {
          "name": "Total Results",
          "path": "total_results"
        }
      ]
    },
    {
      "id": "test",
      "name": "Graylog Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}