      "description": "DELETE https://admin.googleapis.com/admin/directory/v1/groups/{{inputs.Group Key}}/members/{{inputs.Member Key}}",
      "method": "DELETE",
      "path": "/admin/directory/v1/groups/{{inputs.Group Key}}/members/{{inputs.Member Key}}",
      "inputs": [
        {
          "name": "Group Key",
          "required": true
        },
        {
          "name": "Member Key",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Success",
          "path": "success"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
