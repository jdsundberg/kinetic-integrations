{
  "id": "google",
  "service": "Google",
  "version": 1,
  "category": "Other",
  "description": "Google integration with 11 pre-built routines.",
  "auth": {
    "type": "jwt",
    "properties": [
      {
        "name": "service_account_email",
        "required": true,
        "description": "Google service account email."
      },
      {
        "name": "private_key",
        "required": true,
        "description": "PEM private key from service account JSON.",
        "encrypted": true
      },
      {
        "name": "jwt_subject",
        "required": false,
        "description": "Email to impersonate (domain-wide delegation)."
      },
      {
        "name": "jwt_scope",
        "required": true,
        "description": "OAuth2 scope for the JWT assertion."
      },
      {
        "name": "admin_email",
        "required": true,
        "description": "Workspace admin email for domain-wide delegation."
      },
      {
        "name": "domain",
        "required": true,
        "description": "Google Workspace domain."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00695C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">G</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "drive_create_doc",
      "name": "Google Drive Create Document",
      "description": "POST https://www.googleapis.com/drive/v3/files",
      "method": "POST",
      "path": "/drive/v3/files",
      "inputs": [
        {
          "name": "Document Name",
          "required": true,
          "mapTo": "Document Name"
        },
        {
          "name": "Parent Folder Id",
          "required": false,
          "mapTo": "Parent Folder Id"
        }
      ],
      "outputs": [
        {
          "name": "Document ID",
          "path": "document_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Web Link",
          "path": "web_link"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "drive_create_folder",
      "name": "Google Drive Create Folder",
      "description": "POST https://www.googleapis.com/drive/v3/files",
