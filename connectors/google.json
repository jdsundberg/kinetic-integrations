          "name": "Folder ID",
          "path": "folder_id"
        },
        {
          "name": "Folder Name",
          "path": "folder_name"
        },
        {
          "name": "Web Link",
          "path": "web_link"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "drive_share",
      "name": "Google Drive Share",
      "description": "POST https://www.googleapis.com/drive/v3/files/{{inputs.File Id}}/permissions",
      "method": "POST",
      "path": "/drive/v3/files/{{inputs.File Id}}/permissions",
      "inputs": [
        {
          "name": "File Id",
          "required": true,
          "mapTo": "File Id"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "Email"
        },
        {
          "name": "Role",
          "required": true,
          "mapTo": "Role"
        },
        {
          "name": "Type",
          "required": false,
          "mapTo": "Type"
        },
        {
          "name": "Send Notification",
          "required": false,
          "mapTo": "Send Notification"
        }
      ],
      "outputs": [
        {
          "name": "Permission ID",
          "path": "permission_id"
        },
        {
          "name": "Role",
          "path": "role"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
