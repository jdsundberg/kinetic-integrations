{
  "id": "sql-sqlserver",
  "service": "Sql Sqlserver",
  "version": 1,
  "category": "Other",
  "description": "Sql Sqlserver integration with 2 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "jdbc_url",
        "required": true,
        "description": "Microsoft SQL Server JDBC URL (e.g. jdbc:sqlserver://host:1433;databaseName=db)."
      },
      {
        "name": "driver_class",
        "required": true,
        "description": "JDBC driver class. Default for Microsoft SQL Server: com.microsoft.sqlserver.jdbc.SQLServerDriver"
      },
      {
        "name": "username",
        "required": false,
        "description": "Database username."
      },
      {
        "name": "password",
        "required": false,
        "description": "Database password.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0097A7\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">S</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "query",
      "name": "SQL Server Query",
      "description": "POST /query",
      "method": "POST",
      "path": "/query",
      "inputs": [
        {
          "name": "SQL",
          "required": true,
          "mapTo": "SQL"
        },
        {
          "name": "Parameters JSON",
          "required": false,
          "mapTo": "Parameters JSON"
        }
      ],
      "outputs": [
        {
          "name": "Rows JSON",
          "path": "rows"
        },
        {
          "name": "Row Count",
          "path": "rowCount"
        }
      ]
    },
    {
      "id": "test",
      "name": "Sql Sqlserver Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "jdbc:sqlserver://HOST:1433;databaseName=DB"
}
