      { "name": "public_key", "required": true, "description": "API member public key." },
      { "name": "private_key", "required": true, "description": "API member private key.", "encrypted": true },
      { "name": "client_id", "required": true, "description": "Developer clientId GUID registered via https://developer.connectwise.com/ClientID.", "encrypted": true }
    ]
  },
