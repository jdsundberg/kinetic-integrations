{
  "id": "signalfx",
  "service": "SignalFx",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "SignalFx integration with 4 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "api_key_header",
        "required": false,
        "description": "Header name for the API key. Default: X-SF-Token"
      },
      {
        "name": "realm",
        "required": true,
        "description": "SignalFx realm (e.g. us0, us1, eu0)."
      },
      {
        "name": "access_token",
        "required": true,
        "description": "SignalFx access token.",
        "encrypted": true
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "dashboard_create",
      "name": "SignalFx Dashboard Create",
      "description": "POST https://api.<%= @info['realm'] %>.signalfx.com/v2/dashboard",
      "method": "POST",
      "path": "https://api.<%= @info['realm'] %>.signalfx.com/v2/dashboard",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Dashboard Group Id",
          "required": true,
          "mapTo": "Dashboard Group Id"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Charts Json",
          "required": false,
          "mapTo": "Charts Json"
        }
      ],
      "outputs": [
        {
          "name": "Dashboard ID",
          "path": "dashboard_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "detector_create",
      "name": "SignalFx Detector Create",
      "description": "POST https://api.<%= @info['realm'] %>.signalfx.com/v2/detector",
      "method": "POST",
      "path": "https://api.<%= @info['realm'] %>.signalfx.com/v2/detector",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Program Text",
          "required": true,
          "mapTo": "Program Text"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Max Delay",
          "required": false,
          "mapTo": "Max Delay"
        }
      ],
      "outputs": [
        {
          "name": "Detector ID",
          "path": "detector_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "event_send",
      "name": "SignalFx Event Send",
      "description": "POST https://api.<%= @info['realm'] %>.signalfx.com/v2/event",
      "method": "POST",
      "path": "https://api.<%= @info['realm'] %>.signalfx.com/v2/event",
      "inputs": [
        {
          "name": "Event Type",
          "required": true,
          "mapTo": "Event Type"
        },
        {
          "name": "Category",
          "required": false,
          "mapTo": "Category"
        },
        {
          "name": "Dimensions Json",
          "required": false,
          "mapTo": "Dimensions Json"
        },
        {
          "name": "Properties Json",
          "required": false,
          "mapTo": "Properties Json"
        }
      ],
      "outputs": [
        {
          "name": "Event ID",
          "path": "event_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "metric_send",
      "name": "SignalFx Metric Send",
      "description": "POST https://api.<%= @info['realm'] %>.signalfx.com/v2/datapoint",
      "method": "POST",
      "path": "https://api.<%= @info['realm'] %>.signalfx.com/v2/datapoint",
      "inputs": [
        {
          "name": "Metric",
          "required": true,
          "mapTo": "Metric"
        },
        {
          "name": "Value",
          "required": true,
          "mapTo": "Value"
        },
        {
          "name": "Metric Type",
          "required": false,
          "mapTo": "Metric Type"
        },
        {
          "name": "Dimensions Json",
          "required": false,
          "mapTo": "Dimensions Json"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    }
  ]
}