{
  "id": "copper",
  "service": "Copper",
  "version": 1,
  "category": "CRM & Sales",
  "description": "Copper integration with 3 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "email",
        "required": true,
        "description": "email."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00695C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">C</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "lead_create",
      "name": "Copper Lead Create",
      "description": "POST /v1/leads",
      "method": "POST",
      "path": "/v1/leads",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Lead ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "opportunity_create",
      "name": "Copper Opportunity Create",
      "description": "POST /v1/opportunities",
      "method": "POST",
      "path": "/v1/opportunities",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Monetary Value",
          "required": false,
          "mapTo": "Monetary Value"
        }
      ],
      "outputs": [
        {
          "name": "Opportunity ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Copper Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}