{
  "id": "notion",
  "service": "Notion",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Notion integration with 7 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "api_key",
        "required": true,
        "description": "Notion integration API key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#000000\"><path d=\"M4.5 4.2c.7.6 1 .6 2.4.5l13.2-.8c.3 0 0-.3 0-.3L18.3 2.1c-.5-.4-.8-.2-1.3-.1L4 2.9c-.5 0-.6.3-.4.5l.9.8zM5.3 7.7v13.9c0 .7.4 1 1.2 1l14.5-.8c.8 0 .9-.6.9-1.2V6.9c0-.6-.2-.9-.7-.9l-15.2.8c-.6 0-.7.3-.7.8zm14.3.6c.1.4 0 .8-.4.9l-.7.1v10.3c-.6.3-1.2.5-1.6.5-.7 0-.9-.2-1.5-.9l-4.6-7.2v7l1.4.3s0 .8-1.2.8l-3.2.2c-.1-.2 0-.7.3-.7l.8-.2V10l-1.2-.1c-.1-.4.1-1 .8-1.1l3.5-.2 4.8 7.3V9.5l-1.2-.1c-.1-.5.3-.9.7-.9l3.2-.2z\"/></svg>",
  "docsUrl": "https://developers.notion.com/reference/intro",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "block_append",
      "name": "Notion Block Append",
      "description": "PATCH https://api.notion.com/v1/blocks/<%= @inputs['Block Id'] %>/children",
      "method": "PATCH",
      "path": "https://api.notion.com/v1/blocks/<%= @inputs['Block Id'] %>/children",
      "inputs": [
        {
          "name": "Block Id",
          "required": true,
          "mapTo": "Block Id"
        },
        {
          "name": "Children Json",
          "required": true,
          "mapTo": "Children Json"
        }
      ],
      "outputs": [
        {
          "name": "Results JSON",
          "path": "results_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "database_create",
      "name": "Notion Database Create",
      "description": "POST https://api.notion.com/v1/databases",
      "method": "POST",
      "path": "https://api.notion.com/v1/databases",
      "inputs": [
        {
          "name": "Parent Page Id",
          "required": true,
          "mapTo": "Parent Page Id"
        },
        {
          "name": "Title",
          "required": true,
          "mapTo": "Title"
        },
        {
          "name": "Properties Json",
          "required": false,
          "mapTo": "Properties Json"
        }
      ],
      "outputs": [
        {
          "name": "Database ID",
          "path": "database_id"
        },
        {
          "name": "URL",
          "path": "url"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "database_query",
      "name": "Notion Database Query",
      "description": "POST https://api.notion.com/v1/databases/<%= @inputs['Database Id'] %>/query",
      "method": "POST",
      "path": "https://api.notion.com/v1/databases/<%= @inputs['Database Id'] %>/query",
      "inputs": [
        {
          "name": "Database Id",
          "required": true,
          "mapTo": "Database Id"
        },
        {
          "name": "Filter Json",
          "required": false,
          "mapTo": "Filter Json"
        },
        {
          "name": "Sorts Json",
          "required": false,
          "mapTo": "Sorts Json"
        },
        {
          "name": "Page Size",
          "required": false,
          "mapTo": "Page Size"
        }
      ],
      "outputs": [
        {
          "name": "Results JSON",
          "path": "results_json"
        },
        {
          "name": "Has More",
          "path": "has_more"
        },
        {
          "name": "Next Cursor",
          "path": "next_cursor"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "page_create",
      "name": "Notion Page Create",
      "description": "POST https://api.notion.com/v1/pages",
      "method": "POST",
      "path": "https://api.notion.com/v1/pages",
      "inputs": [
        {
          "name": "Parent Page Id",
          "required": false,
          "mapTo": "Parent Page Id"
        },
        {
          "name": "Parent Database Id",
          "required": false,
          "mapTo": "Parent Database Id"
        },
        {
          "name": "Title",
          "required": true,
          "mapTo": "Title"
        },
        {
          "name": "Content",
          "required": false,
          "mapTo": "Content"
        }
      ],
      "outputs": [
        {
          "name": "Page ID",
          "path": "page_id"
        },
        {
          "name": "URL",
          "path": "url"
        },
        {
          "name": "Created",
          "path": "created"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "page_update",
      "name": "Notion Page Update",
      "description": "PATCH https://api.notion.com/v1/pages/<%= @inputs['Page Id'] %>",
      "method": "PATCH",
      "path": "https://api.notion.com/v1/pages/<%= @inputs['Page Id'] %>",
      "inputs": [
        {
          "name": "Page Id",
          "required": true,
          "mapTo": "Page Id"
        },
        {
          "name": "Properties Json",
          "required": true,
          "mapTo": "Properties Json"
        },
        {
          "name": "Archived",
          "required": false,
          "mapTo": "Archived"
        }
      ],
      "outputs": [
        {
          "name": "Page ID",
          "path": "page_id"
        },
        {
          "name": "URL",
          "path": "url"
        },
        {
          "name": "Last Edited",
          "path": "last_edited"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "search",
      "name": "Notion Search",
      "description": "POST https://api.notion.com/v1/search",
      "method": "POST",
      "path": "https://api.notion.com/v1/search",
      "inputs": [
        {
          "name": "Query",
          "required": true,
          "mapTo": "Query"
        },
        {
          "name": "Filter Type",
          "required": false,
          "mapTo": "Filter Type"
        },
        {
          "name": "Page Size",
          "required": false,
          "mapTo": "Page Size"
        }
      ],
      "outputs": [
        {
          "name": "Results JSON",
          "path": "results_json"
        },
        {
          "name": "Has More",
          "path": "has_more"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Notion Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}