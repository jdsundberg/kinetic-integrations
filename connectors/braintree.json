{
  "id": "braintree",
  "service": "Braintree",
  "version": 1,
  "category": "Finance & Payments",
  "description": "Braintree integration with 4 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "merchant_id",
        "required": true,
        "description": "merchant id."
      },
      {
        "name": "environment",
        "required": true,
        "description": "environment."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#003E54\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">B</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "customer_create",
      "name": "Braintree Customer Create",
      "description": "POST /merchants/{merchant_id}/customers",
      "method": "POST",
      "path": "/merchants/{{inputs.Merchant Id}}/customers",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Customer ID",
          "path": "customer.id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Braintree Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "transaction_refund",
      "name": "Braintree Transaction Refund",
      "description": "POST /merchants/{merchant_id}/transactions/{id}/refund",
      "method": "POST",
      "path": "/merchants/{{inputs.Merchant Id}}/transactions/{{inputs.Id}}/refund",
      "inputs": [
        {
          "name": "Transaction ID",
          "required": true,
          "mapTo": "Transaction ID"
        },
        {
          "name": "Amount",
          "required": false,
          "mapTo": "Amount"
        }
      ],
      "outputs": [
        {
          "name": "Refund ID",
          "path": "transaction.id"
        },
        {
          "name": "Status",
          "path": "transaction.status"
        }
      ]
    },
    {
      "id": "transaction_sale",
      "name": "Braintree Transaction Sale",
      "description": "POST /merchants/{merchant_id}/transactions",
      "method": "POST",
      "path": "/merchants/{{inputs.Merchant Id}}/transactions",
      "inputs": [
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Payment Method Nonce",
          "required": true,
          "mapTo": "Payment Method Nonce"
        },
        {
          "name": "Order ID",
          "required": false,
          "mapTo": "Order ID"
        }
      ],
      "outputs": [
        {
          "name": "Transaction ID",
          "path": "transaction.id"
        },
        {
          "name": "Status",
          "path": "transaction.status"
        }
      ]
    }
  ],
  "baseUrl": "https://payments.braintreegateway.com"
}
