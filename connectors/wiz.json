{
  "id": "wiz",
  "service": "Wiz",
  "version": 1,
  "category": "Security & Identity",
  "description": "Wiz integration with 2 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2A2FBC\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">W</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "issue_list",
      "name": "Wiz Issue List",
      "description": "POST /graphql",
      "method": "POST",
      "path": "/graphql",
      "inputs": [
        {
          "name": "Query",
          "required": true,
          "mapTo": "Query"
        }
      ],
      "outputs": [
        {
          "name": "Issues JSON",
          "path": "data.issues.nodes"
        }
      ]
    },
    {
      "id": "test",
      "name": "Wiz Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.wiz.io"
}
