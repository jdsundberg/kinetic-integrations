{
  "id": "tenable",
  "service": "Tenable",
  "version": 1,
  "category": "Security & Identity",
  "description": "Tenable integration with 3 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0085CA\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "asset_list",
      "name": "Tenable Asset List",
      "description": "GET /assets",
      "method": "GET",
      "path": "/assets",
      "inputs": [],
      "outputs": [
        {
          "name": "Assets JSON",
          "path": "assets"
        }
      ]
    },
    {
      "id": "test",
      "name": "Tenable Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "vulnerability_list",
      "name": "Tenable Vulnerability List",
      "description": "GET /workbenches/vulnerabilities",
      "method": "GET",
      "path": "/workbenches/vulnerabilities",
      "inputs": [
        {
          "name": "Date Range",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Vulnerabilities JSON",
          "path": "vulnerabilities"
        }
      ]
    }
  ],
  "baseUrl": "https://cloud.tenable.com"
}
