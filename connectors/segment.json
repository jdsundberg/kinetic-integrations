{
  "id": "segment",
  "service": "Segment",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Segment integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#52BD95\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">S</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "identify",
      "name": "Segment Identify",
      "description": "POST /v1/identify",
      "method": "POST",
      "path": "/v1/identify",
      "inputs": [
        {
          "name": "User ID",
          "required": true,
          "mapTo": "User ID"
        },
        {
          "name": "Traits JSON",
          "required": true,
          "mapTo": "Traits JSON"
        }
      ],
      "outputs": [
        {
          "name": "Success",
          "path": "success"
        }
      ]
    },
    {
      "id": "test",
      "name": "Segment Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "track",
      "name": "Segment Track",
      "description": "POST /v1/track",
      "method": "POST",
      "path": "/v1/track",
      "inputs": [
        {
          "name": "User ID",
          "required": true,
          "mapTo": "User ID"
        },
        {
          "name": "Event",
          "required": true,
          "mapTo": "Event"
        },
        {
          "name": "Properties JSON",
          "required": false,
          "mapTo": "Properties JSON"
        }
      ],
      "outputs": [
        {
          "name": "Success",
          "path": "success"
        }
      ]
    }
  ],
  "baseUrl": "https://api.segment.io"
}
