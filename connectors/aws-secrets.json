{
  "id": "aws-secrets",
  "service": "Aws Secrets",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Aws Secrets integration with 3 pre-built routines.",
  "auth": {
    "type": "aws",
    "properties": [
      {
        "name": "aws_access_key_id",
        "required": true,
        "description": "AWS access key ID."
      },
      {
        "name": "aws_secret_access_key",
        "required": true,
        "description": "AWS secret access key.",
        "encrypted": true
      },
      {
        "name": "aws_region",
        "required": true,
        "description": "AWS region."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#1565C0\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "secret_create",
      "name": "AWS Secrets Manager Create Secret",
      "description": "POST /",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Secret String",
          "required": true,
          "mapTo": "Secret String"
        }
      ],
      "outputs": [
        {
          "name": "ARN",
          "path": "ARN"
        },
        {
          "name": "Name",
          "path": "Name"
        }
      ]
    },
    {
      "id": "secret_get",
      "name": "AWS Secrets Manager Get Secret",
      "description": "POST /",
      "method": "POST",
      "path": "/",
      "inputs": [
        {
          "name": "Secret ID",
          "required": true,
          "mapTo": "Secret ID"
        }
      ],
      "outputs": [
        {
          "name": "Secret String",
          "path": "SecretString"
        },
        {
          "name": "Name",
          "path": "Name"
        }
      ]
    },
    {
      "id": "test",
      "name": "Aws Secrets Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://secretsmanager.REGION.amazonaws.com"
}
