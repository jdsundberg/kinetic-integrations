{
  "id": "freshbooks",
  "service": "Freshbooks",
  "version": 1,
  "category": "Finance & Payments",
  "description": "Freshbooks integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "account_id",
        "required": true,
        "description": "account id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">F</text></svg>",
  "docsUrl": "https://www.freshbooks.com/api/start",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "client_create",
      "name": "FreshBooks Client Create",
      "description": "POST /accounting/account/{account_id}/users/clients",
      "method": "POST",
      "path": "/accounting/account/{account_id}/users/clients",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Client ID",
          "path": "response.result.client.id"
        }
      ]
    },
    {
      "id": "expense_create",
      "name": "FreshBooks Expense Create",
      "description": "POST /accounting/account/{account_id}/expenses/expenses",
      "method": "POST",
      "path": "/accounting/account/{account_id}/expenses/expenses",
      "inputs": [
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Category ID",
          "required": true,
          "mapTo": "Category ID"
        },
        {
          "name": "Date",
          "required": true,
          "mapTo": "Date"
        }
      ],
      "outputs": [
        {
          "name": "Expense ID",
          "path": "response.result.expense.id"
        }
      ]
    },
    {
      "id": "invoice_create",
      "name": "FreshBooks Invoice Create",
      "description": "POST /accounting/account/{account_id}/invoices/invoices",
      "method": "POST",
      "path": "/accounting/account/{account_id}/invoices/invoices",
      "inputs": [
        {
          "name": "Customer ID",
          "required": true,
          "mapTo": "Customer ID"
        },
        {
          "name": "Lines JSON",
          "required": true,
          "mapTo": "Lines JSON"
        }
      ],
      "outputs": [
        {
          "name": "Invoice ID",
          "path": "response.result.invoice.id"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "FreshBooks Payment Create",
      "description": "POST /accounting/account/{account_id}/payments/payments",
      "method": "POST",
      "path": "/accounting/account/{account_id}/payments/payments",
      "inputs": [
        {
          "name": "Invoice ID",
          "required": true,
          "mapTo": "Invoice ID"
        },
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        }
      ],
      "outputs": [
        {
          "name": "Payment ID",
          "path": "response.result.payment.id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Freshbooks Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}