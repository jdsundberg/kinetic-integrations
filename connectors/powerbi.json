{
  "id": "powerbi",
  "service": "Powerbi",
  "version": 1,
  "category": "Other",
  "description": "Powerbi integration with 5 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">P</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "dashboard_list",
      "name": "Power BI Dashboard List",
      "description": "GET https://api.powerbi.com/v1.0/myorg/groups/{{inputs.Group Id}}/dashboards",
      "method": "GET",
      "path": "/v1.0/myorg/groups/{{inputs.Group Id}}/dashboards",
      "inputs": [
        {
          "name": "Group Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Dashboards JSON",
          "path": "dashboards_json"
        },
        {
          "name": "Dashboard Count",
          "path": "dashboard_count"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "dataset_refresh",
      "name": "Power BI Dataset Refresh",
      "description": "POST https://api.powerbi.com/v1.0/myorg/groups/{{inputs.Group Id}}/datasets/{{inputs.Dataset Id}}/refreshes",
      "method": "POST",
      "path": "/v1.0/myorg/groups/{{inputs.Group Id}}/datasets/{{inputs.Dataset Id}}/refreshes",
      "inputs": [
        {
          "name": "Group Id",
          "required": true,
          "mapTo": "Group Id"
        },
        {
          "name": "Dataset Id",
          "required": true,
          "mapTo": "Dataset Id"
        },
        {
          "name": "Notify Option",
          "required": false,
          "mapTo": "Notify Option"
        }
      ],
      "outputs": [
        {
          "name": "Request ID",
          "path": "request_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "group_list",
      "name": "Power BI Group List",
      "description": "GET https://api.powerbi.com/v1.0/myorg/groups",
      "method": "GET",
      "path": "/v1.0/myorg/groups",
      "inputs": [],
      "outputs": [
        {
          "name": "Groups JSON",
          "path": "groups_json"
        },
        {
          "name": "Group Count",
          "path": "group_count"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "report_export",
      "name": "Power BI Report Export",
      "description": "POST https://api.powerbi.com/v1.0/myorg/groups/{{inputs.Group Id}}/reports/{{inputs.Report Id}}/ExportTo",
      "method": "POST",
      "path": "/v1.0/myorg/groups/{{inputs.Group Id}}/reports/{{inputs.Report Id}}/ExportTo",
      "inputs": [
        {
          "name": "Group Id",
          "required": true,
          "mapTo": "Group Id"
        },
        {
          "name": "Report Id",
          "required": true,
          "mapTo": "Report Id"
        },
        {
          "name": "Format",
          "required": true,
          "mapTo": "Format"
        }
      ],
      "outputs": [
        {
          "name": "Export ID",
          "path": "export_id"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Percent Complete",
          "path": "percent_complete"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Powerbi Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.powerbi.com"
}
