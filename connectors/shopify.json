{
  "id": "shopify",
  "service": "Shopify",
  "version": 1,
  "category": "Commerce & Content",
  "description": "Shopify integration with 9 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "api_key_header",
        "required": false,
        "description": "Header name for the API key. Default: X-Shopify-Access-Token"
      },
      {
        "name": "store_url",
        "required": true,
        "description": "Shopify store URL (e.g. https://mystore.myshopify.com)."
      },
      {
        "name": "access_token",
        "required": true,
        "description": "Shopify Admin API access token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#7AB55C\"><path d=\"M15.3 24l7.2-1.6s-2.6-17.6-2.6-17.7c0-.1-.1-.2-.2-.2s-1.9-.1-1.9-.1-1.3-1.3-1.4-1.4l-.9 21.1zM11.7 11.3s-.8-.4-1.8-.4c-1.4 0-1.5.9-1.5 1.1 0 1.2 3.2 1.7 3.2 4.6 0 2.3-1.4 3.8-3.4 3.8-2.3 0-3.5-1.5-3.5-1.5l.6-2.1s1.2 1.1 2.3 1.1c.7 0 1-.5 1-.9 0-1.6-2.6-1.7-2.6-4.3 0-2.2 1.6-4.4 4.8-4.4 1.2 0 1.9.4 1.9.4l-.9 2.7z\"/></svg>",
  "docsUrl": "https://shopify.dev/docs/api",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "customer_create",
      "name": "Shopify Customer Create",
      "description": "POST <%= @info['store_url'] %>/admin/api/2024-01/customers.json",
      "method": "POST",
      "path": "/admin/api/2024-01/customers.json",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        },
        {
          "name": "Tags",
          "required": false,
          "mapTo": "Tags"
        },
        {
          "name": "Note",
          "required": false,
          "mapTo": "Note"
        }
      ],
      "outputs": [
        {
          "name": "Customer ID",
          "path": "customer_id"
        },
        {
          "name": "Email",
          "path": "email"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "customer_retrieve",
      "name": "Shopify Customer Retrieve",
      "description": "GET <%= @info['store_url'] %>/admin/api/2024-01/customers/<%= @inputs['Customer Id'] %>.json",
      "method": "GET",
      "path": "/admin/api/2024-01/customers/<%= @inputs['Customer Id'] %>.json",
      "inputs": [
        {
          "name": "Customer Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Customer ID",
          "path": "customer_id"
        },
        {
          "name": "Email",
          "path": "email"
        },
        {
          "name": "First Name",
          "path": "first_name"
        },
        {
          "name": "Last Name",
          "path": "last_name"
        },
        {
          "name": "Orders Count",
          "path": "orders_count"
        },
        {
          "name": "Customer JSON",
          "path": "customer_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "fulfillment_create",
      "name": "Shopify Fulfillment Create",
      "description": "POST <%= @info['store_url'] %>/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>/fulfillments.json",
      "method": "POST",
      "path": "/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>/fulfillments.json",
      "inputs": [
        {
          "name": "Order Id",
          "required": true,
          "mapTo": "Order Id"
        },
        {
          "name": "Tracking Number",
          "required": false,
          "mapTo": "Tracking Number"
        },
        {
          "name": "Tracking Company",
          "required": false,
          "mapTo": "Tracking Company"
        },
        {
          "name": "Notify Customer",
          "required": false,
          "mapTo": "Notify Customer"
        }
      ],
      "outputs": [
        {
          "name": "Fulfillment ID",
          "path": "fulfillment_id"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "inventory_update",
      "name": "Shopify Inventory Update",
      "description": "POST <%= @info['store_url'] %>/admin/api/2024-01/inventory_levels/set.json",
      "method": "POST",
      "path": "/admin/api/2024-01/inventory_levels/set.json",
      "inputs": [
        {
          "name": "Inventory Item Id",
          "required": true,
          "mapTo": "Inventory Item Id"
        },
        {
          "name": "Location Id",
          "required": true,
          "mapTo": "Location Id"
        },
        {
          "name": "Available",
          "required": true,
          "mapTo": "Available"
        }
      ],
      "outputs": [
        {
          "name": "Inventory Item ID",
          "path": "inventory_item_id"
        },
        {
          "name": "Available",
          "path": "available"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "order_retrieve",
      "name": "Shopify Order Retrieve",
      "description": "GET <%= @info['store_url'] %>/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>.json",
      "method": "GET",
      "path": "/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>.json",
      "inputs": [
        {
          "name": "Order Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Order Number",
          "path": "order_number"
        },
        {
          "name": "Total Price",
          "path": "total_price"
        },
        {
          "name": "Financial Status",
          "path": "financial_status"
        },
        {
          "name": "Fulfillment Status",
          "path": "fulfillment_status"
        },
        {
          "name": "Order JSON",
          "path": "order_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "order_update",
      "name": "Shopify Order Update",
      "description": "PUT <%= @info['store_url'] %>/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>.json",
      "method": "PUT",
      "path": "/admin/api/2024-01/orders/<%= @inputs['Order Id'] %>.json",
      "inputs": [
        {
          "name": "Order Id",
          "required": true,
          "mapTo": "Order Id"
        },
        {
          "name": "Note",
          "required": false,
          "mapTo": "Note"
        },
        {
          "name": "Tags",
          "required": false,
          "mapTo": "Tags"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Order ID",
          "path": "order_id"
        },
        {
          "name": "Updated At",
          "path": "updated_at"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "product_create",
      "name": "Shopify Product Create",
      "description": "POST <%= @info['store_url'] %>/admin/api/2024-01/products.json",
      "method": "POST",
      "path": "/admin/api/2024-01/products.json",
      "inputs": [
        {
          "name": "Title",
          "required": true,
          "mapTo": "Title"
        },
        {
          "name": "Body Html",
          "required": false,
          "mapTo": "Body Html"
        },
        {
          "name": "Vendor",
          "required": false,
          "mapTo": "Vendor"
        },
        {
          "name": "Product Type",
          "required": false,
          "mapTo": "Product Type"
        },
        {
          "name": "Tags",
          "required": false,
          "mapTo": "Tags"
        },
        {
          "name": "Price",
          "required": false,
          "mapTo": "Price"
        }
      ],
      "outputs": [
        {
          "name": "Product ID",
          "path": "product_id"
        },
        {
          "name": "Title",
          "path": "title"
        },
        {
          "name": "Handle",
          "path": "handle"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "product_update",
      "name": "Shopify Product Update",
      "description": "PUT <%= @info['store_url'] %>/admin/api/2024-01/products/<%= @inputs['Product Id'] %>.json",
      "method": "PUT",
      "path": "/admin/api/2024-01/products/<%= @inputs['Product Id'] %>.json",
      "inputs": [
        {
          "name": "Product Id",
          "required": true,
          "mapTo": "Product Id"
        },
        {
          "name": "Title",
          "required": false,
          "mapTo": "Title"
        },
        {
          "name": "Body Html",
          "required": false,
          "mapTo": "Body Html"
        },
        {
          "name": "Vendor",
          "required": false,
          "mapTo": "Vendor"
        },
        {
          "name": "Tags",
          "required": false,
          "mapTo": "Tags"
        },
        {
          "name": "Status",
          "required": false,
          "mapTo": "Status"
        }
      ],
      "outputs": [
        {
          "name": "Product ID",
          "path": "product_id"
        },
        {
          "name": "Updated At",
          "path": "updated_at"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Shopify Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}