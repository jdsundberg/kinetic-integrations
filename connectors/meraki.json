{
  "id": "meraki",
  "service": "Meraki",
  "version": 1,
  "category": "Other",
  "description": "Meraki integration with 3 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">M</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "network_list",
      "name": "Cisco Meraki Network List",
      "description": "GET /api/v1/organizations/{organizationId}/networks",
      "method": "GET",
      "path": "/api/v1/organizations/{{inputs.Organizationid}}/networks",
      "inputs": [
        {
          "name": "Organization ID",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Networks JSON",
          "path": "networks"
        }
      ]
    },
    {
      "id": "organization_list",
      "name": "Cisco Meraki Organization List",
      "description": "GET /api/v1/organizations",
      "method": "GET",
      "path": "/api/v1/organizations",
      "inputs": [],
      "outputs": [
        {
          "name": "Organizations JSON",
          "path": "organizations"
        }
      ]
    },
    {
      "id": "test",
      "name": "Meraki Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}