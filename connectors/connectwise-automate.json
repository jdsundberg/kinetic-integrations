{
  "id": "connectwise-automate",
  "service": "ConnectWise Automate",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "ConnectWise Automate (formerly LabTech) integration with 25 pre-built routines covering clients, locations, computers, contacts, commands, scripts, monitors, tickets, patches, and groups — the legacy CW RMM paired with ConnectWise Manage PSA.",
  "auth": {
    "type": "oauth2",
    "properties": [
      { "name": "api_url", "required": true, "description": "Automate server URL, e.g. https://automate.example.com. Connector appends /cwa/api/v1/... to this base." },
      { "name": "username", "required": true, "description": "Automate user with API permission." },
      { "name": "password", "required": true, "description": "Password.", "encrypted": true },
      { "name": "client_id", "required": true, "description": "ConnectWise developer ClientID GUID.", "encrypted": true }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#007DB8\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">CWA</text></svg>",
  "docsUrl": "https://developer.connectwise.com/Products/ConnectWise_Automate",
  "defaultHeaders": { "Accept": "application/json", "Content-Type": "application/json" },
  "baseUrl": "https://AUTOMATE-HOST",
  "routines": [
    { "id": "test", "name": "ConnectWise Automate Connection Test", "description": "GET /cwa/api/v1/system/information", "method": "GET", "path": "/cwa/api/v1/system/information", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "clients_list", "name": "ConnectWise Automate Clients List", "description": "GET /cwa/api/v1/clients", "method": "GET", "path": "/cwa/api/v1/clients", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Page Size","required":false,"mapTo":"pagesize"},{"name":"Order By","required":false,"mapTo":"orderby"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "client_retrieve", "name": "ConnectWise Automate Client Retrieve", "description": "GET /cwa/api/v1/clients/{{inputs.Client ID}}", "method": "GET", "path": "/cwa/api/v1/clients/{{inputs.Client ID}}", "inputs": [{"name":"Client ID","required":true,"mapTo":"Client ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "client_create", "name": "ConnectWise Automate Client Create", "description": "POST /cwa/api/v1/clients", "method": "POST", "path": "/cwa/api/v1/clients", "inputs": [{"name":"Name","required":true,"mapTo":"Name"},{"name":"Address 1","required":false,"mapTo":"Address1"},{"name":"City","required":false,"mapTo":"City"},{"name":"State","required":false,"mapTo":"State"},{"name":"Zip","required":false,"mapTo":"Zip"},{"name":"Country","required":false,"mapTo":"Country"},{"name":"Phone","required":false,"mapTo":"Phone"},{"name":"Website","required":false,"mapTo":"Website"}], "outputs": [{"name":"Client ID","path":"Id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "client_update", "name": "ConnectWise Automate Client Update", "description": "PATCH /cwa/api/v1/clients/{{inputs.Client ID}}", "method": "PATCH", "path": "/cwa/api/v1/clients/{{inputs.Client ID}}", "inputs": [{"name":"Client ID","required":true,"mapTo":"Client ID"},{"name":"Patch Operations","required":true,"mapTo":"patch"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "locations_list", "name": "ConnectWise Automate Locations List", "description": "GET /cwa/api/v1/locations", "method": "GET", "path": "/cwa/api/v1/locations", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Page Size","required":false,"mapTo":"pagesize"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "location_retrieve", "name": "ConnectWise Automate Location Retrieve", "description": "GET /cwa/api/v1/locations/{{inputs.Location ID}}", "method": "GET", "path": "/cwa/api/v1/locations/{{inputs.Location ID}}", "inputs": [{"name":"Location ID","required":true,"mapTo":"Location ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "computers_list", "name": "ConnectWise Automate Computers List", "description": "GET /cwa/api/v1/computers", "method": "GET", "path": "/cwa/api/v1/computers", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Page Size","required":false,"mapTo":"pagesize"},{"name":"Order By","required":false,"mapTo":"orderby"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "computer_retrieve", "name": "ConnectWise Automate Computer Retrieve", "description": "GET /cwa/api/v1/computers/{{inputs.Computer ID}}", "method": "GET", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "computer_services", "name": "ConnectWise Automate Computer Services", "description": "GET /cwa/api/v1/computers/{{inputs.Computer ID}}/services", "method": "GET", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}/services", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "computer_processes", "name": "ConnectWise Automate Computer Processes", "description": "GET /cwa/api/v1/computers/{{inputs.Computer ID}}/processes", "method": "GET", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}/processes", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "computer_software", "name": "ConnectWise Automate Computer Software", "description": "GET /cwa/api/v1/computers/{{inputs.Computer ID}}/software", "method": "GET", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}/software", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "contacts_list", "name": "ConnectWise Automate Contacts List", "description": "GET /cwa/api/v1/contacts", "method": "GET", "path": "/cwa/api/v1/contacts", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Page Size","required":false,"mapTo":"pagesize"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "command_execute", "name": "ConnectWise Automate Execute Command", "description": "POST /cwa/api/v1/computers/{{inputs.Computer ID}}/CommandExecute", "method": "POST", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}/CommandExecute", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"},{"name":"Command ID","required":true,"mapTo":"CommandId"},{"name":"Parameters","required":false,"mapTo":"Parameters"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "script_run_on_computer", "name": "ConnectWise Automate Run Script on Computer", "description": "POST /cwa/api/v1/computers/{{inputs.Computer ID}}/RunScript", "method": "POST", "path": "/cwa/api/v1/computers/{{inputs.Computer ID}}/RunScript", "inputs": [{"name":"Computer ID","required":true,"mapTo":"Computer ID"},{"name":"Script ID","required":true,"mapTo":"ScriptId"},{"name":"Parameters","required":false,"mapTo":"Parameters"},{"name":"Run Now","required":false,"mapTo":"RunNow"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "scripts_list", "name": "ConnectWise Automate Scripts List", "description": "GET /cwa/api/v1/scripts", "method": "GET", "path": "/cwa/api/v1/scripts", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "script_retrieve", "name": "ConnectWise Automate Script Retrieve", "description": "GET /cwa/api/v1/scripts/{{inputs.Script ID}}", "method": "GET", "path": "/cwa/api/v1/scripts/{{inputs.Script ID}}", "inputs": [{"name":"Script ID","required":true,"mapTo":"Script ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "tickets_list", "name": "ConnectWise Automate Tickets List", "description": "GET /cwa/api/v1/tickets", "method": "GET", "path": "/cwa/api/v1/tickets", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_create", "name": "ConnectWise Automate Ticket Create", "description": "POST /cwa/api/v1/tickets", "method": "POST", "path": "/cwa/api/v1/tickets", "inputs": [{"name":"Subject","required":true,"mapTo":"Subject"},{"name":"Description","required":false,"mapTo":"Description"},{"name":"Client ID","required":true,"mapTo":"Client.Id"},{"name":"Computer ID","required":false,"mapTo":"Computer.Id"},{"name":"Status ID","required":false,"mapTo":"Status.Id"},{"name":"Priority ID","required":false,"mapTo":"Priority.Id"}], "outputs": [{"name":"Ticket ID","path":"Id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "ticket_retrieve", "name": "ConnectWise Automate Ticket Retrieve", "description": "GET /cwa/api/v1/tickets/{{inputs.Ticket ID}}", "method": "GET", "path": "/cwa/api/v1/tickets/{{inputs.Ticket ID}}", "inputs": [{"name":"Ticket ID","required":true,"mapTo":"Ticket ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "monitors_list", "name": "ConnectWise Automate Monitors List", "description": "GET /cwa/api/v1/monitors", "method": "GET", "path": "/cwa/api/v1/monitors", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "patches_list", "name": "ConnectWise Automate Patches List", "description": "GET /cwa/api/v1/patches", "method": "GET", "path": "/cwa/api/v1/patches", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "groups_list", "name": "ConnectWise Automate Groups List", "description": "GET /cwa/api/v1/groups", "method": "GET", "path": "/cwa/api/v1/groups", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "group_computers", "name": "ConnectWise Automate Group Computers", "description": "GET /cwa/api/v1/groups/{{inputs.Group ID}}/computers", "method": "GET", "path": "/cwa/api/v1/groups/{{inputs.Group ID}}/computers", "inputs": [{"name":"Group ID","required":true,"mapTo":"Group ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "alerts_list", "name": "ConnectWise Automate Alerts List", "description": "GET /cwa/api/v1/alerts", "method": "GET", "path": "/cwa/api/v1/alerts", "inputs": [{"name":"Condition","required":false,"mapTo":"condition"},{"name":"Page","required":false,"mapTo":"page"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
