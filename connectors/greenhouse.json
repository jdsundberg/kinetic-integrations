{
  "id": "greenhouse",
  "service": "Greenhouse",
  "version": 1,
  "category": "HR & People",
  "description": "Greenhouse integration with 4 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#15AE67\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">G</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "application_list",
      "name": "Greenhouse Application List",
      "description": "GET /v1/applications",
      "method": "GET",
      "path": "/v1/applications",
      "inputs": [],
      "outputs": [
        {
          "name": "Applications JSON",
          "path": "applications"
        }
      ]
    },
    {
      "id": "candidate_create",
      "name": "Greenhouse Candidate Create",
      "description": "POST /v1/candidates",
      "method": "POST",
      "path": "/v1/candidates",
      "inputs": [
        {
          "name": "First Name",
          "required": true,
          "mapTo": "First Name"
        },
        {
          "name": "Last Name",
          "required": true,
          "mapTo": "Last Name"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "Email"
        }
      ],
      "outputs": [
        {
          "name": "Candidate ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "job_list",
      "name": "Greenhouse Job List",
      "description": "GET /v1/jobs?status=open",
      "method": "GET",
      "path": "/v1/jobs?status=open",
      "inputs": [],
      "outputs": [
        {
          "name": "Jobs JSON",
          "path": "jobs"
        }
      ]
    },
    {
      "id": "test",
      "name": "Greenhouse Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://harvest.greenhouse.io"
}
