{
  "id": "palo-alto",
  "service": "Palo Alto",
  "version": 1,
  "category": "Security & Identity",
  "description": "Palo Alto integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">P</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "alert_list",
      "name": "Palo Alto Prisma Alert List",
      "description": "GET /alert/v2?timeType=relative&timeAmount=24&timeUnit=hour",
      "method": "GET",
      "path": "/alert/v2?timeType=relative&timeAmount=24&timeUnit=hour",
      "inputs": [
        {
          "name": "Policy Name",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Alerts JSON",
          "path": "items"
        }
      ]
    },
    {
      "id": "test",
      "name": "Palo Alto Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}