      "name": "Square Catalog Object Create",
      "description": "POST https://connect.squareup.com/v2/catalog/object",
      "method": "POST",
      "path": "https://connect.squareup.com/v2/catalog/object",
      "inputs": [
        {
          "name": "Idempotency Key",
          "required": true,
          "mapTo": "Idempotency Key"
        },
        {
          "name": "Type",
          "required": true,
          "mapTo": "Type"
        },
        {
          "name": "Item Name",
          "required": true,
          "mapTo": "Item Name"
        },
        {
          "name": "Variation Name",
          "required": true,
          "mapTo": "Variation Name"
        },
        {
          "name": "Price",
          "required": true,
          "mapTo": "Price"
        },
        {
          "name": "Currency",
          "required": true,
          "mapTo": "Currency"
        }
      ],
      "outputs": [
        {
          "name": "Catalog Object ID",
          "path": "catalog_object_id"
        },
        {
          "name": "Version",
          "path": "version"
        },
        {
          "name": "Updated At",
          "path": "updated_at"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
