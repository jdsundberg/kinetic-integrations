{
  "id": "ldap",
  "service": "Ldap",
  "version": 1,
  "category": "Other",
  "description": "Ldap integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "server",
        "required": true,
        "description": "LDAP server URL (e.g. ldaps://dc01.example.com:636)."
      },
      {
        "name": "bind_dn",
        "required": true,
        "description": "Bind DN for authentication (e.g. CN=svc-kinetic,OU=Service Accounts,DC=example,DC=com)."
      },
      {
        "name": "bind_password",
        "required": true,
        "description": "Bind password.",
        "encrypted": true
      },
      {
        "name": "base_dn",
        "required": true,
        "description": "Base DN for searches (e.g. DC=example,DC=com)."
      },
      {
        "name": "use_ssl",
        "required": false,
        "description": "Use SSL/TLS (default: true)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0097A7\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">L</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "search",
      "name": "LDAP Search",
      "description": "POST /search",
      "method": "POST",
      "path": "/search",
      "inputs": [
        {
          "name": "Base DN",
          "required": true,
          "mapTo": "Base DN"
        },
        {
          "name": "Filter",
          "required": true,
          "mapTo": "Filter"
        },
        {
          "name": "Attributes JSON",
          "required": false,
          "mapTo": "Attributes JSON"
        }
      ],
      "outputs": [
        {
          "name": "Entries JSON",
          "path": "entries"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "test",
      "name": "Ldap Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "user_create",
      "name": "LDAP User Create",
      "description": "POST /add",
      "method": "POST",
      "path": "/add",
      "inputs": [
        {
          "name": "DN",
          "required": true,
          "mapTo": "DN"
        },
        {
          "name": "Attributes JSON",
          "required": true,
          "mapTo": "Attributes JSON"
        }
      ],
      "outputs": [
        {
          "name": "DN",
          "path": "dn"
        }
      ]
    }
  ],
  "baseUrl": "ldaps://LDAPHOST:636"
}
