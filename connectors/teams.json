        {
          "name": "Join URL",
          "path": "join_url"
        },
        {
          "name": "Meeting JSON",
          "path": "meeting_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
