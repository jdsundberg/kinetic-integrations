      "description": "POST https://graph.microsoft.com/v1.0/users/<%= @inputs['Organizer Id'] %>/onlineMeetings",
      "method": "POST",
      "path": "/v1.0/users/<%= @inputs['Organizer Id'] %>/onlineMeetings",
