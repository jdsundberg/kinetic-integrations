{
  "id": "teams",
  "service": "Teams",
  "version": 1,
  "category": "Communication",
  "description": "Teams integration with 11 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope (if required)."
      },
      {
        "name": "tenant_id",
        "required": true,
        "description": "Azure AD tenant ID."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#2E7D32\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">T</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "channel_create",
      "name": "Microsoft Teams Channel Create",
      "description": "POST https://graph.microsoft.com/v1.0/teams/<%= @inputs['Team Id'] %>/channels",
      "method": "POST",
      "path": "/v1.0/teams/<%= @inputs['Team Id'] %>/channels",
      "inputs": [
        {
          "name": "Team Id",
          "required": true,
          "mapTo": "Team Id"
        },
        {
          "name": "Display Name",
          "required": true,
          "mapTo": "Display Name"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Membership Type",
          "required": false,
          "mapTo": "Membership Type"
        }
      ],
      "outputs": [
        {
          "name": "Channel ID",
          "path": "channel_id"
        },
        {
          "name": "Display Name",
          "path": "display_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "channel_list",
      "name": "Microsoft Teams Channel List",
      "description": "GET https://graph.microsoft.com/v1.0/teams/<%= @inputs['Team Id'] %>/channels",
      "method": "GET",
      "path": "/v1.0/teams/<%= @inputs['Team Id'] %>/channels",
      "inputs": [
        {
          "name": "Team Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Channels JSON",
          "path": "channels_json"
        },
        {
          "name": "Count",
          "path": "count"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "chat_create",
      "name": "Microsoft Teams Chat Create",
      "description": "POST https://graph.microsoft.com/v1.0/chats",
      "method": "POST",
      "path": "/v1.0/chats",
      "inputs": [
        {
          "name": "Chat Type",
          "required": true,
          "mapTo": "Chat Type"
        },
        {
          "name": "Member Ids",
          "required": true,
          "mapTo": "Member Ids"
        },
        {
          "name": "Topic",
          "required": false,
          "mapTo": "Topic"
        }
      ],
      "outputs": [
        {
          "name": "Chat ID",
          "path": "chat_id"
        },
        {
          "name": "Topic",
          "path": "topic"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
