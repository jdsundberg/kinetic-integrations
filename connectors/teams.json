      "outputs": [
        {
          "name": "Member ID",
          "path": "member_id"
        },
        {
          "name": "Display Name",
          "path": "display_name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "member_remove",
