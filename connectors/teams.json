      "description": "DELETE https://graph.microsoft.com/v1.0/teams/<%= @inputs['Team Id'] %>/members/<%= @inputs['Membership Id'] %>",
      "method": "DELETE",
      "path": "/v1.0/teams/<%= @inputs['Team Id'] %>/members/<%= @inputs['Membership Id'] %>",
      "inputs": [
        {
          "name": "Team Id",
          "required": true
