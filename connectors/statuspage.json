{
  "id": "statuspage",
  "service": "Statuspage",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Statuspage integration with 3 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#172B4D\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">S</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "incident_create",
      "name": "Statuspage Incident Create",
      "description": "POST /v1/pages/{page_id}/incidents",
      "method": "POST",
      "path": "/v1/pages/{{inputs.Page ID}}/incidents",
      "inputs": [
        {
          "name": "Page ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Status",
          "required": true,
          "mapTo": "Status"
        },
        {
          "name": "Body",
          "required": false,
          "mapTo": "Body"
        }
      ],
      "outputs": [
        {
          "name": "Incident ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "incident_list",
      "name": "Statuspage Incident List",
      "description": "GET /v1/pages/{page_id}/incidents",
      "method": "GET",
      "path": "/v1/pages/{{inputs.Page ID}}/incidents",
      "inputs": [
        {
          "name": "Page ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Incidents JSON",
          "path": "incidents"
        }
      ]
    },
    {
      "id": "test",
      "name": "Statuspage Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.statuspage.io"
}
