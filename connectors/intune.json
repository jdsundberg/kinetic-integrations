{
  "id": "intune",
  "service": "Intune",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Intune integration with 7 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">I</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "app_assign",
      "name": "Microsoft Intune App Assign",
      "description": "POST https://graph.microsoft.com/v1.0/deviceAppManagement/mobileApps/{{inputs.App Id}}/assign",
      "method": "POST",
      "path": "/v1.0/deviceAppManagement/mobileApps/{{inputs.App Id}}/assign",
      "inputs": [
        {
          "name": "App Id",
          "required": true,
          "mapTo": "App Id"
        },
        {
          "name": "Group Id",
          "required": true,
          "mapTo": "Group Id"
        },
        {
          "name": "Intent",
          "required": false,
          "mapTo": "Intent"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "compliance_create",
      "name": "Microsoft Intune Compliance Create",
      "description": "POST https://graph.microsoft.com/v1.0/deviceManagement/deviceCompliancePolicies",
      "method": "POST",
      "path": "/v1.0/deviceManagement/deviceCompliancePolicies",
      "inputs": [
        {
          "name": "Display Name",
          "required": true,
          "mapTo": "Display Name"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Platform",
          "required": true,
          "mapTo": "Platform"
        },
        {
          "name": "Password Required",
          "required": false,
          "mapTo": "Password Required"
        },
        {
          "name": "Min Password Length",
          "required": false,
          "mapTo": "Min Password Length"
        }
      ],
      "outputs": [
        {
          "name": "Policy ID",
          "path": "policy_id"
        },
        {
          "name": "Display Name",
          "path": "display_name"
        },
        {
          "name": "Created DateTime",
          "path": "created_datetime"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "compliance_policy_list",
      "name": "Microsoft Intune Compliance Policy List",
      "description": "GET /v1.0/deviceManagement/deviceCompliancePolicies",
      "method": "GET",
      "path": "/v1.0/deviceManagement/deviceCompliancePolicies",
      "inputs": [],
      "outputs": [
        {
          "name": "Policies JSON",
          "path": "value"
        }
      ]
    },
    {
      "id": "device_list",
      "name": "Microsoft Intune Device List",
      "description": "GET /v1.0/deviceManagement/managedDevices",
      "method": "GET",
      "path": "/v1.0/deviceManagement/managedDevices",
      "inputs": [],
      "outputs": [
        {
          "name": "Devices JSON",
          "path": "value"
        }
      ]
    },
    {
      "id": "device_retrieve",
      "name": "Microsoft Intune Device Retrieve",
      "description": "GET https://graph.microsoft.com/v1.0/deviceManagement/managedDevices/{{inputs.Device Id}}",
      "method": "GET",
      "path": "/v1.0/deviceManagement/managedDevices/{{inputs.Device Id}}",
      "inputs": [
        {
          "name": "Device Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Device ID",
          "path": "device_id"
        },
        {
          "name": "Device Name",
          "path": "device_name"
        },
        {
          "name": "OS Version",
          "path": "os_version"
        },
        {
          "name": "Compliance State",
          "path": "compliance_state"
        },
        {
          "name": "Last Sync",
          "path": "last_sync"
        },
        {
          "name": "User Principal Name",
          "path": "user_principal_name"
        },
        {
          "name": "Device JSON",
          "path": "device_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "policy_create",
      "name": "Microsoft Intune Policy Create",
      "description": "POST https://graph.microsoft.com/v1.0/deviceManagement/deviceConfigurations",
      "method": "POST",
      "path": "/v1.0/deviceManagement/deviceConfigurations",
      "inputs": [
        {
          "name": "Display Name",
          "required": true,
          "mapTo": "Display Name"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Platform",
          "required": true,
          "mapTo": "Platform"
        },
        {
          "name": "Settings Json",
          "required": false,
          "mapTo": "Settings Json"
        }
      ],
      "outputs": [
        {
          "name": "Policy ID",
          "path": "policy_id"
        },
        {
          "name": "Display Name",
          "path": "display_name"
        },
        {
          "name": "Created DateTime",
          "path": "created_datetime"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Intune Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}