{
  "id": "zoho-crm",
  "service": "Zoho Crm",
  "version": 1,
  "category": "CRM & Sales",
  "description": "Zoho Crm integration with 3 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#283593\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">Z</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "record_create",
      "name": "Zoho CRM Record Create",
      "description": "POST /crm/v6/{module}",
      "method": "POST",
      "path": "/crm/v6/{{inputs.Module}}",
      "inputs": [
        {
          "name": "Module",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Data JSON",
          "required": true,
          "mapTo": "Data JSON"
        }
      ],
      "outputs": [
        {
          "name": "Record ID",
          "path": "data[0].details.id"
        }
      ]
    },
    {
      "id": "record_list",
      "name": "Zoho CRM Record List",
      "description": "GET /crm/v6/{module}",
      "method": "GET",
      "path": "/crm/v6/{{inputs.Module}}",
      "inputs": [
        {
          "name": "Module",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Records JSON",
          "path": "data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Zoho Crm Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}