      "name": "ServiceNow Change Request Create",
      "description": "POST /api/now/table/change_request",
      "method": "POST",
      "path": "/api/now/table/change_request",
      "inputs": [
        {
          "name": "Short Description",
          "required": true,
          "mapTo": "Short Description"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "Description"
        },
        {
          "name": "Type",
          "required": false,
          "mapTo": "Type"
        },
        {
          "name": "Category",
          "required": false,
          "mapTo": "Category"
        },
        {
          "name": "Assignment Group",
          "required": false,
          "mapTo": "Assignment Group"
        },
        {
          "name": "Requested By",
          "required": false,
          "mapTo": "Requested By"
        }
      ],
      "outputs": [
        {
          "name": "Sys ID",
          "path": "sys_id"
        },
        {
          "name": "Number",
          "path": "number"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
