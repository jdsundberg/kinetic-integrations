{
  "id": "servicenow",
  "service": "Servicenow",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Servicenow integration with 11 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "instance_url",
        "required": true,
        "description": "ServiceNow instance URL (e.g. https://myco.service-now.com)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#00695C\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">S</text></svg>",
  "docsUrl": "https://developer.servicenow.com/dev.do#!/reference/api/latest/rest/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
