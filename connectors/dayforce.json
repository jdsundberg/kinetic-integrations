{
  "id": "dayforce",
  "service": "Dayforce",
  "version": 1,
  "category": "Other",
  "description": "Dayforce integration with 2 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      },
      {
        "name": "client_namespace",
        "required": true,
        "description": "client namespace."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0097A7\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">D</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "employee_retrieve",
      "name": "Dayforce Employee Retrieve",
      "description": "GET /Api/{clientNamespace}/V1/Employees/{xRefCode}",
      "method": "GET",
      "path": "/Api/{{inputs.Clientnamespace}}/V1/Employees/{{inputs.Xrefcode}}",
      "inputs": [
        {
          "name": "Client Namespace",
          "required": true
        },
        {
          "name": "XRef Code",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Employee JSON",
          "path": "Data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Dayforce Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}