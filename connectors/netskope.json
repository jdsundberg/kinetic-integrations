{
  "id": "netskope",
  "service": "Netskope",
  "version": 1,
  "category": "Security & Identity",
  "description": "Netskope integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#04A6D7\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">N</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "alert_list",
      "name": "Netskope Alert List",
      "description": "GET /api/v2/events/data/alert?timeperiod={timeperiod}",
      "method": "GET",
      "path": "/api/v2/events/data/alert?timeperiod={{inputs.Timeperiod}}",
      "inputs": [
        {
          "name": "Time Period",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Alerts JSON",
          "path": "data"
        }
      ]
    },
    {
      "id": "test",
      "name": "Netskope Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}