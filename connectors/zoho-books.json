{
  "id": "zoho-books",
  "service": "Zoho Books",
  "version": 1,
  "category": "Accounting",
  "description": "Zoho Books integration with 9 pre-built routines.",
  "auth": {
    "type": "oauth2_refresh",
    "properties": [
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "refresh_token",
        "required": true,
        "description": "OAuth2 refresh token.",
        "encrypted": true
      },
      {
        "name": "organization_id",
        "required": true,
        "description": "Zoho Books organization ID."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#283593\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">Z</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "account_list",
      "name": "Zoho Books Chart of Accounts",
      "description": "GET /api/v3/accounts",
      "method": "GET",
      "path": "/api/v3/accounts",
      "inputs": [],
      "outputs": [
        {
          "name": "Accounts JSON",
          "path": "accounts"
        },
        {
          "name": "Count",
          "path": "count"
        }
      ]
    },
    {
      "id": "bill_create",
      "name": "Zoho Books Bill Create",
      "description": "POST /api/v3/bills",
      "method": "POST",
      "path": "/api/v3/bills",
      "inputs": [
        {
          "name": "Vendor Id",
          "required": true,
          "mapTo": "Vendor Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        }
      ],
      "outputs": [
        {
          "name": "Bill Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "customer_create",
      "name": "Zoho Books Customer Create",
      "description": "POST /api/v3/customers",
      "method": "POST",
      "path": "/api/v3/customers",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        },
        {
          "name": "Address",
          "required": false,
          "mapTo": "Address"
        }
      ],
      "outputs": [
        {
          "name": "Customer Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    },
    {
      "id": "invoice_create",
      "name": "Zoho Books Invoice Create",
      "description": "POST /api/v3/invoices",
      "method": "POST",
      "path": "/api/v3/invoices",
      "inputs": [
        {
          "name": "Customer Id",
          "required": true,
          "mapTo": "Customer Id"
        },
        {
          "name": "Line Items JSON",
          "required": true,
          "mapTo": "Line Items JSON"
        },
        {
          "name": "Due Date",
          "required": false,
          "mapTo": "Due Date"
        },
        {
          "name": "Currency",
          "required": false,
          "mapTo": "Currency"
        }
      ],
      "outputs": [
        {
          "name": "Invoice Id",
          "path": "id"
        },
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "invoice_retrieve",
      "name": "Zoho Books Invoice Retrieve",
      "description": "GET /api/v3/invoices/{invoice_id}",
      "method": "GET",
      "path": "/api/v3/invoices/{{inputs.Invoice Id}}",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Invoice Number",
          "path": "number"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Total",
          "path": "total"
        },
        {
          "name": "Balance Due",
          "path": "balance"
        }
      ]
    },
    {
      "id": "journal_entry_create",
      "name": "Zoho Books Journal Entry Create",
      "description": "POST /api/v3/journal-entries",
      "method": "POST",
      "path": "/api/v3/journal-entries",
      "inputs": [
        {
          "name": "Date",
          "required": true,
          "mapTo": "Date"
        },
        {
          "name": "Lines JSON",
          "required": true,
          "mapTo": "Lines JSON"
        },
        {
          "name": "Memo",
          "required": false,
          "mapTo": "Memo"
        }
      ],
      "outputs": [
        {
          "name": "Entry Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "Zoho Books Payment Create",
      "description": "POST /api/v3/payments",
      "method": "POST",
      "path": "/api/v3/payments",
      "inputs": [
        {
          "name": "Invoice Id",
          "required": true,
          "mapTo": "Invoice Id"
        },
        {
          "name": "Amount",
          "required": true,
          "mapTo": "Amount"
        },
        {
          "name": "Payment Date",
          "required": false,
          "mapTo": "Payment Date"
        },
        {
          "name": "Payment Method",
          "required": false,
          "mapTo": "Payment Method"
        }
      ],
      "outputs": [
        {
          "name": "Payment Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "test",
      "name": "Zoho Books Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "vendor_create",
      "name": "Zoho Books Vendor Create",
      "description": "POST /api/v3/vendors",
      "method": "POST",
      "path": "/api/v3/vendors",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Vendor Id",
          "path": "id"
        },
        {
          "name": "Name",
          "path": "name"
        }
      ]
    }
  ]
}