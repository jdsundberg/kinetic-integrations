{
  "id": "kinetic-core-api",
  "service": "Kinetic Core API",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Kinetic Platform Core API \u2014 manage submissions, forms, kapps, users, teams, and space configuration. Pre-installed on every Kinetic instance.",
  "docsUrl": "https://docs.kineticdata.com/reference",
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F36C24\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">K</text></svg>",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "api_username",
        "required": true,
        "description": "Kinetic Platform username (often a service account like space-integration-user)."
      },
      {
        "name": "api_password",
        "required": true,
        "encrypted": true,
        "description": "Kinetic Platform password."
      },
      {
        "name": "api_location",
        "required": true,
        "description": "Kinetic server URL (e.g. https://myspace.kinops.io)."
      },
      {
        "name": "enable_debug_logging",
        "required": false,
        "description": "True or False. Enables verbose logging."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "submission_create",
      "name": "Submission Create",
      "description": "Creates a submission on a form.",
      "method": "POST",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/forms/{{inputs.Form Slug}}/submissions",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Form Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Values JSON",
          "required": true,
          "description": "JSON object of field name-value pairs.",
          "mapTo": "values"
        },
        {
          "name": "Core State",
          "required": false,
          "description": "Draft, Submitted, or Closed.",
          "mapTo": "coreState"
        }
      ],
      "outputs": [
        {
          "name": "Submission ID",
          "path": "submission.id"
        },
        {
          "name": "Handle",
          "path": "submission.handle"
        }
      ]
    },
    {
      "id": "submission_retrieve",
      "name": "Submission Retrieve",
      "description": "Retrieves a submission by ID.",
      "method": "GET",
      "path": "/app/api/v1/submissions/{{inputs.Submission ID}}?include=values,details",
      "inputs": [
        {
          "name": "Submission ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Values JSON",
          "path": "submission.values"
        },
        {
          "name": "Core State",
          "path": "submission.coreState"
        },
        {
          "name": "Created At",
          "path": "submission.createdAt"
        }
      ]
    },
    {
      "id": "submission_update",
      "name": "Submission Update",
      "description": "Updates a submission's values and/or state.",
      "method": "PUT",
      "path": "/app/api/v1/submissions/{{inputs.Submission ID}}",
      "inputs": [
        {
          "name": "Submission ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Values JSON",
          "required": false,
          "mapTo": "values"
        },
        {
          "name": "Core State",
          "required": false,
          "mapTo": "coreState"
        }
      ],
      "outputs": [
        {
          "name": "Submission ID",
          "path": "submission.id"
        }
      ]
    },
    {
      "id": "submission_delete",
      "name": "Submission Delete",
      "description": "Deletes a submission.",
      "method": "DELETE",
      "path": "/app/api/v1/submissions/{{inputs.Submission ID}}",
      "inputs": [
        {
          "name": "Submission ID",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": []
    },
    {
      "id": "submission_search",
      "name": "Submissions Search",
      "description": "Searches submissions with KQL.",
      "method": "GET",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/forms/{{inputs.Form Slug}}/submissions?include=values&limit=25&q={{inputs.Query}}",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Form Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Query",
          "required": false,
          "description": "KQL query (e.g. values[Status]=\"Active\")."
        }
      ],
      "outputs": [
        {
          "name": "Submissions JSON",
          "path": "submissions"
        },
        {
          "name": "Next Page Token",
          "path": "nextPageToken"
        }
      ]
    },
    {
      "id": "submission_update_status",
      "name": "Submission Update Status",
      "description": "Updates a submission's core state (Draft/Submitted/Closed).",
      "method": "PUT",
      "path": "/app/api/v1/submissions/{{inputs.Submission ID}}",
      "inputs": [
        {
          "name": "Submission ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Core State",
          "required": true,
          "description": "Draft, Submitted, or Closed.",
          "mapTo": "coreState"
        }
      ],
      "outputs": [
        {
          "name": "Submission ID",
          "path": "submission.id"
        }
      ]
    },
    {
      "id": "user_create",
      "name": "User Create",
      "description": "Creates a platform user.",
      "method": "POST",
      "path": "/app/api/v1/users",
      "inputs": [
        {
          "name": "Username",
          "required": true,
          "mapTo": "username"
        },
        {
          "name": "Display Name",
          "required": true,
          "mapTo": "displayName"
        },
        {
          "name": "Email",
          "required": true,
          "mapTo": "email"
        },
        {
          "name": "Enabled",
          "required": false,
          "mapTo": "enabled"
        },
        {
          "name": "Space Admin",
          "required": false,
          "mapTo": "spaceAdmin"
        }
      ],
      "outputs": [
        {
          "name": "Username",
          "path": "user.username"
        }
      ]
    },
    {
      "id": "user_retrieve",
      "name": "User Retrieve",
      "description": "Retrieves a user by username.",
      "method": "GET",
      "path": "/app/api/v1/users/{{inputs.Username}}?include=details",
      "inputs": [
        {
          "name": "Username",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Display Name",
          "path": "user.displayName"
        },
        {
          "name": "Email",
          "path": "user.email"
        },
        {
          "name": "Enabled",
          "path": "user.enabled"
        },
        {
          "name": "Space Admin",
          "path": "user.spaceAdmin"
        }
      ]
    },
    {
      "id": "user_update",
      "name": "User Update",
      "description": "Updates a user's properties.",
      "method": "PUT",
      "path": "/app/api/v1/users/{{inputs.Username}}",
      "inputs": [
        {
          "name": "Username",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Display Name",
          "required": false,
          "mapTo": "displayName"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "email"
        },
        {
          "name": "Enabled",
          "required": false,
          "mapTo": "enabled"
        }
      ],
      "outputs": [
        {
          "name": "Username",
          "path": "user.username"
        }
      ]
    },
    {
      "id": "user_delete",
      "name": "User Delete",
      "description": "Deletes a platform user.",
      "method": "DELETE",
      "path": "/app/api/v1/users/{{inputs.Username}}",
      "inputs": [
        {
          "name": "Username",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": []
    },
    {
      "id": "users_list",
      "name": "Users List",
      "description": "Lists platform users.",
      "method": "GET",
      "path": "/app/api/v1/users?include=details&limit=25",
      "inputs": [],
      "outputs": [
        {
          "name": "Users JSON",
          "path": "users"
        }
      ]
    },
    {
      "id": "team_create",
      "name": "Team Create",
      "description": "Creates a team.",
      "method": "POST",
      "path": "/app/api/v1/teams",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "name"
        },
        {
          "name": "Slug",
          "required": true,
          "mapTo": "slug"
        },
        {
          "name": "Description",
          "required": false,
          "mapTo": "description"
        }
      ],
      "outputs": [
        {
          "name": "Slug",
          "path": "team.slug"
        }
      ]
    },
    {
      "id": "team_retrieve",
      "name": "Team Retrieve",
      "description": "Retrieves a team.",
      "method": "GET",
      "path": "/app/api/v1/teams/{{inputs.Slug}}?include=memberships",
      "inputs": [
        {
          "name": "Slug",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Name",
          "path": "team.name"
        },
        {
          "name": "Members JSON",
          "path": "team.memberships"
        }
      ]
    },
    {
      "id": "team_membership_create",
      "name": "Team Membership Create",
      "description": "Adds a user to a team.",
      "method": "POST",
      "path": "/app/api/v1/teams/{{inputs.Slug}}/memberships",
      "inputs": [
        {
          "name": "Team Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Username",
          "required": true,
          "mapTo": "user.username"
        }
      ],
      "outputs": []
    },
    {
      "id": "team_membership_delete",
      "name": "Team Membership Delete",
      "description": "Removes a user from a team.",
      "method": "DELETE",
      "path": "/app/api/v1/teams/{{inputs.Slug}}/memberships/{{inputs.Username}}",
      "inputs": [
        {
          "name": "Team Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Username",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": []
    },
    {
      "id": "teams_list",
      "name": "Teams List",
      "description": "Lists all teams.",
      "method": "GET",
      "path": "/app/api/v1/teams?include=memberships",
      "inputs": [],
      "outputs": [
        {
          "name": "Teams JSON",
          "path": "teams"
        }
      ]
    },
    {
      "id": "kapp_create",
      "name": "Kapp Create",
      "description": "Creates a kapp.",
      "method": "POST",
      "path": "/app/api/v1/kapps",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "name"
        },
        {
          "name": "Slug",
          "required": true,
          "mapTo": "slug"
        }
      ],
      "outputs": [
        {
          "name": "Slug",
          "path": "kapp.slug"
        }
      ]
    },
    {
      "id": "kapp_retrieve",
      "name": "Kapp Retrieve",
      "description": "Retrieves a kapp.",
      "method": "GET",
      "path": "/app/api/v1/kapps/{{inputs.Slug}}",
      "inputs": [
        {
          "name": "Slug",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Name",
          "path": "kapp.name"
        },
        {
          "name": "Slug",
          "path": "kapp.slug"
        }
      ]
    },
    {
      "id": "kapps_list",
      "name": "Kapps List",
      "description": "Lists all kapps.",
      "method": "GET",
      "path": "/app/api/v1/kapps",
      "inputs": [],
      "outputs": [
        {
          "name": "Kapps JSON",
          "path": "kapps"
        }
      ]
    },
    {
      "id": "form_create",
      "name": "Form Create",
      "description": "Creates a form in a kapp.",
      "method": "POST",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/forms",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "name"
        },
        {
          "name": "Slug",
          "required": true,
          "mapTo": "slug"
        },
        {
          "name": "Status",
          "required": false,
          "mapTo": "status"
        }
      ],
      "outputs": [
        {
          "name": "Slug",
          "path": "form.slug"
        }
      ]
    },
    {
      "id": "form_retrieve",
      "name": "Form Retrieve",
      "description": "Retrieves a form.",
      "method": "GET",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/forms/{{inputs.Form Slug}}?include=details",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Form Slug",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Name",
          "path": "form.name"
        },
        {
          "name": "Status",
          "path": "form.status"
        }
      ]
    },
    {
      "id": "forms_list",
      "name": "Forms List",
      "description": "Lists forms in a kapp.",
      "method": "GET",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/forms?include=details",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Forms JSON",
          "path": "forms"
        }
      ]
    },
    {
      "id": "space_retrieve",
      "name": "Space Retrieve",
      "description": "Retrieves the current space.",
      "method": "GET",
      "path": "/app/api/v1/space?include=details",
      "inputs": [],
      "outputs": [
        {
          "name": "Space JSON",
          "path": "space"
        }
      ]
    },
    {
      "id": "workflow_create",
      "name": "Workflow Create",
      "description": "Creates a workflow on a kapp.",
      "method": "POST",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/workflows",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Name",
          "required": true,
          "mapTo": "name"
        },
        {
          "name": "Event",
          "required": true,
          "description": "e.g. Submission Submitted",
          "mapTo": "event"
        },
        {
          "name": "Type",
          "required": false,
          "mapTo": "type"
        }
      ],
      "outputs": [
        {
          "name": "Workflow ID",
          "path": "workflow.id"
        }
      ]
    },
    {
      "id": "workflow_list",
      "name": "Workflow List",
      "description": "Lists workflows on a kapp.",
      "method": "GET",
      "path": "/app/api/v1/kapps/{{inputs.Kapp Slug}}/workflows",
      "inputs": [
        {
          "name": "Kapp Slug",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Workflows JSON",
          "path": "workflows"
        }
      ]
    },
    {
      "id": "test",
      "name": "Kinetic Core API Connection Test",
      "description": "Validates authentication by retrieving current user.",
      "method": "GET",
      "path": "/app/api/v1/me",
      "inputs": [],
      "outputs": [
        {
          "name": "Username",
          "path": "username"
        },
        {
          "name": "Display Name",
          "path": "displayName"
        }
      ]
    }
  ]
}
