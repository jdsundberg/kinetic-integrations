{
  "id": "gosystem-tax",
  "service": "Gosystem Tax",
  "version": 1,
  "category": "Tax Software",
  "description": "Gosystem Tax integration with 5 pre-built routines.",
  "auth": {
    "type": "oauth2_refresh",
    "properties": [
      {
        "name": "client_id",
        "required": true,
        "description": "Thomson Reuters OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "Thomson Reuters OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "refresh_token",
        "required": true,
        "description": "OAuth2 refresh token.",
        "encrypted": true
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "client_create",
      "name": "Thomson Reuters GoSystem Tax RS Client Create",
      "description": "POST /api/v1/clients",
      "method": "POST",
      "path": "/api/v1/clients",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "SSN",
          "required": true,
          "mapTo": "SSN"
        },
        {
          "name": "Email",
          "required": false,
          "mapTo": "Email"
        },
        {
          "name": "Phone",
          "required": false,
          "mapTo": "Phone"
        }
      ],
      "outputs": [
        {
          "name": "Client Id",
          "path": "id"
        }
      ]
    },
    {
      "id": "return_create",
      "name": "Thomson Reuters GoSystem Tax RS Return Create",
      "description": "POST /api/v1/returns",
      "method": "POST",
      "path": "/api/v1/returns",
      "inputs": [
        {
          "name": "Taxpayer SSN",
          "required": true,
          "mapTo": "Taxpayer SSN"
        },
        {
          "name": "Tax Year",
          "required": true,
          "mapTo": "Tax Year"
        },
        {
          "name": "Filing Status",
          "required": true,
          "mapTo": "Filing Status"
        },
        {
          "name": "Taxpayer Name",
          "required": true,
          "mapTo": "Taxpayer Name"
        }
      ],
      "outputs": [
        {
          "name": "Return Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        }
      ]
    },
    {
      "id": "return_retrieve",
      "name": "Thomson Reuters GoSystem Tax RS Return Retrieve",
      "description": "GET /api/v1/returns/{return_id}",
      "method": "GET",
      "path": "/api/v1/returns/{return_id}",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Federal Refund",
          "path": "federal_refund"
        },
        {
          "name": "State Refund",
          "path": "state_refund"
        },
        {
          "name": "Tax Year",
          "path": "tax_year"
        }
      ]
    },
    {
      "id": "return_status",
      "name": "Thomson Reuters GoSystem Tax RS Return Status",
      "description": "GET /api/v1/returns/{return_id}/status",
      "method": "GET",
      "path": "/api/v1/returns/{return_id}/status",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Accepted Date",
          "path": "accepted_date"
        },
        {
          "name": "Rejection Reason",
          "path": "rejection_reason"
        }
      ]
    },
    {
      "id": "return_submit",
      "name": "Thomson Reuters GoSystem Tax RS Return E-File",
      "description": "POST /api/v1/returns/{return_id}/efile",
      "method": "POST",
      "path": "/api/v1/returns/{return_id}/efile",
      "inputs": [
        {
          "name": "Return Id",
          "required": true,
          "pathParam": true
        },
        {
          "name": "PIN",
          "required": false,
          "mapTo": "PIN"
        }
      ],
      "outputs": [
        {
          "name": "Submission Id",
          "path": "id"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Confirmation",
          "path": "confirmation_number"
        }
      ]
    }
  ]
}