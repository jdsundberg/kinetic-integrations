{
  "id": "jamf",
  "service": "Jamf",
  "version": 1,
  "category": "Observability & Analytics",
  "description": "Jamf integration with 7 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "Jamf Pro server URL (e.g. https://myco.jamfcloud.com)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#1565C0\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">J</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "command_send",
      "name": "Jamf Pro Command Send",
      "description": "POST /api/v1/mdm/commands",
      "method": "POST",
      "path": "/api/v1/mdm/commands",
      "inputs": [
        {
          "name": "Command Type",
          "required": true,
          "mapTo": "Command Type"
        },
        {
          "name": "Device Ids",
          "required": true,
          "mapTo": "Device Ids"
        },
        {
          "name": "Passcode",
          "required": false,
          "mapTo": "Passcode"
        }
      ],
      "outputs": [
        {
          "name": "Command UUID",
          "path": "command_uuid"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "computer_list",
      "name": "Jamf Pro Computer List",
      "description": "GET /api/v1/computers-inventory",
      "method": "GET",
      "path": "/api/v1/computers-inventory",
      "inputs": [],
      "outputs": [
        {
          "name": "Computers JSON",
          "path": "results"
        }
      ]
    },
    {
      "id": "device_command",
      "name": "Jamf Pro Device Command",
      "description": "POST /api/v1/mdm/commands",
      "method": "POST",
      "path": "/api/v1/mdm/commands",
      "inputs": [
        {
          "name": "Command Type",
          "required": true,
          "mapTo": "Command Type"
        },
        {
          "name": "Device IDs JSON",
          "required": true,
          "mapTo": "Device IDs JSON"
        }
      ],
      "outputs": [
        {
          "name": "Command ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "device_retrieve",
      "name": "Jamf Pro Device Retrieve",
      "description": "GET /api/v1/computers-inventory/{{inputs.Device Id}}",
      "method": "GET",
      "path": "/api/v1/computers-inventory/{{inputs.Device Id}}",
      "inputs": [
        {
          "name": "Device Id",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Device ID",
          "path": "device_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Serial Number",
          "path": "serial_number"
        },
        {
          "name": "OS Version",
          "path": "os_version"
        },
        {
          "name": "Last Check-In",
          "path": "last_check-in"
        },
        {
          "name": "Device JSON",
          "path": "device_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "group_create",
      "name": "Jamf Pro Group Create",
      "description": "POST /api/v1/computer-groups",
      "method": "POST",
      "path": "/api/v1/computer-groups",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Is Smart",
          "required": false,
          "mapTo": "Is Smart"
        },
        {
          "name": "Criteria Json",
          "required": false,
          "mapTo": "Criteria Json"
        }
      ],
      "outputs": [
        {
          "name": "Group ID",
          "path": "group_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "policy_create",
      "name": "Jamf Pro Policy Create",
      "description": "POST /api/v1/policies",
      "method": "POST",
      "path": "/api/v1/policies",
      "inputs": [
        {
          "name": "Name",
          "required": true,
          "mapTo": "Name"
        },
        {
          "name": "Enabled",
          "required": false,
          "mapTo": "Enabled"
        },
        {
          "name": "Trigger",
          "required": false,
          "mapTo": "Trigger"
        },
        {
          "name": "Frequency",
          "required": false,
          "mapTo": "Frequency"
        },
        {
          "name": "Scope Json",
          "required": false,
          "mapTo": "Scope Json"
        }
      ],
      "outputs": [
        {
          "name": "Policy ID",
          "path": "policy_id"
        },
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Jamf Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}