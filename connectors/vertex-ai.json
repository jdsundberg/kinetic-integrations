{
  "id": "vertex-ai",
  "service": "Vertex Ai",
  "version": 1,
  "category": "Other",
  "description": "Vertex Ai integration with 2 pre-built routines.",
  "auth": {
    "type": "jwt",
    "properties": [
      {
        "name": "service_account_email",
        "required": true,
        "description": "Google service account email."
      },
      {
        "name": "private_key",
        "required": true,
        "description": "PEM private key.",
        "encrypted": true
      },
      {
        "name": "jwt_subject",
        "required": false,
        "description": "Email to impersonate."
      },
      {
        "name": "jwt_scope",
        "required": true,
        "description": "OAuth2 scope."
      },
      {
        "name": "project_id",
        "required": true,
        "description": "project id."
      },
      {
        "name": "region",
        "required": true,
        "description": "region."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">V</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "predict",
      "name": "Google Vertex AI Predict",
      "description": "POST /v1/projects/{project_id}/locations/{location}/publishers/google/models/{model_id}:predict",
      "method": "POST",
      "path": "/v1/projects/{{inputs.Project ID}}/locations/{{inputs.Location}}/publishers/google/models/{{inputs.Model ID}}:predict",
      "inputs": [
        {
          "name": "Project ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Location",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Model ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Instances JSON",
          "required": true,
          "mapTo": "Instances JSON"
        }
      ],
      "outputs": [
        {
          "name": "Predictions JSON",
          "path": "predictions"
        }
      ]
    },
    {
      "id": "test",
      "name": "Vertex Ai Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}