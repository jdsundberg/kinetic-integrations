{
  "id": "redis",
  "service": "Redis",
  "version": 1,
  "category": "Other",
  "description": "Redis integration with 4 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "host",
        "required": false,
        "description": "Redis server hostname (default: localhost)."
      },
      {
        "name": "port",
        "required": false,
        "description": "Redis server port (default: 6379)."
      },
      {
        "name": "password",
        "required": false,
        "description": "Redis password (if authentication is enabled).",
        "encrypted": true
      },
      {
        "name": "database",
        "required": false,
        "description": "Redis database index (default: 0)."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">R</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "delete",
      "name": "Redis Delete",
      "description": "DELETE /del/{key}",
      "method": "DELETE",
      "path": "/del/{key}",
      "inputs": [
        {
          "name": "Key",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Result",
          "path": "result"
        }
      ]
    },
    {
      "id": "get",
      "name": "Redis Get",
      "description": "GET /get/{key}",
      "method": "GET",
      "path": "/get/{key}",
      "inputs": [
        {
          "name": "Key",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Value",
          "path": "value"
        }
      ]
    },
    {
      "id": "set",
      "name": "Redis Set",
      "description": "POST /set",
      "method": "POST",
      "path": "/set",
      "inputs": [
        {
          "name": "Key",
          "required": true,
          "mapTo": "Key"
        },
        {
          "name": "Value",
          "required": true,
          "mapTo": "Value"
        },
        {
          "name": "TTL",
          "required": false,
          "mapTo": "TTL"
        }
      ],
      "outputs": [
        {
          "name": "Result",
          "path": "result"
        }
      ]
    },
    {
      "id": "test",
      "name": "Redis Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}