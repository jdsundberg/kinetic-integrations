{
  "id": "generic-apikey-query",
  "service": "Generic REST (API Key Query)",
  "version": 1,
  "category": "Generic",
  "generic": true,
  "description": "Connect to any REST API using an API key in the query string.",
  "auth": {
    "type": "apikey_query",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "encrypted": true,
        "description": "API key value."
      },
      {
        "name": "api_key_param",
        "required": false,
        "description": "Query parameter name (default: api_key)."
      },
      {
        "name": "base_url",
        "required": true,
        "description": "API base URL."
      }
    ]
  },
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": []
}