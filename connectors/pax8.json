{
  "id": "pax8",
  "service": "Pax8",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Pax8 cloud marketplace integration with 22 pre-built routines covering companies (end customers), contacts, products, subscriptions (create/update/cancel), orders, usage summaries, and invoices — the MSP-dominant cloud distributor for Microsoft, Acronis, and other cloud services.",
  "auth": {
    "type": "oauth2",
    "properties": [
      { "name": "client_id", "required": true, "description": "Pax8 API client ID (from Pax8 Admin > Integrations > API Keys)." },
      { "name": "client_secret", "required": true, "description": "Pax8 API client secret.", "encrypted": true },
      { "name": "token_url", "required": true, "description": "OAuth2 token endpoint. Default: https://login.pax8.com/oauth/token." },
      { "name": "audience", "required": true, "description": "OAuth2 audience. Default: api://p8.client." },
      { "name": "api_url", "required": true, "description": "Pax8 API base URL. Default: https://api.pax8.com." }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#F47B20\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">Pax8</text></svg>",
  "docsUrl": "https://docs.pax8.com/",
  "defaultHeaders": { "Accept": "application/json", "Content-Type": "application/json" },
  "baseUrl": "https://api.pax8.com",
  "routines": [
    { "id": "test", "name": "Pax8 Connection Test", "description": "GET /v1/companies (limit=1)", "method": "GET", "path": "/v1/companies", "inputs": [], "outputs": [{"name":"Response Code","path":"response_code"},{"name":"Connected","path":"connected"}] },
    { "id": "companies_list", "name": "Pax8 Companies List", "description": "GET /v1/companies", "method": "GET", "path": "/v1/companies", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"},{"name":"Name","required":false,"mapTo":"name"},{"name":"Status","required":false,"mapTo":"status"}], "outputs": [{"name":"Content","path":"content"},{"name":"Page","path":"page"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "company_create", "name": "Pax8 Company Create", "description": "POST /v1/companies", "method": "POST", "path": "/v1/companies", "inputs": [{"name":"Name","required":true,"mapTo":"name"},{"name":"Address","required":true,"mapTo":"address"},{"name":"City","required":true,"mapTo":"city"},{"name":"State Or Province","required":true,"mapTo":"stateOrProvince"},{"name":"Postal Code","required":true,"mapTo":"postalCode"},{"name":"Country","required":true,"mapTo":"country"},{"name":"Phone","required":false,"mapTo":"phone"},{"name":"Website","required":false,"mapTo":"website"},{"name":"Billing Contact Email","required":false,"mapTo":"billingContactEmail"},{"name":"External ID","required":false,"mapTo":"externalId"}], "outputs": [{"name":"Company ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "company_update", "name": "Pax8 Company Update", "description": "PUT /v1/companies/{{inputs.Company ID}}", "method": "PUT", "path": "/v1/companies/{{inputs.Company ID}}", "inputs": [{"name":"Company ID","required":true,"mapTo":"Company ID"},{"name":"Name","required":false,"mapTo":"name"},{"name":"Address","required":false,"mapTo":"address"},{"name":"City","required":false,"mapTo":"city"},{"name":"State Or Province","required":false,"mapTo":"stateOrProvince"},{"name":"Postal Code","required":false,"mapTo":"postalCode"},{"name":"Status","required":false,"mapTo":"status"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "company_retrieve", "name": "Pax8 Company Retrieve", "description": "GET /v1/companies/{{inputs.Company ID}}", "method": "GET", "path": "/v1/companies/{{inputs.Company ID}}", "inputs": [{"name":"Company ID","required":true,"mapTo":"Company ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "contacts_list", "name": "Pax8 Company Contacts List", "description": "GET /v1/companies/{{inputs.Company ID}}/contacts", "method": "GET", "path": "/v1/companies/{{inputs.Company ID}}/contacts", "inputs": [{"name":"Company ID","required":true,"mapTo":"Company ID"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "contact_create", "name": "Pax8 Contact Create", "description": "POST /v1/companies/{{inputs.Company ID}}/contacts", "method": "POST", "path": "/v1/companies/{{inputs.Company ID}}/contacts", "inputs": [{"name":"Company ID","required":true,"mapTo":"Company ID"},{"name":"First Name","required":true,"mapTo":"firstName"},{"name":"Last Name","required":true,"mapTo":"lastName"},{"name":"Email","required":true,"mapTo":"email"},{"name":"Phone","required":false,"mapTo":"phone"},{"name":"Types","required":false,"mapTo":"types"}], "outputs": [{"name":"Contact ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "products_list", "name": "Pax8 Products List", "description": "GET /v1/products", "method": "GET", "path": "/v1/products", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"},{"name":"Vendor Name","required":false,"mapTo":"vendorName"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "product_retrieve", "name": "Pax8 Product Retrieve", "description": "GET /v1/products/{{inputs.Product ID}}", "method": "GET", "path": "/v1/products/{{inputs.Product ID}}", "inputs": [{"name":"Product ID","required":true,"mapTo":"Product ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "product_pricing", "name": "Pax8 Product Pricing", "description": "GET /v1/products/{{inputs.Product ID}}/pricing", "method": "GET", "path": "/v1/products/{{inputs.Product ID}}/pricing", "inputs": [{"name":"Product ID","required":true,"mapTo":"Product ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscriptions_list", "name": "Pax8 Subscriptions List", "description": "GET /v1/subscriptions", "method": "GET", "path": "/v1/subscriptions", "inputs": [{"name":"Company ID","required":false,"mapTo":"companyId"},{"name":"Product ID","required":false,"mapTo":"productId"},{"name":"Status","required":false,"mapTo":"status"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscription_retrieve", "name": "Pax8 Subscription Retrieve", "description": "GET /v1/subscriptions/{{inputs.Subscription ID}}", "method": "GET", "path": "/v1/subscriptions/{{inputs.Subscription ID}}", "inputs": [{"name":"Subscription ID","required":true,"mapTo":"Subscription ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscription_create", "name": "Pax8 Subscription Create", "description": "POST /v1/subscriptions", "method": "POST", "path": "/v1/subscriptions", "inputs": [{"name":"Company ID","required":true,"mapTo":"companyId"},{"name":"Product ID","required":true,"mapTo":"productId"},{"name":"Quantity","required":true,"mapTo":"quantity"},{"name":"Billing Term","required":true,"mapTo":"billingTerm"},{"name":"Commitment Term ID","required":false,"mapTo":"commitmentTermId"},{"name":"Start Date","required":false,"mapTo":"startDate"}], "outputs": [{"name":"Subscription ID","path":"id"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscription_update_quantity", "name": "Pax8 Subscription Update Quantity", "description": "PUT /v1/subscriptions/{{inputs.Subscription ID}}/quantity", "method": "PUT", "path": "/v1/subscriptions/{{inputs.Subscription ID}}/quantity", "inputs": [{"name":"Subscription ID","required":true,"mapTo":"Subscription ID"},{"name":"Quantity","required":true,"mapTo":"quantity"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscription_cancel", "name": "Pax8 Subscription Cancel", "description": "POST /v1/subscriptions/{{inputs.Subscription ID}}/cancel", "method": "POST", "path": "/v1/subscriptions/{{inputs.Subscription ID}}/cancel", "inputs": [{"name":"Subscription ID","required":true,"mapTo":"Subscription ID"},{"name":"Cancellation Reason","required":false,"mapTo":"reason"},{"name":"Cancel Date","required":false,"mapTo":"cancelDate"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "subscription_reactivate", "name": "Pax8 Subscription Reactivate", "description": "POST /v1/subscriptions/{{inputs.Subscription ID}}/reactivate", "method": "POST", "path": "/v1/subscriptions/{{inputs.Subscription ID}}/reactivate", "inputs": [{"name":"Subscription ID","required":true,"mapTo":"Subscription ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "orders_list", "name": "Pax8 Orders List", "description": "GET /v1/orders", "method": "GET", "path": "/v1/orders", "inputs": [{"name":"Company ID","required":false,"mapTo":"companyId"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "order_retrieve", "name": "Pax8 Order Retrieve", "description": "GET /v1/orders/{{inputs.Order ID}}", "method": "GET", "path": "/v1/orders/{{inputs.Order ID}}", "inputs": [{"name":"Order ID","required":true,"mapTo":"Order ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "usage_summaries_list", "name": "Pax8 Usage Summaries List", "description": "GET /v1/usage-summaries", "method": "GET", "path": "/v1/usage-summaries", "inputs": [{"name":"Company ID","required":false,"mapTo":"companyId"},{"name":"Start Period","required":false,"mapTo":"startPeriod"},{"name":"End Period","required":false,"mapTo":"endPeriod"},{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "invoices_list", "name": "Pax8 Invoices List", "description": "GET /v1/invoices", "method": "GET", "path": "/v1/invoices", "inputs": [{"name":"Page","required":false,"mapTo":"page"},{"name":"Size","required":false,"mapTo":"size"}], "outputs": [{"name":"Content","path":"content"},{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "invoice_retrieve", "name": "Pax8 Invoice Retrieve", "description": "GET /v1/invoices/{{inputs.Invoice ID}}", "method": "GET", "path": "/v1/invoices/{{inputs.Invoice ID}}", "inputs": [{"name":"Invoice ID","required":true,"mapTo":"Invoice ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] },
    { "id": "invoice_details", "name": "Pax8 Invoice Details", "description": "GET /v1/invoices/{{inputs.Invoice ID}}/details", "method": "GET", "path": "/v1/invoices/{{inputs.Invoice ID}}/details", "inputs": [{"name":"Invoice ID","required":true,"mapTo":"Invoice ID"}], "outputs": [{"name":"Response Body","path":"response_body"},{"name":"Response Code","path":"response_code"}] }
  ]
}
