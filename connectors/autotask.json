      "name": "Autotask Connection Test",
      "description": "GET /V1.0/Version",
      "method": "GET",
      "path": "/V1.0/Version",
      "inputs": [],
      "outputs": [
        { "name": "Response Code", "path": "response_code" },
        { "name": "Connected", "path": "connected" }
      ]
    },
    {
