{
  "id": "autotask",
  "service": "Autotask",
  "version": 1,
  "category": "ITSM & Service Management",
  "description": "Autotask PSA integration with 36 pre-built routines covering tickets, companies, contacts, contracts, configuration items, projects, tasks, time entries, expenses, opportunities, quotes, invoices, and service calls.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Autotask API user username (typically an email-like string created under Admin > Resources (Users) > API User)."
      },
      {
        "name": "secret",
        "required": true,
        "description": "Autotask API user secret (password).",
        "encrypted": true
      },
      {
        "name": "integration_code",
        "required": true,
        "description": "Autotask ApiIntegrationCode (tracking identifier). Sent with every request as the ApiIntegrationCode header.",
        "encrypted": true
      },
      {
        "name": "zone_url",
        "required": true,
        "description": "Zone-specific base URL for this Autotask account, e.g. https://webservices14.autotask.net/ATServicesRest. Retrieve via GET /ATServicesRest/V1.0/zoneInformation?user=<username>."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#E31E24\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">AT</text></svg>",
  "docsUrl": "https://ww19.autotask.net/help/DeveloperHelp/Content/APIs/REST/REST_API_Home.htm",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "baseUrl": "https://ZONE.autotask.net/ATServicesRest",
