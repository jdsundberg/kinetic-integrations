{
  "id": "plivo",
  "service": "Plivo",
  "version": 1,
  "category": "Communication",
  "description": "Plivo integration with 5 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "auth_id",
        "required": true,
        "description": "Plivo Auth ID."
      },
      {
        "name": "auth_token",
        "required": true,
        "description": "Plivo Auth Token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#57BE56\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">P</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "call_create",
      "name": "Plivo Call Create",
      "description": "Plivo Call Create.",
      "method": "POST",
      "path": "/v1/Account/Call/",
      "inputs": [
        {
          "name": "From",
          "required": true,
          "mapTo": "From"
        },
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "Answer Url",
          "required": true,
          "mapTo": "Answer Url"
        },
        {
          "name": "Answer Method",
          "required": false,
          "mapTo": "Answer Method"
        }
      ],
      "outputs": [
        {
          "name": "Request UUID",
          "path": "request_uuid"
        },
        {
          "name": "API ID",
          "path": "api_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "message_retrieve",
      "name": "Plivo Message Retrieve",
      "description": "Plivo Message Retrieve.",
      "method": "GET",
      "path": "/v1/Account/Message/{{inputs.Message Uuid}}/",
      "inputs": [
        {
          "name": "Message Uuid",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Message UUID",
          "path": "message_uuid"
        },
        {
          "name": "From",
          "path": "from"
        },
        {
          "name": "To",
          "path": "to"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Message JSON",
          "path": "message_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "number_search",
      "name": "Plivo Number Search",
      "description": "Plivo Number Search.",
      "method": "GET",
      "path": "/v1/Account/PhoneNumber/?country_iso={{inputs.Country Iso}}&type={{inputs.Type}}&limit={{inputs.Limit}}",
      "inputs": [
        {
          "name": "Country Iso",
          "required": true
        },
        {
          "name": "Type",
          "required": false
        },
        {
          "name": "Limit",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "Numbers JSON",
          "path": "numbers_json"
        },
        {
          "name": "API ID",
          "path": "api_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "sms_send",
      "name": "Plivo SMS Send",
      "description": "Plivo SMS Send.",
      "method": "POST",
      "path": "/v1/Account/Message/",
      "inputs": [
        {
          "name": "Src",
          "required": true,
          "mapTo": "Src"
        },
        {
          "name": "Dst",
          "required": true,
          "mapTo": "Dst"
        },
        {
          "name": "Text",
          "required": true,
          "mapTo": "Text"
        },
        {
          "name": "Url",
          "required": false,
          "mapTo": "Url"
        }
      ],
      "outputs": [
        {
          "name": "Message UUID",
          "path": "message_uuid"
        },
        {
          "name": "API ID",
          "path": "api_id"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Plivo Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ],
  "baseUrl": "https://api.plivo.com"
}
