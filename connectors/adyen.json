{
  "id": "adyen",
  "service": "Adyen",
  "version": 1,
  "category": "Finance & Payments",
  "description": "Adyen integration with 4 pre-built routines.",
  "auth": {
    "type": "apikey",
    "properties": [
      {
        "name": "api_key",
        "required": true,
        "description": "API key.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "base url."
      },
      {
        "name": "merchant_account",
        "required": true,
        "description": "merchant account."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#0ABF53\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "payment_capture",
      "name": "Adyen Payment Capture",
      "description": "POST /v71/payments/{paymentPspReference}/captures",
      "method": "POST",
      "path": "/v71/payments/{{inputs.Paymentpspreference}}/captures",
      "inputs": [
        {
          "name": "PSP Reference",
          "required": true,
          "mapTo": "PSP Reference"
        },
        {
          "name": "Amount Value",
          "required": true,
          "mapTo": "Amount Value"
        },
        {
          "name": "Amount Currency",
          "required": true,
          "mapTo": "Amount Currency"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "PSP Reference",
          "path": "pspReference"
        }
      ]
    },
    {
      "id": "payment_create",
      "name": "Adyen Payment Create",
      "description": "POST /v71/payments",
      "method": "POST",
      "path": "/v71/payments",
      "inputs": [
        {
          "name": "Amount Value",
          "required": true,
          "mapTo": "Amount Value"
        },
        {
          "name": "Amount Currency",
          "required": true,
          "mapTo": "Amount Currency"
        },
        {
          "name": "Reference",
          "required": true,
          "mapTo": "Reference"
        },
        {
          "name": "Payment Method JSON",
          "required": true,
          "mapTo": "Payment Method JSON"
        }
      ],
      "outputs": [
        {
          "name": "PSP Reference",
          "path": "pspReference"
        },
        {
          "name": "Result Code",
          "path": "resultCode"
        }
      ]
    },
    {
      "id": "refund_create",
      "name": "Adyen Refund Create",
      "description": "POST /v71/payments/{paymentPspReference}/refunds",
      "method": "POST",
      "path": "/v71/payments/{{inputs.Paymentpspreference}}/refunds",
      "inputs": [
        {
          "name": "PSP Reference",
          "required": true,
          "mapTo": "PSP Reference"
        },
        {
          "name": "Amount Value",
          "required": true,
          "mapTo": "Amount Value"
        },
        {
          "name": "Amount Currency",
          "required": true,
          "mapTo": "Amount Currency"
        }
      ],
      "outputs": [
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "PSP Reference",
          "path": "pspReference"
        }
      ]
    },
    {
      "id": "test",
      "name": "Adyen Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}