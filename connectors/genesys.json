{
  "id": "genesys",
  "service": "Genesys",
  "version": 1,
  "category": "Other",
  "description": "Genesys integration with 3 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      },
      {
        "name": "region",
        "required": true,
        "description": "region."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#1565C0\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">G</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "conversation_list",
      "name": "Genesys Cloud Conversation List",
      "description": "GET /api/v2/analytics/conversations",
      "method": "GET",
      "path": "/api/v2/analytics/conversations",
      "inputs": [],
      "outputs": [
        {
          "name": "Conversations JSON",
          "path": "conversations"
        }
      ]
    },
    {
      "id": "test",
      "name": "Genesys Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    },
    {
      "id": "user_list",
      "name": "Genesys Cloud User List",
      "description": "GET /api/v2/users",
      "method": "GET",
      "path": "/api/v2/users",
      "inputs": [],
      "outputs": [
        {
          "name": "Users JSON",
          "path": "entities"
        }
      ]
    }
  ]
}