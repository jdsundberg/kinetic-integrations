{
  "id": "dbt-cloud",
  "service": "Dbt Cloud",
  "version": 1,
  "category": "Data & Analytics",
  "description": "Dbt Cloud integration with 2 pre-built routines.",
  "auth": {
    "type": "bearer",
    "properties": [
      {
        "name": "access_token",
        "required": true,
        "description": "API access token or bearer token.",
        "encrypted": true
      },
      {
        "name": "account_id",
        "required": true,
        "description": "account id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#7B1FA2\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">D</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "job_run",
      "name": "dbt Cloud Job Run",
      "description": "POST /api/v2/accounts/{account_id}/jobs/{job_id}/run/",
      "method": "POST",
      "path": "/api/v2/accounts/{account_id}/jobs/{job_id}/run/",
      "inputs": [
        {
          "name": "Account ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Job ID",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Cause",
          "required": true,
          "mapTo": "Cause"
        }
      ],
      "outputs": [
        {
          "name": "Run ID",
          "path": "data.id"
        },
        {
          "name": "Status",
          "path": "data.status_humanized"
        }
      ]
    },
    {
      "id": "test",
      "name": "Dbt Cloud Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}