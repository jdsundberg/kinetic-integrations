{
  "id": "azure-keyvault",
  "service": "Azure Keyvault",
  "version": 1,
  "category": "Cloud & Infrastructure",
  "description": "Azure Keyvault integration with 3 pre-built routines.",
  "auth": {
    "type": "oauth2",
    "properties": [
      {
        "name": "token_url",
        "required": true,
        "description": "OAuth2 token endpoint URL."
      },
      {
        "name": "client_id",
        "required": true,
        "description": "OAuth2 client ID."
      },
      {
        "name": "client_secret",
        "required": true,
        "description": "OAuth2 client secret.",
        "encrypted": true
      },
      {
        "name": "oauth_scope",
        "required": false,
        "description": "OAuth2 scope."
      },
      {
        "name": "tenant_id",
        "required": true,
        "description": "tenant id."
      },
      {
        "name": "vault_url",
        "required": true,
        "description": "vault url."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#C62828\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">A</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "secret_get",
      "name": "Azure Key Vault Get Secret",
      "description": "GET /secrets/{secret_name}?api-version=7.4",
      "method": "GET",
      "path": "/secrets/{secret_name}?api-version=7.4",
      "inputs": [
        {
          "name": "Secret Name",
          "required": true,
          "pathParam": true
        }
      ],
      "outputs": [
        {
          "name": "Value",
          "path": "value"
        },
        {
          "name": "ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "secret_set",
      "name": "Azure Key Vault Set Secret",
      "description": "PUT /secrets/{secret_name}?api-version=7.4",
      "method": "PUT",
      "path": "/secrets/{secret_name}?api-version=7.4",
      "inputs": [
        {
          "name": "Secret Name",
          "required": true,
          "pathParam": true
        },
        {
          "name": "Value",
          "required": true,
          "mapTo": "Value"
        }
      ],
      "outputs": [
        {
          "name": "ID",
          "path": "id"
        }
      ]
    },
    {
      "id": "test",
      "name": "Azure Keyvault Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}