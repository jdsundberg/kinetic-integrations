{
  "id": "jenkins",
  "service": "Jenkins",
  "version": 1,
  "category": "DevOps & Collaboration",
  "description": "Jenkins integration with 5 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "base_url",
        "required": true,
        "description": "Jenkins base URL (e.g. https://jenkins.myco.com)."
      },
      {
        "name": "api_token",
        "required": true,
        "description": "Jenkins API token.",
        "encrypted": true
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"#D24939\"><path d=\"M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm0 22a10 10 0 110-20 10 10 0 010 20zm-2-15a2 2 0 114 0c0 .8-.5 1.5-1.2 1.8l.7 3.2H10.5l.7-3.2A2 2 0 0110 7zm-1 8h6v4H9v-4z\"/></svg>",
  "docsUrl": "https://www.jenkins.io/doc/book/using/remote-access-api/",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "build_info",
      "name": "Jenkins Build Info",
      "description": "GET /job/{{inputs.Job Name}}/{{inputs.Build Number}}/api/json",
      "method": "GET",
      "path": "/job/{{inputs.Job Name}}/{{inputs.Build Number}}/api/json",
      "inputs": [
        {
          "name": "Job Name",
          "required": true
        },
        {
          "name": "Build Number",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Build Number",
          "path": "build_number"
        },
        {
          "name": "Result",
          "path": "result"
        },
        {
          "name": "Duration",
          "path": "duration"
        },
        {
          "name": "Timestamp",
          "path": "timestamp"
        },
        {
          "name": "Building",
          "path": "building"
        },
        {
          "name": "Build JSON",
          "path": "build_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "job_retrieve",
      "name": "Jenkins Job Retrieve",
      "description": "GET /job/{{inputs.Job Name}}/api/json",
      "method": "GET",
      "path": "/job/{{inputs.Job Name}}/api/json",
      "inputs": [
        {
          "name": "Job Name",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "Name",
          "path": "name"
        },
        {
          "name": "URL",
          "path": "url"
        },
        {
          "name": "Color",
          "path": "color"
        },
        {
          "name": "Last Build Number",
          "path": "last_build_number"
        },
        {
          "name": "Last Build URL",
          "path": "last_build_url"
        },
        {
          "name": "Job JSON",
          "path": "job_json"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "job_trigger",
      "name": "Jenkins Job Trigger",
      "description": "POST /job/{{inputs.Job Name}}/buildWithParameters",
      "method": "POST",
      "path": "/job/{{inputs.Job Name}}/buildWithParameters",
      "inputs": [
        {
          "name": "Job Name",
          "required": true,
          "mapTo": "Job Name"
        },
        {
          "name": "Parameters Json",
          "required": false,
          "mapTo": "Parameters Json"
        }
      ],
      "outputs": [
        {
          "name": "Queue URL",
          "path": "queue_url"
        },
        {
          "name": "Status",
          "path": "status"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "node_list",
      "name": "Jenkins Node List",
      "description": "GET /computer/api/json",
      "method": "GET",
      "path": "/computer/api/json",
      "inputs": [],
      "outputs": [
        {
          "name": "Computers JSON",
          "path": "computers_json"
        },
        {
          "name": "Total Executors",
          "path": "total_executors"
        },
        {
          "name": "Busy Executors",
          "path": "busy_executors"
        },
        {
          "name": "Response Body",
          "path": "response_body"
        },
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Handler Error Message",
          "path": "handler_error_message"
        }
      ]
    },
    {
      "id": "test",
      "name": "Jenkins Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}