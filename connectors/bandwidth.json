{
  "id": "bandwidth",
  "service": "Bandwidth",
  "version": 1,
  "category": "Communication",
  "description": "Bandwidth integration with 2 pre-built routines.",
  "auth": {
    "type": "basic",
    "properties": [
      {
        "name": "username",
        "required": true,
        "description": "Username or email for authentication."
      },
      {
        "name": "password",
        "required": true,
        "description": "Password or API token.",
        "encrypted": true
      },
      {
        "name": "account_id",
        "required": true,
        "description": "account id."
      }
    ]
  },
  "icon": "<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#079CEE\"/><text x=\"12\" y=\"16.5\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" font-family=\"sans-serif\" fill=\"white\">B</text></svg>",
  "defaultHeaders": {
    "Accept": "application/json",
    "Content-Type": "application/json"
  },
  "routines": [
    {
      "id": "message_send",
      "name": "Bandwidth Message Send",
      "description": "POST /api/v2/users/{account_id}/messages",
      "method": "POST",
      "path": "/api/v2/users/{account_id}/messages",
      "inputs": [
        {
          "name": "From",
          "required": true,
          "mapTo": "From"
        },
        {
          "name": "To",
          "required": true,
          "mapTo": "To"
        },
        {
          "name": "Text",
          "required": true,
          "mapTo": "Text"
        }
      ],
      "outputs": [
        {
          "name": "Message ID",
          "path": "id"
        },
        {
          "name": "Direction",
          "path": "direction"
        }
      ]
    },
    {
      "id": "test",
      "name": "Bandwidth Connection Test",
      "description": "GET /",
      "method": "GET",
      "path": "/",
      "inputs": [],
      "outputs": [
        {
          "name": "Response Code",
          "path": "response_code"
        },
        {
          "name": "Connected",
          "path": "connected"
        }
      ]
    }
  ]
}